<UserControl x:Class="DialogEditor.WPF.Views.ConversationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
             xmlns:vm="clr-namespace:DialogEditor.WPF.ViewModels"
             xmlns:models="clr-namespace:DialogEditor.Core.Models;assembly=DialogEditor.Core">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252525" Padding="8,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{StaticResource Legend_Control_Fit}"
                            Command="{x:Static nodify:EditorCommands.FitToScreen}"
                            CommandTarget="{Binding ElementName=Editor}"
                            Style="{StaticResource CanvasToolButton}"
                            ToolTip="{StaticResource ToolTip_FitToScreen}"/>
                    <Button Content="+"
                            Command="{x:Static nodify:EditorCommands.ZoomIn}"
                            CommandTarget="{Binding ElementName=Editor}"
                            Style="{StaticResource CanvasToolButton}" Margin="4,0,0,0"
                            ToolTip="{StaticResource ToolTip_ZoomIn}"/>
                    <Button Content="&#x2212;"
                            Command="{x:Static nodify:EditorCommands.ZoomOut}"
                            CommandTarget="{Binding ElementName=Editor}"
                            Style="{StaticResource CanvasToolButton}" Margin="2,0,0,0"
                            ToolTip="{StaticResource ToolTip_ZoomOut}"/>
                    <Button Content="&#x2302;"
                            Click="CenterOnRoot_Click"
                            Style="{StaticResource CanvasToolButton}" Margin="8,0,0,0"
                            ToolTip="{StaticResource ToolTip_JumpToRoot}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding NodeCountText}"
                           Foreground="#888" FontSize="10" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Grid VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Background="#333" Foreground="#ccc" CaretBrush="#ccc"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="6,2,24,2" FontSize="10"
                             VerticalContentAlignment="Center"
                             KeyDown="SearchBox_KeyDown"
                             ToolTip="{StaticResource ToolTip_SearchNodes}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="#2a2a2a"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Placeholder -->
                    <TextBlock Text="{StaticResource Placeholder_SearchNodes}" Foreground="#555" FontSize="10"
                               Padding="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Clear button -->
                    <Button Command="{Binding ClearSearchCommand}"
                            HorizontalAlignment="Right" Width="20"
                            Content="&#x2715;" VerticalAlignment="Center"
                            Style="{StaticResource FlatIconButton}"
                            ToolTip="{StaticResource ToolTip_ClearSearch}"/>
                </Grid>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <nodify:NodifyEditor x:Name="Editor"
                                 Background="#7a6a8e"
                                 ItemsSource="{Binding Nodes}"
                                 Connections="{Binding Connections}">

                <nodify:NodifyEditor.ItemContainerStyle>
                    <Style TargetType="{x:Type nodify:ItemContainer}">
                        <Setter Property="Location" Value="{Binding Location, Mode=TwoWay,
                                                   Converter={StaticResource LayoutPointConverter}}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchMatch}" Value="False">
                                <Setter Property="Opacity" Value="0.2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </nodify:NodifyEditor.ItemContainerStyle>

                <nodify:NodifyEditor.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                        <nodify:Node Input="{Binding Inputs}"
                                     Output="{Binding Outputs}">

                            <nodify:Node.InputConnectorTemplate>
                                <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                                    <nodify:NodeInput Anchor="{Binding Anchor, Mode=OneWayToSource,
                                                                  Converter={StaticResource LayoutPointConverter}}"
                                                      IsConnected="True"/>
                                </DataTemplate>
                            </nodify:Node.InputConnectorTemplate>

                            <nodify:Node.OutputConnectorTemplate>
                                <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                                    <nodify:NodeOutput Anchor="{Binding Anchor, Mode=OneWayToSource,
                                                                   Converter={StaticResource LayoutPointConverter}}"
                                                       IsConnected="True"/>
                                </DataTemplate>
                            </nodify:Node.OutputConnectorTemplate>

                            <Grid Width="200">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{Binding SpeakerCategory, Converter={StaticResource SpeakerCategoryToBrush}}"
                                        CornerRadius="2,2,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="White" FontWeight="Bold"
                                               FontSize="10" Padding="6,3"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding TextPreview}"
                                           TextWrapping="Wrap"
                                           Padding="6,4"
                                           FontSize="10"
                                           Foreground="#333"
                                           MaxHeight="70">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Background" Value="#F5F0D0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SpeakerCategory}" Value="{x:Static models:SpeakerCategory.Player}">
                                                    <Setter Property="Background" Value="#D5E8F5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SpeakerCategory}" Value="{x:Static models:SpeakerCategory.Narrator}">
                                                    <Setter Property="Background" Value="#D5F0E8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SpeakerCategory}" Value="{x:Static models:SpeakerCategory.Script}">
                                                    <Setter Property="Background" Value="#E0E0E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Border Grid.Row="2" Padding="6,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8E0B0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SpeakerCategory}" Value="{x:Static models:SpeakerCategory.Player}">
                                                    <Setter Property="Background" Value="#B0CDE8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SpeakerCategory}" Value="{x:Static models:SpeakerCategory.Narrator}">
                                                    <Setter Property="Background" Value="#B0E0D5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SpeakerCategory}" Value="{x:Static models:SpeakerCategory.Script}">
                                                    <Setter Property="Background" Value="#C8C8C8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding FooterText}"
                                               FontSize="9" Foreground="#666"/>
                                </Border>
                            </Grid>

                        </nodify:Node>
                    </DataTemplate>
                </nodify:NodifyEditor.ItemTemplate>

                <nodify:NodifyEditor.ConnectionTemplate>
                    <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                        <nodify:Connection Source="{Binding Source.Anchor,
                                                      Converter={StaticResource LayoutPointConverter}}"
                                           Target="{Binding Target.Anchor,
                                                    Converter={StaticResource LayoutPointConverter}}">
                            <nodify:Connection.Style>
                                <Style TargetType="nodify:Connection">
                                    <Setter Property="Stroke" Value="#aaa"/>
                                    <Setter Property="StrokeThickness" Value="1.5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QuestionNodeTextDisplay}" Value="Never">
                                            <Setter Property="Stroke" Value="#555"/>
                                            <Setter Property="StrokeDashArray" Value="4,3"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QuestionNodeTextDisplay}" Value="Always">
                                            <Setter Property="Stroke" Value="#b8760a"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                            <Setter Property="Stroke" Value="White"/>
                                            <Setter Property="StrokeThickness" Value="2.5"/>
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsHighlighted}" Value="True"/>
                                                <Condition Binding="{Binding QuestionNodeTextDisplay}" Value="Always"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Stroke" Value="#f0a830"/>
                                            <Setter Property="StrokeThickness" Value="2.5"/>
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsHighlighted}" Value="True"/>
                                                <Condition Binding="{Binding QuestionNodeTextDisplay}" Value="Never"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Stroke" Value="#bbb"/>
                                            <Setter Property="StrokeThickness" Value="2.5"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </nodify:Connection.Style>
                        </nodify:Connection>
                    </DataTemplate>
                </nodify:NodifyEditor.ConnectionTemplate>

            </nodify:NodifyEditor>

            <nodify:Minimap
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="8" Width="160" Height="110"
                IsReadOnly="False"
                Background="#1a1a2a"
                ToolTip="{StaticResource ToolTip_Minimap}"
                ItemsSource="{Binding Nodes}"
                ViewportLocation="{Binding ViewportLocation, ElementName=Editor, Mode=TwoWay}"
                ViewportSize="{Binding ViewportSize, ElementName=Editor}">
                <nodify:Minimap.ItemContainerStyle>
                    <Style TargetType="nodify:MinimapItem">
                        <Setter Property="Location" Value="{Binding Location,
                                           Converter={StaticResource LayoutPointConverter}}"/>
                        <Setter Property="Width" Value="200"/>
                        <Setter Property="Height" Value="80"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="nodify:MinimapItem">
                                    <Border Background="{Binding SpeakerCategory, Converter={StaticResource SpeakerCategoryToBrush}}"
                                            CornerRadius="2"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </nodify:Minimap.ItemContainerStyle>
            </nodify:Minimap>

        </Grid>
    </Grid>
</UserControl>
