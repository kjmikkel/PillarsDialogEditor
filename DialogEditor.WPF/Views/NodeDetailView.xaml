<UserControl x:Class="DialogEditor.WPF.Views.NodeDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{StaticResource Label_SelectNode}"
                   Foreground="#555" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding HasContent, Converter={StaticResource InverseBoolToVis}}"/>

        <ScrollViewer Grid.Row="0" Background="#2d2d2d"
                      Visibility="{Binding HasContent, Converter={StaticResource BoolToVis}}">
            <StackPanel Margin="8">

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_Node}" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Foreground="White" FontSize="11">
                        <Run Text="{Binding NodeId}"/>
                        <Run Text=" &#x2014; "/>
                        <Run Text="{Binding NodeType}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_Speaker}" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding SpeakerName}" Foreground="#5dade2" FontSize="11"/>
                    <TextBlock Text="{Binding SpeakerGuid}" Foreground="#555" FontSize="9"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_Listener}" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding ListenerName}" Foreground="#aaa" FontSize="11"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_DefaultMaleText}" Style="{StaticResource LabelStyle}"/>
                    <Border Background="#1a1a1a" Padding="6" CornerRadius="3">
                        <TextBlock Text="{Binding DefaultText}"
                                   Foreground="#e8e8e8" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_FemaleText}" Style="{StaticResource LabelStyle}"/>
                    <Border Background="#1a1a1a" Padding="6" CornerRadius="3">
                        <TextBlock Text="{Binding FemaleTextDisplay}"
                                   Foreground="{Binding HasFemaleText, Converter={StaticResource BoolToFemaleTextBrush}}"
                                   FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10"
                            Visibility="{Binding HasComments, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{StaticResource Label_Comments}" Style="{StaticResource LabelStyle}"/>
                    <Border Background="#1a1a1a" Padding="6" CornerRadius="3">
                        <TextBlock Text="{Binding Comments}"
                                   Foreground="#c9a84c" FontSize="10" FontStyle="Italic"
                                   TextWrapping="Wrap" LineHeight="16"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_Conditions}" Style="{StaticResource LabelStyle}"/>
                    <Border Background="#1a1a1a" Padding="6" CornerRadius="3">
                        <TextBlock Text="{Binding ConditionsText}"
                                   Foreground="#e8a020" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_DisplayPersist}" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Foreground="#aaa" FontSize="11">
                        <Run Text="{Binding DisplayType}"/>
                        <Run Text=" &#xB7; "/>
                        <Run Text="{Binding Persistence}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Margin="0,0,0,10"
                            Visibility="{Binding HasActorDirection, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{StaticResource Label_ActorDirection}" Style="{StaticResource LabelStyle}"/>
                    <Border Background="#1a1a1a" Padding="6" CornerRadius="3">
                        <TextBlock Text="{Binding ActorDirection}"
                                   Foreground="#c9a84c" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16" FontStyle="Italic"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_Scripts}" Style="{StaticResource LabelStyle}"/>
                    <Border Background="#1a1a1a" Padding="6" CornerRadius="3">
                        <TextBlock Text="{Binding ScriptsText}"
                                   Foreground="#7dcea0" FontSize="10"
                                   TextWrapping="Wrap" LineHeight="16"/>
                    </Border>
                </StackPanel>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="{StaticResource Label_LinksTo}" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding LinksTo}"
                               Foreground="#5dade2" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,0"
                            Visibility="{Binding HasVoiceSection, Converter={StaticResource BoolToVis}}">
                    <Border Background="#1e2a1e" BorderBrush="#2a3a2a" BorderThickness="1"
                            CornerRadius="3" Padding="8,6">
                        <StackPanel>
                            <TextBlock Text="{StaticResource Label_Voice}" Style="{StaticResource LabelStyle}"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,3"
                                  Visibility="{Binding HasExternalVO, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Label_File}" Foreground="#666" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{Binding ExternalVO}"
                                           Foreground="#e8e8e8" FontSize="9" TextWrapping="Wrap"
                                           FontFamily="Consolas"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Label_HasVO}" Foreground="#666" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{Binding HasVO}"
                                           Foreground="#7dcea0" FontSize="10"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Label_HideSpeaker}" Foreground="#666" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{Binding HideSpeaker}"
                                           Foreground="#e8a020" FontSize="10"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
