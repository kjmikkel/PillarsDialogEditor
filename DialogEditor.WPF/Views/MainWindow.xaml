<Window x:Class="DialogEditor.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DialogEditor.WPF.Views"
        Title="Pillars Dialog Editor"
        Icon="/app.ico"
        Width="1400" Height="850"
        Background="#1e1e1e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252525" Padding="6,4">
            <DockPanel>
                <ToggleButton x:Name="HelpToggle"
                              DockPanel.Dock="Right"
                              Content="?"
                              Style="{StaticResource HelpToggleButton}"
                              ToolTip="{StaticResource ToolTip_HelpToggle}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenFolderCommand}"
                            Content="{StaticResource Button_OpenFolder}"
                            Foreground="White"
                            Style="{StaticResource CanvasToolButton}"
                            ToolTip="{StaticResource ToolTip_OpenFolder}"/>
                    <Rectangle Width="1" Fill="#444" Margin="8,0" VerticalAlignment="Stretch"/>
                    <TextBlock Text="{StaticResource Label_Language}" Foreground="#888" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Visibility="{Binding AvailableLanguages.Count, Converter={StaticResource CountToVis}}"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                              MinWidth="60"
                              ToolTip="{StaticResource ToolTip_Language}"
                              Visibility="{Binding AvailableLanguages.Count, Converter={StaticResource CountToVis}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="240" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <views:GameBrowserView Grid.Column="0" DataContext="{Binding Browser}"/>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#333"/>
            <views:ConversationView Grid.Column="2" DataContext="{Binding Canvas}"/>
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#333"/>
            <views:NodeDetailView Grid.Column="4" DataContext="{Binding Detail}"/>

            <!-- Legend overlay -->
            <Border Grid.ColumnSpan="5"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Panel.ZIndex="20"
                    Width="280" Margin="0,6,12,0"
                    Background="#1a1a2a" BorderBrush="#3a3a5a" BorderThickness="1"
                    CornerRadius="4"
                    Visibility="{Binding IsChecked, ElementName=HelpToggle,
                                         Converter={StaticResource BoolToVis}}">
                <DockPanel>

                    <Border DockPanel.Dock="Top" Background="#252535"
                            CornerRadius="4,4,0,0" Padding="10,6">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="&#x2715;"
                                    Style="{StaticResource FlatIconButton}"
                                    Click="CloseHelp_Click"
                                    ToolTip="{StaticResource ToolTip_CloseLegend}"/>
                            <TextBlock Text="{StaticResource Legend_Header}" Foreground="#888"
                                       FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                        <StackPanel>

                            <!-- Connections -->
                            <TextBlock Text="{StaticResource Legend_Connections}" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Grid Width="30" Height="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Line X1="0" Y1="3" X2="30" Y2="3" Stroke="#aaa" StrokeThickness="2"/>
                                </Grid>
                                <TextBlock Foreground="#ccc" FontSize="10" VerticalAlignment="Center">
                                    <Run FontWeight="Bold" Text="{StaticResource Legend_ShowOnce}"/>
                                    <Run Foreground="#888" Text="{StaticResource Legend_ShowOnce_Desc}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Grid Width="30" Height="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Line X1="0" Y1="3" X2="30" Y2="3" Stroke="#b8760a" StrokeThickness="2"/>
                                </Grid>
                                <TextBlock Foreground="#ccc" FontSize="10" VerticalAlignment="Center">
                                    <Run FontWeight="Bold" Text="{StaticResource Legend_Always}"/>
                                    <Run Foreground="#888" Text="{StaticResource Legend_Always_Desc}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Grid Width="30" Height="6" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Line X1="0" Y1="3" X2="30" Y2="3" Stroke="#555"
                                          StrokeThickness="2" StrokeDashArray="4,2"/>
                                </Grid>
                                <TextBlock Foreground="#ccc" FontSize="10" VerticalAlignment="Center">
                                    <Run FontWeight="Bold" Text="{StaticResource Legend_Never}"/>
                                    <Run Foreground="#888" Text="{StaticResource Legend_Never_Desc}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Node types -->
                            <TextBlock Text="{StaticResource Legend_NodeTypes}" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <Border Width="12" Height="12" Background="#F5F0D0"
                                        CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource Legend_NpcLine}"
                                           Foreground="#ccc" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <Border Width="12" Height="12" Background="#D5E8F5"
                                        CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="#ccc" FontSize="10" VerticalAlignment="Center">
                                    <Run Text="{StaticResource Legend_PlayerChoice}"/>
                                    <Run Foreground="#aaa" Text="{StaticResource Legend_PlayerChoiceMark}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <Border Width="12" Height="12" Background="#D5F0E8"
                                        CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource Legend_Narrator}"
                                           Foreground="#ccc" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="12" Height="12" Background="#E0E0E0"
                                        CornerRadius="2" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource Legend_ScriptAction}"
                                           Foreground="#ccc" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Symbols -->
                            <TextBlock Text="{StaticResource Legend_Symbols}" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>

                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⚙ N" Foreground="#e8a020" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Symbol_Conditions}"
                                           Foreground="#888" FontSize="10" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="♀" Foreground="#aaa" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Symbol_FemaleText}"
                                           Foreground="#888" FontSize="10" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✦" Foreground="#aaa" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Symbol_PlayerChoice}"
                                           Foreground="#888" FontSize="10" TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Canvas controls -->
                            <TextBlock Text="{StaticResource Legend_Canvas}" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>

                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Fit}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Fit_Desc}" Foreground="#888" FontSize="10"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Zoom}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Zoom_Desc}" Foreground="#888" FontSize="10"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Root}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Root_Desc}" Foreground="#888" FontSize="10"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Scroll}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Scroll_Desc}" Foreground="#888" FontSize="10"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Drag}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Drag_Desc}" Foreground="#888" FontSize="10"/>
                            </Grid>

                            <!-- Browser controls -->
                            <TextBlock Text="{StaticResource Legend_Browser}" Style="{StaticResource LabelStyle}" Margin="0,0,0,5"/>

                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_ExpandCollapse}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_ExpandCollapse_Desc}" Foreground="#888" FontSize="10"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Filter}" Foreground="#ccc" FontSize="10"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Filter_Desc}"
                                           Foreground="#888" FontSize="10" TextWrapping="Wrap"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Background="#1a1a1a">
            <TextBlock Text="{Binding StatusText}" Foreground="#888" FontSize="11"/>
        </StatusBar>
    </Grid>
</Window>
