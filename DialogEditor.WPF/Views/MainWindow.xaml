<Window x:Class="DialogEditor.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DialogEditor.WPF.Views"
        Title="Pillars Dialog Editor"
        Icon="/app.ico"
        Width="1400" Height="850"
        Background="#1e1e1e">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252525" Padding="6,4">
            <DockPanel>
                <ToggleButton x:Name="HelpToggle"
                              DockPanel.Dock="Right"
                              Content="?"
                              Style="{StaticResource HelpToggleButton}"
                              ToolTip="{StaticResource ToolTip_HelpToggle}"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding OpenFolderCommand}"
                            Content="{StaticResource Button_OpenFolder}"
                            Foreground="White"
                            Style="{StaticResource CanvasToolButton}"
                            ToolTip="{StaticResource ToolTip_OpenFolder}"/>
                    <Rectangle Width="1" Fill="#444" Margin="8,0" VerticalAlignment="Stretch"/>
                    <TextBlock Text="{StaticResource Label_Language}" Foreground="#888" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Visibility="{Binding AvailableLanguages.Count, Converter={StaticResource CountToVis}}"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                              MinWidth="60"
                              ToolTip="{StaticResource ToolTip_Language}"
                              Visibility="{Binding AvailableLanguages.Count, Converter={StaticResource CountToVis}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BrowserColumn" Width="220" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition x:Name="DetailColumn" Width="240" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- Browser panel (Column 0) -->
            <Grid x:Name="BrowserPanel" Grid.Column="0">
                <!-- Expanded state -->
                <Grid Visibility="{Binding IsBrowserExpanded, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <!-- Drop shadow when open as a temporary flyout -->
                                <DataTrigger Binding="{Binding IsBrowserFlyoutOpen}" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="18"
                                                             Color="Black" Opacity="0.65"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Panel.ZIndex" Value="5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Border Background="#252525" Padding="6,4">
                        <DockPanel>
                            <!-- Pin button only — no separate collapse button.
                                 Clicking pin opens+pins; clicking outside closes flyout. -->
                            <ToggleButton DockPanel.Dock="Right"
                                          IsChecked="{Binding IsBrowserPinned, Mode=TwoWay}"
                                          Content="&#x1F4CC;"
                                          Style="{StaticResource HelpToggleButton}"
                                          ToolTip="{StaticResource ToolTip_PinPanel}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,6,0">
                                <Button Command="{Binding Browser.ExpandAllCommand}" Content="⊞"
                                        Style="{StaticResource FlatIconButton}"
                                        ToolTip="{StaticResource ToolTip_ExpandAll}"/>
                                <Button Command="{Binding Browser.CollapseAllCommand}" Content="⊟" Margin="2,0,0,0"
                                        Style="{StaticResource FlatIconButton}"
                                        ToolTip="{StaticResource ToolTip_CollapseAll}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{StaticResource Browser_Header}"
                                           Foreground="#888" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentConversationName}"
                                           Foreground="#555" FontSize="10" Margin="6,0,0,0"
                                           Visibility="{Binding CurrentConversationName,
                                                        Converter={StaticResource NullOrEmptyToVis}}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <views:GameBrowserView Grid.Row="1" DataContext="{Binding Browser}"/>
                </Grid>
                <!-- Collapsed strip — pin opens+pins; title click opens as flyout -->
                <Grid Visibility="{Binding IsBrowserExpanded, Converter={StaticResource InverseBoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ToggleButton Grid.Row="0" Margin="4,4,4,0"
                                  IsChecked="{Binding IsBrowserPinned, Mode=TwoWay}"
                                  Content="&#x1F4CC;"
                                  Style="{StaticResource HelpToggleButton}"
                                  ToolTip="{StaticResource ToolTip_PinPanel}"/>
                    <TextBlock Grid.Row="1" Margin="0,10,0,0"
                               Text="{StaticResource Browser_Header}"
                               Foreground="#555" FontSize="10" FontWeight="Bold"
                               Cursor="Hand"
                               HorizontalAlignment="Center" VerticalAlignment="Top"
                               MouseDown="CollapsedBrowserTitle_MouseDown"
                               ToolTip="{StaticResource ToolTip_TogglePanel}">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="90"/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#333"/>
            <views:ConversationView x:Name="CanvasView" Grid.Column="2" DataContext="{Binding Canvas}"/>
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#333"/>

            <!-- Detail panel (Column 4) -->
            <Grid Grid.Column="4">
                <!-- Expanded state -->
                <Grid Visibility="{Binding IsDetailExpanded, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="#252525" Padding="6,4">
                        <DockPanel>
                            <ToggleButton DockPanel.Dock="Right"
                                          IsChecked="{Binding IsDetailExpanded, Mode=TwoWay}"
                                          Style="{StaticResource PanelCollapseButton}"
                                          ToolTip="{StaticResource ToolTip_TogglePanel}"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{StaticResource Label_NodeDetails}"
                                           Foreground="#888" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentConversationName}"
                                           Foreground="#555" FontSize="10" Margin="6,0,0,0"
                                           Visibility="{Binding CurrentConversationName,
                                                        Converter={StaticResource NullOrEmptyToVis}}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <views:NodeDetailView Grid.Row="1" DataContext="{Binding Detail}"/>
                </Grid>
                <!-- Collapsed strip -->
                <Grid Visibility="{Binding IsDetailExpanded, Converter={StaticResource InverseBoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ToggleButton Grid.Row="0" Margin="4,4,4,0"
                                  IsChecked="{Binding IsDetailExpanded, Mode=TwoWay}"
                                  Style="{StaticResource PanelCollapseButton}"
                                  ToolTip="{StaticResource ToolTip_TogglePanel}"/>
                    <TextBlock Grid.Row="1" Margin="0,10,0,0"
                               Text="{StaticResource Label_NodeDetails}"
                               Foreground="#555" FontSize="10" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Top">
                        <TextBlock.LayoutTransform>
                            <RotateTransform Angle="90"/>
                        </TextBlock.LayoutTransform>
                    </TextBlock>
                </Grid>
            </Grid>

            <!-- Legend overlay -->
            <Border Grid.ColumnSpan="5"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Panel.ZIndex="20"
                    Width="360" Margin="0,6,12,0"
                    Background="#1a1a2a" BorderBrush="#3a3a5a" BorderThickness="1"
                    CornerRadius="4"
                    Visibility="{Binding IsChecked, ElementName=HelpToggle,
                                         Converter={StaticResource BoolToVis}}">
                <DockPanel>

                    <Border DockPanel.Dock="Top" Background="#252535"
                            CornerRadius="4,4,0,0" Padding="10,6">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="&#x2715;"
                                    Style="{StaticResource FlatIconButton}"
                                    Click="CloseHelp_Click"
                                    ToolTip="{StaticResource ToolTip_CloseLegend}"/>
                            <TextBlock Text="{StaticResource Legend_Header}" Foreground="#888"
                                       FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                        <StackPanel>

                            <!-- Connections -->
                            <TextBlock Text="{StaticResource Legend_Connections}" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Grid Width="34" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Line X1="0" Y1="4" X2="34" Y2="4" Stroke="#aaa" StrokeThickness="2.5"/>
                                </Grid>
                                <TextBlock Foreground="#ccc" FontSize="12" VerticalAlignment="Center">
                                    <Run FontWeight="Bold" Text="{StaticResource Legend_ShowOnce}"/>
                                    <Run Foreground="#888" Text="{StaticResource Legend_ShowOnce_Desc}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Grid Width="34" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Line X1="0" Y1="4" X2="34" Y2="4" Stroke="#b8760a" StrokeThickness="2.5"/>
                                </Grid>
                                <TextBlock Foreground="#ccc" FontSize="12" VerticalAlignment="Center">
                                    <Run FontWeight="Bold" Text="{StaticResource Legend_Always}"/>
                                    <Run Foreground="#888" Text="{StaticResource Legend_Always_Desc}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Grid Width="34" Height="8" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Line X1="0" Y1="4" X2="34" Y2="4" Stroke="#555"
                                          StrokeThickness="2.5" StrokeDashArray="4,2"/>
                                </Grid>
                                <TextBlock Foreground="#ccc" FontSize="12" VerticalAlignment="Center">
                                    <Run FontWeight="Bold" Text="{StaticResource Legend_Never}"/>
                                    <Run Foreground="#888" Text="{StaticResource Legend_Never_Desc}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Node types -->
                            <TextBlock Text="{StaticResource Legend_NodeTypes}" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,0,6"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="14" Height="14" Background="#F5F0D0"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource Legend_NpcLine}"
                                           Foreground="#ccc" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="14" Height="14" Background="#D5E8F5"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="#ccc" FontSize="12" VerticalAlignment="Center">
                                    <Run Text="{StaticResource Legend_PlayerChoice}"/>
                                    <Run Foreground="#aaa" Text="{StaticResource Legend_PlayerChoiceMark}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border Width="14" Height="14" Background="#D5F0E8"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource Legend_Narrator}"
                                           Foreground="#ccc" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="14" Height="14" Background="#E0E0E0"
                                        CornerRadius="2" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{StaticResource Legend_ScriptAction}"
                                           Foreground="#ccc" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Symbols -->
                            <TextBlock Text="{StaticResource Legend_Symbols}" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,0,6"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⚙ N" Foreground="#e8a020" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Symbol_Conditions}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="♀" Foreground="#aaa" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Symbol_FemaleText}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✦" Foreground="#aaa" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Symbol_PlayerChoice}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Canvas controls -->
                            <TextBlock Text="{StaticResource Legend_Canvas}" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,0,6"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Fit}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Fit_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Zoom}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Zoom_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Root}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Root_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Scroll}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Scroll_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Drag}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Drag_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_CtrlF}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_CtrlF_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>

                            <!-- Browser controls -->
                            <TextBlock Text="{StaticResource Legend_Browser}" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,0,6"/>

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_ExpandCollapse}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_ExpandCollapse_Desc}" Foreground="#888" FontSize="12"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Filter}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Filter_Desc}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Control_Escape}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Control_Escape_Desc}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Browser_Pin}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Browser_Pin_Desc}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{StaticResource Legend_Browser_Flyout}" Foreground="#ccc" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{StaticResource Legend_Browser_Flyout_Desc}"
                                           Foreground="#888" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2" Background="#1a1a1a">
            <TextBlock Text="{Binding StatusText}" Foreground="#888" FontSize="11"/>
        </StatusBar>
    </Grid>
</Window>
