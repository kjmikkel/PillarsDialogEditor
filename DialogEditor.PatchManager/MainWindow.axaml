<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.PatchManager.MainWindow"
        Title="{StaticResource PatchManager_WindowTitle}"
        Icon="avares://DialogEditor.PatchManager/Assets/app.ico"
        Width="640" Height="580" MinWidth="500" MinHeight="420"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Surface.Window}"
        x:CompileBindings="False">
    <DockPanel>
        <!-- Standalone-only theme bar. Lives here (not in the shared PatchManagerView, which
             the editor also hosts) so it appears only in the standalone PatchManager. -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Surface.Header}"
                Padding="8,6">
            <shared:ThemePickerView x:Name="ThemePicker" HorizontalAlignment="Left"/>
        </Border>
        <shared:PatchManagerView/>
    </DockPanel>
</Window>
