<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DialogEditor.PatchManager.Converters"
             x:Class="DialogEditor.PatchManager.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter  x:Key="InverseBoolToVis"/>
            <converters:NullOrEmptyConverter  x:Key="NullOrEmptyToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
