<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:DialogEditor.PatchManager.Converters"
             x:Class="DialogEditor.PatchManager.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Layer 0 token registry (shared project): resolves the Brush.* keys that
                     PatchManagerView binds, so this standalone app renders identically to the
                     editor's hosted copy. -->
                <ResourceInclude Source="avares://DialogEditor.Avalonia.Shared/Resources/Palette.Dark.axaml"/>
                <ResourceInclude Source="avares://DialogEditor.Avalonia.Shared/Resources/Tokens.axaml"/>
                <ResourceInclude Source="avares://DialogEditor.Avalonia.Shared/Resources/SharedStrings.axaml"/>
                <ResourceInclude Source="avares://DialogEditor.PatchManager/Resources/Strings.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:InverseBoolConverter x:Key="InverseBoolToVis"/>
            <converters:NullOrEmptyConverter x:Key="NullOrEmptyToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
