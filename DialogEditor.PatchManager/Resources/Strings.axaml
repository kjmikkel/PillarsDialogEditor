<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Standalone-app-only strings (general editor keys not in the shared lib) -->
    <sys:String x:Key="PatchManager_WindowTitle">Patch Manager — Pillars Dialog Editor</sys:String>
    <sys:String x:Key="Dialog_SelectFolder">Select game root folder</sys:String>
    <sys:String x:Key="FileType_DialogProject">Dialog Project (*.dialogproject)</sys:String>
    <sys:String x:Key="Status_FolderNotRecognized">Folder not recognised as PoE1 or PoE2 root.</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="PatchManager_SettingsTitle">Patch Manager — Settings</sys:String>
    <sys:String x:Key="PatchManager_SettingsButton">⚙ Settings…</sys:String>
    <sys:String x:Key="PatchManager_SettingsTooltip">Open settings to change the colour theme and application language</sys:String>
    <sys:String x:Key="AutomationName_PatchManagerSettings">Settings</sys:String>

</ResourceDictionary>
