<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ─── Patch Manager strings — canonical, shared by editor and standalone ── -->

    <!-- Labels and button content -->
    <sys:String x:Key="PatchManager_Title">Patch Manager</sys:String>
    <sys:String x:Key="PatchManager_GameFolder">Game folder</sys:String>
    <sys:String x:Key="PatchManager_GameFolderWatermark">(no game folder selected)</sys:String>
    <sys:String x:Key="PatchManager_BrowseGame">Browse…</sys:String>
    <sys:String x:Key="PatchManager_LoadOrder">Load Order</sys:String>
    <sys:String x:Key="PatchManager_SaveLoadOrder">Save load order…</sys:String>
    <sys:String x:Key="PatchManager_LoadLoadOrder">Load load order…</sys:String>
    <sys:String x:Key="PatchManager_AddProjects">Add project(s)…</sys:String>
    <sys:String x:Key="PatchManager_Apply">Apply patches</sys:String>
    <sys:String x:Key="PatchManager_Applying">Applying…</sys:String>
    <sys:String x:Key="PatchManager_EmptyHint">Add .dialogproject files above. Lower entries win on conflict.</sys:String>
    <sys:String x:Key="PatchManager_OrderHint">↑ First applied   ↓ Last applied (wins on conflict)</sys:String>

    <!-- Status and error messages (used via Loc.Get/Format) -->
    <sys:String x:Key="PatchManager_NoConflicts">No conflicts detected.</sys:String>
    <sys:String x:Key="PatchManager_ConflictsFound">{0} conflict(s) detected — reorder so the version you want is lowest in the list.</sys:String>
    <sys:String x:Key="PatchManager_ApplySuccess">Applied {0} patch(es) to {1}.</sys:String>
    <sys:String x:Key="PatchManager_ApplyError">Apply failed: {0}</sys:String>
    <sys:String x:Key="PatchManager_LoadError">Could not load '{0}': {1}</sys:String>
    <sys:String x:Key="PatchManager_EntryConflict">⚠ conflicts with another project</sys:String>
    <sys:String x:Key="PatchManager_EntryConflictDetail">Conflicts with another project — move lower to override the other, or higher to be overridden</sys:String>
    <sys:String x:Key="PatchManager_EntryLoadError">⚠ could not load</sys:String>
    <sys:String x:Key="ToolTip_PatchManagerOpen">Open the Patch Manager to combine and apply multiple .dialogproject files in a defined load order</sys:String>

    <!-- Tooltips -->
    <sys:String x:Key="ToolTip_BrowseGameFolder">Select the root folder of your PoE1 or PoE2 installation</sys:String>
    <sys:String x:Key="ToolTip_AddProjects">Add one or more .dialogproject files to the load order</sys:String>
    <sys:String x:Key="ToolTip_SaveLoadOrder">Save the current load order to a .patchlist file for later reuse</sys:String>
    <sys:String x:Key="ToolTip_LoadLoadOrder">Open a previously saved .patchlist file</sys:String>
    <sys:String x:Key="ToolTip_MoveEntryUp">Move up — lower index is applied first; lower position wins on conflict</sys:String>
    <sys:String x:Key="ToolTip_MoveEntryDown">Move down — lower position in the list wins on conflict</sys:String>
    <sys:String x:Key="ToolTip_RemoveEntry">Remove from load order</sys:String>
    <sys:String x:Key="ToolTip_ApplyPatches">Apply all patches to the game folder in load order. Lower entries win on conflict.</sys:String>

    <!-- FileType descriptions (used by file pickers) -->
    <sys:String x:Key="FileType_PatchList">Patch list (*.patchlist)</sys:String>

    <!-- ─── Accessibility — screen-reader names for icon-only buttons ─────────── -->
    <sys:String x:Key="AutomationName_MovePatchUp">Move patch up</sys:String>
    <sys:String x:Key="AutomationName_MovePatchDown">Move patch down</sys:String>
    <sys:String x:Key="AutomationName_RemovePatch">Remove patch</sys:String>

    <!-- ─── Theme picker (Layer 2) — shared by editor and standalone PatchManager ── -->
    <sys:String x:Key="Settings_Theme">Theme</sys:String>
    <sys:String x:Key="Settings_ThemeTooltip">Choose the colour theme for the whole application. The change is applied immediately and remembered for next time. High Contrast and Colourblind improve readability for low vision and colour-vision deficiency.</sys:String>
    <sys:String x:Key="Theme_Name_Auto">System Default</sys:String>
    <sys:String x:Key="Theme_Name_Dark">Dark</sys:String>
    <sys:String x:Key="Theme_Name_Light">Light</sys:String>
    <sys:String x:Key="Theme_Name_Colourblind">Colourblind</sys:String>
    <sys:String x:Key="Theme_Name_HighContrast">High Contrast</sys:String>

    <!-- ─── First-run theme onboarding (Gaps item 15) — shared by editor and standalone PatchManager ── -->
    <sys:String x:Key="ThemeOnboarding_Title">Choose a Theme</sys:String>
    <sys:String x:Key="ThemeOnboarding_Intro">Pick a colour theme below — you can change this anytime later in Settings.</sys:String>
    <sys:String x:Key="ThemeOnboarding_PreviewLabel">Preview</sys:String>
    <sys:String x:Key="ThemeOnboarding_Continue">Continue</sys:String>
    <sys:String x:Key="ThemeOnboarding_Card_Npc">NPC</sys:String>
    <sys:String x:Key="ThemeOnboarding_Card_Player">Player</sys:String>
    <sys:String x:Key="ThemeOnboarding_Card_Narrator">Narrator</sys:String>
    <sys:String x:Key="ThemeOnboarding_Sample_Npc">"The road north is closed," the guard says.</sys:String>
    <sys:String x:Key="ThemeOnboarding_Sample_Player">[Persuade] Let us through — it's urgent.</sys:String>
    <sys:String x:Key="ThemeOnboarding_Sample_Narrator">The guard eyes you warily, hand on his sword.</sys:String>
    <sys:String x:Key="ThemeOnboarding_Badge_Warning">Warning</sys:String>
    <sys:String x:Key="ThemeOnboarding_Badge_Error">Error</sys:String>
    <sys:String x:Key="ThemeOnboarding_Button_Primary">Primary</sys:String>
    <sys:String x:Key="ThemeOnboarding_Button_Destructive">Destructive</sys:String>
    <sys:String x:Key="ThemeOnboarding_Button_Plain">Plain</sys:String>

</ResourceDictionary>
