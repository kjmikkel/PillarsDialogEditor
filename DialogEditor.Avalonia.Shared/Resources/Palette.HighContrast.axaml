<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  PALETTE — HIGH-CONTRAST set (Layer 1). Same Palette.* keys as Palette.Dark.axaml.
          Aim: WCAG AAA — text >=7:1, non-text UI (borders) >=4.5:1. Surfaces collapse to near-black;
          structure is carried by the bright Palette.Line.* borders and the visible
          Palette.Control.Background (the §3 split), NOT by surface-tone steps. Node cards stay light
          cards taken to the extreme (white bodies, black Ink). Header fills are kept (no consumer
          change) and deepened where needed for white text >=7. Keys matched by PaletteSetParityTests;
          values locked by PaletteGoldenTests; gated by PaletteContrastTests (AAA) +
          HighContrastBordersAreVisible. See spec docs/superpowers/specs/2026-06-09-layer1-highcontrast-design.md. -->

    <!-- Neutrals: surfaces -> black; text -> white/light; toolbar states -> visible mid-greys -->
    <Color x:Key="Palette.Neutral.80">#FF000000</Color>   <!-- input surface -->
    <Color x:Key="Palette.Neutral.100">#FF000000</Color>  <!-- card surface -->
    <Color x:Key="Palette.Neutral.115">#FF000000</Color>  <!-- window surface -->
    <Color x:Key="Palette.Neutral.125">#FF000000</Color>  <!-- inset surface -->
    <Color x:Key="Palette.Neutral.145">#FF000000</Color>  <!-- panel surface -->
    <Color x:Key="Palette.Neutral.175">#FF000000</Color>  <!-- subtle surface -->
    <Color x:Key="Palette.Neutral.200">#FF000000</Color>  <!-- header surface -->
    <Color x:Key="Palette.Neutral.225">#FF6D6D6D</Color>  <!-- toolbar checked -->
    <Color x:Key="Palette.Neutral.265">#FF5D5D5D</Color>  <!-- toolbar hover / checkedhover -->
    <Color x:Key="Palette.Neutral.290">#FF6D6D6D</Color>  <!-- toolbar pressed -->
    <Color x:Key="Palette.Neutral.335">#FF9A9A9A</Color>  <!-- border.muted / female.dim / connection.never -->
    <Color x:Key="Palette.Neutral.400">#FFB8B8B8</Color>  <!-- disabled text (brightened for HC; still dimmest, ~9:1) -->
    <Color x:Key="Palette.Neutral.535">#FFD4D4D4</Color>  <!-- muted text -->
    <Color x:Key="Palette.Neutral.600">#FFDCDCDC</Color>  <!-- caption text -->
    <Color x:Key="Palette.Neutral.665">#FFFFFFFF</Color>  <!-- toolbar fg / muted.light -->
    <Color x:Key="Palette.Neutral.735">#FFD6D6D6</Color>  <!-- tertiary text -->
    <Color x:Key="Palette.Neutral.785">#FFF0F0F0</Color>  <!-- script card footer (light) -->
    <Color x:Key="Palette.Neutral.800">#FFE6E6E6</Color>  <!-- secondary text -->
    <Color x:Key="Palette.Neutral.865">#FFF0F0F0</Color>  <!-- emphasis text -->
    <Color x:Key="Palette.Neutral.875">#FFFFFFFF</Color>  <!-- script card body (light) -->
    <Color x:Key="Palette.Neutral.910">#FFFFFFFF</Color>  <!-- primary text -->
    <Color x:Key="Palette.Black">#FF000000</Color>
    <Color x:Key="Palette.White">#FFFFFFFF</Color>

    <!-- Ink — dark-on-light node-card text (cards are white in HC) -->
    <Color x:Key="Palette.Ink.Strong">#FF000000</Color>
    <Color x:Key="Palette.Ink.Muted">#FF2A2A2A</Color>

    <!-- Line / Control — bright dividers + visible control backgrounds (the §3 split; gated >=4.5) -->
    <Color x:Key="Palette.Line.Subtle">#FF8C8C8C</Color>
    <Color x:Key="Palette.Line.Default">#FFA8A8A8</Color>
    <Color x:Key="Palette.Line.Strong">#FFFFFFFF</Color>
    <Color x:Key="Palette.Line.Muted">#FF6A6A6A</Color>
    <Color x:Key="Palette.Control.Background">#FF4D4D4D</Color>
    <Color x:Key="Palette.Connection.Base">#FFAAAAAA</Color>  <!-- resting connection stroke: grey, NOT white, so the white highlighted link stands out (>=1.8:1) while staying visible on the canvas (~5.8:1) -->

    <!-- Accents -->
    <Color x:Key="Palette.Crimson.700">#FF7B241C</Color>  <!-- NPC header / destructive (white text >=7) -->
    <Color x:Key="Palette.Maroon.800">#FFFF8080</Color>   <!-- diff removed fill (bright) -->
    <Color x:Key="Palette.Maroon.900">#FF2A0000</Color>   <!-- conflict theirs bg -->
    <Color x:Key="Palette.Red.500">#FFFF6B6B</Color>      <!-- severity error -->
    <Color x:Key="Palette.Red.450">#FFFF8080</Color>      <!-- removed text -->
    <Color x:Key="Palette.Red.550">#FFFF8080</Color>      <!-- inline error text -->
    <Color x:Key="Palette.Red.300">#FFFF9C9C</Color>      <!-- conflict theirs fg -->
    <Color x:Key="Palette.Azure.600">#FF1A5276</Color>    <!-- player header / primary button / focus (white >=7) -->
    <Color x:Key="Palette.Azure.150">#FFFFFFFF</Color>    <!-- player card body -->
    <Color x:Key="Palette.Azure.250">#FFF0F0F0</Color>    <!-- player card footer -->
    <Color x:Key="Palette.Slate.700">#FF2C3E50</Color>    <!-- script header (white >=7) -->
    <Color x:Key="Palette.Navy.100">#FF000000</Color>     <!-- info window bg -->
    <Color x:Key="Palette.Navy.150">#FF001A33</Color>     <!-- conflict mine bg -->
    <Color x:Key="Palette.Sky.300">#FF8CC4FF</Color>      <!-- conflict mine fg -->
    <Color x:Key="Palette.Sky.250">#FF9CDCFE</Color>      <!-- syntax code / inline mine -->
    <Color x:Key="Palette.Sky.350">#FF9CC4FF</Color>      <!-- link subtle -->
    <Color x:Key="Palette.Sky.400">#FF6BB6FF</Color>      <!-- link -->
    <Color x:Key="Palette.Sky.450">#FF6BB6FF</Color>      <!-- info / severity info -->
    <Color x:Key="Palette.Teal.600">#FF0A4A3E</Color>     <!-- narrator header (deepened; white >=7) -->
    <Color x:Key="Palette.Teal.150">#FFFFFFFF</Color>     <!-- narrator card body -->
    <Color x:Key="Palette.Teal.250">#FFF0F0F0</Color>     <!-- narrator card footer -->
    <Color x:Key="Palette.Green.600">#FF155018</Color>    <!-- confirm button bg (white >=7) -->
    <Color x:Key="Palette.Green.550">#FF5BFF8F</Color>    <!-- diff added fill (bright) -->
    <Color x:Key="Palette.Green.500">#FF5BFF8F</Color>    <!-- success text -->
    <Color x:Key="Palette.Green.400">#FF5BFF8F</Color>    <!-- added/new text; syntax script -->
    <Color x:Key="Palette.Amber.500">#FFFFC04D</Color>    <!-- severity warning -->
    <Color x:Key="Palette.Amber.600">#FFFFD23B</Color>    <!-- commit-meta gold -->
    <Color x:Key="Palette.Amber.520">#FFFFB000</Color>    <!-- bark outline / highlight -->
    <Color x:Key="Palette.Amber.540">#FFFFD23B</Color>    <!-- changed text -->
    <Color x:Key="Palette.Amber.560">#FFFFD24D</Color>    <!-- bark detail text / bark footer -->
    <Color x:Key="Palette.Amber.570">#FFFFE08A</Color>    <!-- bark footer (light) -->
    <Color x:Key="Palette.Amber.550">#FFFFD24D</Color>    <!-- syntax condition -->
    <Color x:Key="Palette.Amber.900">#FF5C4500</Color>    <!-- bark header / border -->
    <Color x:Key="Palette.Amber.950">#FF1A1400</Color>    <!-- bark detail bg -->
    <Color x:Key="Palette.Amber.610">#FFFFD23B</Color>    <!-- diff changed fill -->
    <Color x:Key="Palette.Olive.500">#FFC8C860</Color>    <!-- quotidian note -->
    <Color x:Key="Palette.Burnt.600">#FF6E3A0E</Color>    <!-- caution button (white >=7) -->
    <Color x:Key="Palette.Parchment.100">#FFFFFFFF</Color> <!-- NPC card body -->
    <Color x:Key="Palette.Parchment.200">#FFF0F0F0</Color> <!-- NPC card footer -->
    <Color x:Key="Palette.Cream.100">#FFFFFFFF</Color>     <!-- bark card body -->
    <Color x:Key="Palette.Neutral.520">#FF3A3A3A</Color>  <!-- canvas backdrop (Brush.Canvas.Background): neutral grey matching Dark/Light/Colourblind's tone, dark enough that Line.Default GridSplitters (~4.8:1) and white node cards stay visible against the near-black chrome -->
    <Color x:Key="Palette.Magenta.500">#FFFF5BD0</Color>  <!-- about-window status text -->

    <!-- Annotation box colours — high contrast variants (bright strokes, low fill opacity). -->
    <Color x:Key="Palette.Annotation.Yellow.Fill">#20FFC04D</Color>
    <Color x:Key="Palette.Annotation.Yellow.Header">#60FFC04D</Color>
    <Color x:Key="Palette.Annotation.Yellow.Stroke">#FFFFCA00</Color>
    <Color x:Key="Palette.Annotation.Red.Fill">#20FF6B6B</Color>
    <Color x:Key="Palette.Annotation.Red.Header">#60FF3333</Color>
    <Color x:Key="Palette.Annotation.Red.Stroke">#FFFF6B6B</Color>
    <Color x:Key="Palette.Annotation.Green.Fill">#205BFF8F</Color>
    <Color x:Key="Palette.Annotation.Green.Header">#604BCC73</Color>
    <Color x:Key="Palette.Annotation.Green.Stroke">#FF5BFF8F</Color>
    <Color x:Key="Palette.Annotation.Blue.Fill">#206BB6FF</Color>
    <Color x:Key="Palette.Annotation.Blue.Header">#604490CC</Color>
    <Color x:Key="Palette.Annotation.Blue.Stroke">#FF6BB6FF</Color>
    <Color x:Key="Palette.Annotation.Purple.Fill">#20EE00AA</Color>
    <Color x:Key="Palette.Annotation.Purple.Header">#60BB0088</Color>
    <Color x:Key="Palette.Annotation.Purple.Stroke">#FFEE00AA</Color>

    <!-- Alpha / effect primitives (overlays + shadow) -->
    <Color x:Key="Palette.Alpha.Scrim">#BB000000</Color>
    <Color x:Key="Palette.Alpha.Shadow">#A0000000</Color>
    <Color x:Key="Palette.Alpha.HairlineOnDark">#33FFFFFF</Color>
    <BoxShadows x:Key="Palette.Effect.CardShadow">0 0 18 0 #A0000000</BoxShadows>
</ResourceDictionary>
