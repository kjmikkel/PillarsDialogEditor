<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  PALETTE — LIGHT set (Layer 1). Same keys as Palette.Dark.axaml, light-theme values.
          Slot-inverted neutrals; node cards stay light cards; accent text deepened for contrast. See spec §4.1. -->

    <!-- Neutrals (grayscale ramp) -->
    <Color x:Key="Palette.Neutral.80">#FFFBFBFB</Color>
    <Color x:Key="Palette.Neutral.100">#FFFFFFFF</Color>
    <Color x:Key="Palette.Neutral.115">#FFF4F4F2</Color>
    <Color x:Key="Palette.Neutral.125">#FFECECEA</Color>
    <Color x:Key="Palette.Neutral.145">#FFE9E9E7</Color>
    <Color x:Key="Palette.Neutral.175">#FFDEDEDC</Color>
    <Color x:Key="Palette.Neutral.200">#FFD6D6D4</Color>
    <Color x:Key="Palette.Neutral.225">#FFCFCFCD</Color>
    <Color x:Key="Palette.Neutral.265">#FFC2C2C0</Color>
    <Color x:Key="Palette.Neutral.290">#FFB6B6B4</Color>
    <Color x:Key="Palette.Neutral.335">#FF9A9A9A</Color>
    <Color x:Key="Palette.Neutral.400">#FFAFAFAF</Color>
    <Color x:Key="Palette.Neutral.535">#FF6B6B6B</Color>
    <Color x:Key="Palette.Neutral.600">#FF595959</Color>
    <Color x:Key="Palette.Neutral.665">#FF4F4F4F</Color>
    <Color x:Key="Palette.Neutral.735">#FF3A3A3A</Color>
    <Color x:Key="Palette.Neutral.785">#FFCFCFCF</Color>
    <Color x:Key="Palette.Neutral.800">#FF333333</Color>
    <Color x:Key="Palette.Neutral.865">#FF2A2A2A</Color>
    <Color x:Key="Palette.Neutral.875">#FFE8E8E8</Color>
    <Color x:Key="Palette.Neutral.910">#FF1A1A1A</Color>
    <Color x:Key="Palette.Black">#FF000000</Color>
    <Color x:Key="Palette.White">#FFFFFFFF</Color>

    <!--  INK — dedicated dark-on-light text primitives (spec §3.3). Kept on their OWN keys (not
          Neutral.200/400) so the always-light node-card body text can stay dark while Neutral.200/400
          re-value for surface/border/disabled roles in the Light & High-Contrast palettes. Dark values
          equal the former Neutral.200/400 so this layer changes nothing on screen. Ink is a named
          role-primitive (defined by use, dark-on-light), not a numeric tone in the neutral ramp. -->
    <Color x:Key="Palette.Ink.Strong">#FF333333</Color>
    <Color x:Key="Palette.Ink.Muted">#FF666666</Color>

    <!-- Accents -->
    <Color x:Key="Palette.Crimson.700">#FF7B241C</Color>
    <Color x:Key="Palette.Maroon.800">#FFF3D2CD</Color>
    <Color x:Key="Palette.Maroon.900">#FFF5DEDC</Color>
    <Color x:Key="Palette.Red.500">#FFC0392B</Color>
    <Color x:Key="Palette.Red.450">#FFC0271C</Color>
    <Color x:Key="Palette.Red.550">#FFC62828</Color>
    <Color x:Key="Palette.Red.300">#FFA8281E</Color>
    <Color x:Key="Palette.Azure.600">#FF1A5276</Color>
    <Color x:Key="Palette.Azure.150">#FFD5E8F5</Color>
    <Color x:Key="Palette.Azure.250">#FFB0CDE8</Color>
    <Color x:Key="Palette.Slate.700">#FF2C3E50</Color>
    <Color x:Key="Palette.Navy.100">#FFEAEAF2</Color>
    <Color x:Key="Palette.Navy.150">#FFDCE7F5</Color>
    <Color x:Key="Palette.Sky.300">#FF1A4E8A</Color>
    <Color x:Key="Palette.Sky.250">#FF0A6CA8</Color>
    <Color x:Key="Palette.Sky.350">#FF5566AA</Color>
    <Color x:Key="Palette.Sky.400">#FF1565C0</Color>
    <Color x:Key="Palette.Sky.450">#FF1F77A8</Color>
    <Color x:Key="Palette.Teal.600">#FF0E6655</Color>
    <Color x:Key="Palette.Teal.150">#FFD5F0E8</Color>
    <Color x:Key="Palette.Teal.250">#FFB0E0D5</Color>
    <Color x:Key="Palette.Green.600">#FF2D6A2D</Color>
    <Color x:Key="Palette.Green.550">#FFCDEBD5</Color>
    <Color x:Key="Palette.Green.500">#FF1E7D34</Color>
    <Color x:Key="Palette.Green.400">#FF1F7A3D</Color>
    <Color x:Key="Palette.Amber.500">#FF8F5E00</Color>
    <Color x:Key="Palette.Amber.600">#FF8A6508</Color>
    <Color x:Key="Palette.Amber.610">#FFF2E2B0</Color>
    <Color x:Key="Palette.Amber.520">#FFB26A00</Color>
    <Color x:Key="Palette.Amber.540">#FF9A6300</Color>
    <Color x:Key="Palette.Amber.560">#FFE8C050</Color>
    <Color x:Key="Palette.Amber.570">#FFE8D080</Color>
    <Color x:Key="Palette.Amber.550">#FF8A5E00</Color>
    <Color x:Key="Palette.Amber.900">#FF7A5C00</Color>
    <Color x:Key="Palette.Amber.950">#FF2A2000</Color>
    <Color x:Key="Palette.Olive.500">#FF6F6F1E</Color>
    <Color x:Key="Palette.Burnt.600">#FF8E4912</Color>
    <Color x:Key="Palette.Parchment.100">#FFF5F0D0</Color>
    <Color x:Key="Palette.Parchment.200">#FFE8E0B0</Color>
    <Color x:Key="Palette.Cream.100">#FFFFF8DC</Color>
    <Color x:Key="Palette.Mauve.500">#FF7A6A8E</Color>
    <Color x:Key="Palette.Magenta.500">#FFB8007F</Color>

    <!-- Alpha / effect primitives (overlays + shadow live here so hex stays confined) -->
    <Color x:Key="Palette.Alpha.Scrim">#BB000000</Color>
    <Color x:Key="Palette.Alpha.Shadow">#A0000000</Color>
    <Color x:Key="Palette.Alpha.HairlineOnDark">#33FFFFFF</Color>
    <BoxShadows x:Key="Palette.Effect.CardShadow">0 0 18 0 #A0000000</BoxShadows>
</ResourceDictionary>
