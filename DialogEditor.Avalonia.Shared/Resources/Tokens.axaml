<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font sizes — semantic type-scale layer (mirrors the Brush.* token layer below).
         Every view binds these keys; no bare FontSize="N" literal may appear outside
         this file. See docs/superpowers/specs/2026-06-14-fontsize-token-foundation-design.md.
         FontSize.Micro (8) was retired: its only use (NodeDetailView group-header style)
         is now FontSize.Caption — bold weight + muted colour already distinguish group
         headers from field labels at the same size, and 8px was flagged as too small to
         read comfortably. -->
    <x:Double x:Key="FontSize.Caption">9</x:Double>
    <x:Double x:Key="FontSize.Small">10</x:Double>
    <x:Double x:Key="FontSize.Label">11</x:Double>
    <x:Double x:Key="FontSize.Body">12</x:Double>
    <x:Double x:Key="FontSize.Medium">13</x:Double>
    <x:Double x:Key="FontSize.Subtitle">14</x:Double>
    <x:Double x:Key="FontSize.Title">18</x:Double>
    <x:Double x:Key="FontSize.Display">32</x:Double>

    <!--  TOKENS — semantic brush layer (Layer 0, public contract).
          Every view, converter, and dependent gap binds THESE keys (never Palette.*).
          Each brush references exactly one Palette.* colour; two tokens may share a
          primitive on purpose (e.g. Text.Female.Active and Text.Primary) to decouple
          meaning from value. Foreground vs background of the same concept are distinct
          tokens by design. See spec §3.1, §4, §7. -->

    <!-- Node cards (dissolves SpeakerCategoryToBrushConverter / NodeColorConverter dup) -->
    <SolidColorBrush x:Key="Brush.Node.Npc.Header"      Color="{StaticResource Palette.Crimson.700}"/>
    <SolidColorBrush x:Key="Brush.Node.Npc.Body"        Color="{StaticResource Palette.Parchment.100}"/>
    <SolidColorBrush x:Key="Brush.Node.Npc.Footer"      Color="{StaticResource Palette.Parchment.200}"/>
    <SolidColorBrush x:Key="Brush.Node.Player.Header"    Color="{StaticResource Palette.Azure.600}"/>
    <SolidColorBrush x:Key="Brush.Node.Player.Body"      Color="{StaticResource Palette.Azure.150}"/>
    <SolidColorBrush x:Key="Brush.Node.Player.Footer"    Color="{StaticResource Palette.Azure.250}"/>
    <SolidColorBrush x:Key="Brush.Node.Narrator.Header"  Color="{StaticResource Palette.Teal.600}"/>
    <SolidColorBrush x:Key="Brush.Node.Narrator.Body"    Color="{StaticResource Palette.Teal.150}"/>
    <SolidColorBrush x:Key="Brush.Node.Narrator.Footer"  Color="{StaticResource Palette.Teal.250}"/>
    <SolidColorBrush x:Key="Brush.Node.Script.Header"    Color="{StaticResource Palette.Slate.700}"/>
    <SolidColorBrush x:Key="Brush.Node.Script.Body"      Color="{StaticResource Palette.Neutral.875}"/>
    <SolidColorBrush x:Key="Brush.Node.Script.Footer"    Color="{StaticResource Palette.Neutral.785}"/>
    <SolidColorBrush x:Key="Brush.Node.Bark.Header"      Color="{StaticResource Palette.Amber.900}"/>
    <SolidColorBrush x:Key="Brush.Node.Bark.Body"        Color="{StaticResource Palette.Cream.100}"/>
    <SolidColorBrush x:Key="Brush.Node.Bark.Footer"      Color="{StaticResource Palette.Amber.570}"/>

    <!-- Diff canvas fills -->
    <!-- Brush.Text.Meta.Commit stays on Amber.600 (commit gold). Diff.Changed.Fill split onto Amber.610 (separate from commit gold) per Layer 1 spec §3.3. -->
    <SolidColorBrush x:Key="Brush.Diff.Added.Fill"    Color="{StaticResource Palette.Green.550}"/>
    <SolidColorBrush x:Key="Brush.Diff.Changed.Fill"  Color="{StaticResource Palette.Amber.610}"/>
    <SolidColorBrush x:Key="Brush.Diff.Removed.Fill"  Color="{StaticResource Palette.Maroon.800}"/>

    <!-- Severity -->
    <SolidColorBrush x:Key="Brush.Severity.Info"     Color="{StaticResource Palette.Sky.450}"/>
    <SolidColorBrush x:Key="Brush.Severity.Warning"  Color="{StaticResource Palette.Amber.500}"/>
    <SolidColorBrush x:Key="Brush.Severity.Error"    Color="{StaticResource Palette.Red.500}"/>

    <!-- Toolbar buttons -->
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Background"   Color="{StaticResource Palette.Control.Background}"/>
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Foreground"   Color="{StaticResource Palette.Neutral.665}"/>
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Hover"        Color="{StaticResource Palette.Neutral.265}"/>
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Pressed"      Color="{StaticResource Palette.Neutral.290}"/>
    <SolidColorBrush x:Key="Brush.Toolbar.Button.Checked"      Color="{StaticResource Palette.Neutral.225}"/>
    <SolidColorBrush x:Key="Brush.Toolbar.Button.CheckedHover" Color="{StaticResource Palette.Neutral.265}"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="Brush.Surface.Window"  Color="{StaticResource Palette.Neutral.115}"/>
    <SolidColorBrush x:Key="Brush.Surface.Panel"   Color="{StaticResource Palette.Neutral.145}"/>
    <SolidColorBrush x:Key="Brush.Surface.Card"    Color="{StaticResource Palette.Neutral.100}"/>
    <SolidColorBrush x:Key="Brush.Surface.Input"   Color="{StaticResource Palette.Neutral.80}"/>
    <SolidColorBrush x:Key="Brush.Surface.Inset"   Color="{StaticResource Palette.Neutral.125}"/>
    <!-- Subtle surface (tree/list panels). Neutral.175 is "subtle surface / divider"
         per spec §5; this is its surface role (Border.Subtle is the divider role). -->
    <SolidColorBrush x:Key="Brush.Surface.Subtle"  Color="{StaticResource Palette.Neutral.175}"/>
    <SolidColorBrush x:Key="Brush.Surface.Header"  Color="{StaticResource Palette.Neutral.200}"/>
    <SolidColorBrush x:Key="Brush.Surface.Info"    Color="{StaticResource Palette.Navy.100}"/>
    <SolidColorBrush x:Key="Brush.Surface.Overlay.Scrim" Color="{StaticResource Palette.Alpha.Scrim}"/>

    <!-- Borders — re-pointed to the Palette.Line.* split so High-Contrast can make dividers bright
         while surfaces go near-black (spec 2026-06-09-layer1-highcontrast-design.md §3). -->
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Palette.Line.Default}"/>
    <SolidColorBrush x:Key="Brush.Border.Subtle"  Color="{StaticResource Palette.Line.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Border.Strong"  Color="{StaticResource Palette.Line.Strong}"/>
    <SolidColorBrush x:Key="Brush.Border.Muted"   Color="{StaticResource Palette.Line.Muted}"/>
    <SolidColorBrush x:Key="Brush.Border.OnDark"  Color="{StaticResource Palette.Alpha.HairlineOnDark}"/>
    <SolidColorBrush x:Key="Brush.Border.Focus"   Color="{StaticResource Palette.Azure.600}"/>

    <!-- Text -->
    <!-- Text emphasis ramp (light→dim), each a distinct used grey level -->
    <SolidColorBrush x:Key="Brush.Text.Primary"      Color="{StaticResource Palette.Neutral.910}"/>
    <SolidColorBrush x:Key="Brush.Text.Emphasis"     Color="{StaticResource Palette.Neutral.865}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary"    Color="{StaticResource Palette.Neutral.800}"/>
    <SolidColorBrush x:Key="Brush.Text.Tertiary"     Color="{StaticResource Palette.Neutral.735}"/>
    <SolidColorBrush x:Key="Brush.Text.Muted.Light"  Color="{StaticResource Palette.Neutral.665}"/>
    <SolidColorBrush x:Key="Brush.Text.Caption"      Color="{StaticResource Palette.Neutral.600}"/>
    <SolidColorBrush x:Key="Brush.Text.Muted"        Color="{StaticResource Palette.Neutral.535}"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled"     Color="{StaticResource Palette.Neutral.400}"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent"     Color="{StaticResource Palette.White}"/>
    <SolidColorBrush x:Key="Brush.Text.Female.Active" Color="{StaticResource Palette.Neutral.910}"/>
    <SolidColorBrush x:Key="Brush.Text.Female.Dim"    Color="{StaticResource Palette.Neutral.335}"/>
    <!-- Dark text on the LIGHT-tinted node-card bodies (NPC parchment, player azure, …) —
         the inverse of the dark-theme ramp above. No Text.* token matched Neutral.200/400
         as a foreground, so these name the "dark-on-light" role for the Layer 1 seam.
         Re-pointed to Palette.Ink.* per Layer 1 spec §3.3. -->
    <SolidColorBrush x:Key="Brush.Text.OnLight"       Color="{StaticResource Palette.Ink.Strong}"/>
    <SolidColorBrush x:Key="Brush.Text.OnLight.Muted" Color="{StaticResource Palette.Ink.Muted}"/>

    <!-- Status foreground accents -->
    <SolidColorBrush x:Key="Brush.Text.Status.New"     Color="{StaticResource Palette.Green.400}"/>
    <SolidColorBrush x:Key="Brush.Text.Status.Added"   Color="{StaticResource Palette.Green.400}"/>
    <SolidColorBrush x:Key="Brush.Text.Status.Changed" Color="{StaticResource Palette.Amber.540}"/>
    <SolidColorBrush x:Key="Brush.Text.Status.Removed"  Color="{StaticResource Palette.Red.450}"/>
    <SolidColorBrush x:Key="Brush.Text.Status.Success"  Color="{StaticResource Palette.Green.500}"/>
    <SolidColorBrush x:Key="Brush.Text.Status.Error"    Color="{StaticResource Palette.Red.550}"/>
    <SolidColorBrush x:Key="Brush.Text.Status.Pending"  Color="{StaticResource Palette.Magenta.500}"/>
    <SolidColorBrush x:Key="Brush.Text.Meta.Commit"     Color="{StaticResource Palette.Amber.600}"/>

    <!-- Syntax / parameter styling -->
    <SolidColorBrush x:Key="Brush.Syntax.Condition" Color="{StaticResource Palette.Amber.550}"/>
    <SolidColorBrush x:Key="Brush.Syntax.Script"    Color="{StaticResource Palette.Green.400}"/>
    <SolidColorBrush x:Key="Brush.Syntax.Code"      Color="{StaticResource Palette.Sky.250}"/>
    <SolidColorBrush x:Key="Brush.Syntax.Default"   Color="{StaticResource Palette.Neutral.910}"/>

    <!-- Inline text-diff word highlight (InlineDiffTextBlock + GitConflictResolutionWindow
         code-behind). Foreground accents for the differing run, each a BRIGHT tint of its
         side's hue so the word glows in that side's colour: mine = blue, theirs = red —
         mirroring the Conflict.*.Foreground pair. Blue+red (not green+red) keeps the two
         sides distinguishable for red-green colour deficiency. Distinct tokens from the
         Brush.Diff.*.Fill canvas backgrounds; Mine is a brighter Sky tone than the panel
         header (Sky.300) so it pops within body text. -->
    <SolidColorBrush x:Key="Brush.Diff.Inline.Mine"   Color="{StaticResource Palette.Sky.250}"/>
    <SolidColorBrush x:Key="Brush.Diff.Inline.Theirs" Color="{StaticResource Palette.Red.300}"/>

    <!-- Merge-conflict mine/theirs (GitConflictResolutionWindow). Mine = the BLUE pair,
         Theirs = the RED pair, matching the live window's panels. Spec §7.8's first draft
         listed these names against the opposite hues; the shipping window is authoritative,
         so the values are corrected here and the window now binds its matching-named tokens. -->
    <SolidColorBrush x:Key="Brush.Conflict.Mine.Background"   Color="{StaticResource Palette.Navy.150}"/>
    <SolidColorBrush x:Key="Brush.Conflict.Mine.Foreground"   Color="{StaticResource Palette.Sky.300}"/>
    <SolidColorBrush x:Key="Brush.Conflict.Theirs.Background"  Color="{StaticResource Palette.Maroon.900}"/>
    <SolidColorBrush x:Key="Brush.Conflict.Theirs.Foreground"  Color="{StaticResource Palette.Red.300}"/>

    <!-- Canvas connection strokes (ConversationView edges + LegendWindow swatches).
         A distinct semantic family from text/borders so a future palette can recolour
         edges independently; the White highlight is tokenised here for family completeness. -->
    <SolidColorBrush x:Key="Brush.Connection.Default"            Color="{StaticResource Palette.Connection.Base}"/>
    <SolidColorBrush x:Key="Brush.Connection.Always"            Color="{StaticResource Palette.Amber.500}"/>
    <SolidColorBrush x:Key="Brush.Connection.Never"             Color="{StaticResource Palette.Neutral.335}"/>
    <SolidColorBrush x:Key="Brush.Connection.Highlighted"        Color="{StaticResource Palette.White}"/>
    <SolidColorBrush x:Key="Brush.Connection.Highlighted.Always" Color="{StaticResource Palette.Amber.520}"/>
    <SolidColorBrush x:Key="Brush.Connection.Highlighted.Never"  Color="{StaticResource Palette.Neutral.735}"/>

    <!-- Action buttons (coloured background, white text). Confirm = green commit/apply;
         Caution = burnt force/destructive-ish; Primary = azure default dialog action
         (OK/Create/Save); Destructive = crimson hard delete. Primary/Destructive complete
         the family for the dialog action buttons §7.9's first draft omitted (spec §7.9). -->
    <SolidColorBrush x:Key="Brush.Button.Confirm.Background"     Color="{StaticResource Palette.Green.600}"/>
    <SolidColorBrush x:Key="Brush.Button.Caution.Background"     Color="{StaticResource Palette.Burnt.600}"/>
    <SolidColorBrush x:Key="Brush.Button.Primary.Background"     Color="{StaticResource Palette.Azure.600}"/>
    <SolidColorBrush x:Key="Brush.Button.Destructive.Background" Color="{StaticResource Palette.Crimson.700}"/>

    <!-- Bark detail block + canvas bark outline -->
    <SolidColorBrush x:Key="Brush.Bark.Detail.Background" Color="{StaticResource Palette.Amber.950}"/>
    <SolidColorBrush x:Key="Brush.Bark.Detail.Border"    Color="{StaticResource Palette.Amber.900}"/>
    <SolidColorBrush x:Key="Brush.Bark.Detail.Text"      Color="{StaticResource Palette.Amber.560}"/>
    <SolidColorBrush x:Key="Brush.Node.Bark.Outline"     Color="{StaticResource Palette.Amber.520}"/>
    <SolidColorBrush x:Key="Brush.Node.Quotidian.Note"   Color="{StaticResource Palette.Olive.500}"/>

    <!-- Annotation boxes — seven curated colours, each with Fill/Header/Stroke.
         AnnotationColorConverter resolves "Brush.Annotation.{ColorKey}.{zone}" at runtime. -->
    <SolidColorBrush x:Key="Brush.Annotation.Yellow.Fill"   Color="{StaticResource Palette.Annotation.Yellow.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Yellow.Header" Color="{StaticResource Palette.Annotation.Yellow.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Yellow.Stroke" Color="{StaticResource Palette.Annotation.Yellow.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Red.Fill"      Color="{StaticResource Palette.Annotation.Red.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Red.Header"    Color="{StaticResource Palette.Annotation.Red.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Red.Stroke"    Color="{StaticResource Palette.Annotation.Red.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Green.Fill"    Color="{StaticResource Palette.Annotation.Green.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Green.Header"  Color="{StaticResource Palette.Annotation.Green.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Green.Stroke"  Color="{StaticResource Palette.Annotation.Green.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Blue.Fill"     Color="{StaticResource Palette.Annotation.Blue.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Blue.Header"   Color="{StaticResource Palette.Annotation.Blue.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Blue.Stroke"   Color="{StaticResource Palette.Annotation.Blue.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Purple.Fill"   Color="{StaticResource Palette.Annotation.Purple.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Purple.Header" Color="{StaticResource Palette.Annotation.Purple.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Purple.Stroke" Color="{StaticResource Palette.Annotation.Purple.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Teal.Fill"     Color="{StaticResource Palette.Annotation.Teal.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Teal.Header"   Color="{StaticResource Palette.Annotation.Teal.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Teal.Stroke"   Color="{StaticResource Palette.Annotation.Teal.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Orange.Fill"   Color="{StaticResource Palette.Annotation.Orange.Fill}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Orange.Header" Color="{StaticResource Palette.Annotation.Orange.Header}"/>
    <SolidColorBrush x:Key="Brush.Annotation.Orange.Stroke" Color="{StaticResource Palette.Annotation.Orange.Stroke}"/>

    <!-- Links, info text, highlight, badge (accent foregrounds) -->
    <SolidColorBrush x:Key="Brush.Text.Link"         Color="{StaticResource Palette.Sky.400}"/>
    <SolidColorBrush x:Key="Brush.Text.Link.Subtle"  Color="{StaticResource Palette.Sky.350}"/>
    <SolidColorBrush x:Key="Brush.Text.Info"         Color="{StaticResource Palette.Sky.450}"/>
    <SolidColorBrush x:Key="Brush.Text.Highlight"    Color="{StaticResource Palette.Amber.520}"/>
    <SolidColorBrush x:Key="Brush.Canvas.Background" Color="{StaticResource Palette.Neutral.520}"/>
</ResourceDictionary>
