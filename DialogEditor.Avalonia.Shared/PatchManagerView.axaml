<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
             x:Class="DialogEditor.Avalonia.Shared.PatchManagerView"
             Background="{DynamicResource Brush.Surface.Window}"
             x:CompileBindings="False">

    <UserControl.Styles>
        <Style Selector="TextBlock.section-label">
            <Setter Property="Foreground"  Value="{DynamicResource Brush.Text.Muted}"/>
            <Setter Property="FontSize"    Value="{StaticResource FontSize.Small}"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Background"      Value="{DynamicResource Brush.Toolbar.Button.Background}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSize.Label}"/>
        </Style>
        <Style Selector="Button.primary-btn">
            <Setter Property="Background"      Value="{DynamicResource Brush.Button.Primary.Background}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,6"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSize.Body}"/>
            <Setter Property="MinWidth"        Value="120"/>
        </Style>
        <Style Selector="TextBox.path-box">
            <Setter Property="Background"      Value="{DynamicResource Brush.Surface.Input}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Brush.Border.Strong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSize.Label}"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="IsReadOnly"      Value="True"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="14,12,14,12">

        <!-- ── Game folder ─────────────────────────────────────────── -->
        <TextBlock Grid.Row="0" Classes="section-label"
                   Text="{StaticResource PatchManager_GameFolder}"/>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBox Grid.Column="0" Classes="path-box"
                     Text="{Binding GameFolder}"
                     Watermark="{StaticResource PatchManager_GameFolderWatermark}"
                     ToolTip.Tip="{StaticResource ToolTip_BrowseGameFolder}"
                     AutomationProperties.HelpText="{StaticResource ToolTip_BrowseGameFolder}"
                     AutomationProperties.Name="{StaticResource PatchManager_GameFolder}"/>
            <Button Grid.Column="1" Classes="action-btn"
                    Content="{StaticResource PatchManager_BrowseGame}"
                    Command="{Binding BrowseGameFolderCommand}"
                    Margin="6,0,0,0"
                    ToolTip.Tip="{StaticResource ToolTip_BrowseGameFolder}"
                    AutomationProperties.HelpText="{StaticResource ToolTip_BrowseGameFolder}"/>
        </Grid>

        <!-- ── Load Order ──────────────────────────────────────────── -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto">

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Classes="section-label" DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="{StaticResource PatchManager_LoadOrder}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <Button Classes="action-btn"
                            Content="{StaticResource PatchManager_SaveLoadOrder}"
                            Command="{Binding SaveLoadOrderCommand}"
                            ToolTip.Tip="{StaticResource ToolTip_SaveLoadOrder}"
                            AutomationProperties.HelpText="{StaticResource ToolTip_SaveLoadOrder}"/>
                    <Button Classes="action-btn"
                            Content="{StaticResource PatchManager_LoadLoadOrder}"
                            Command="{Binding LoadLoadOrderCommand}"
                            ToolTip.Tip="{StaticResource ToolTip_LoadLoadOrder}"
                            AutomationProperties.HelpText="{StaticResource ToolTip_LoadLoadOrder}"/>
                    <Button Classes="action-btn"
                            Content="{StaticResource PatchManager_AddProjects}"
                            Command="{Binding AddEntriesCommand}"
                            ToolTip.Tip="{StaticResource ToolTip_AddProjects}"
                            AutomationProperties.HelpText="{StaticResource ToolTip_AddProjects}"/>
                </StackPanel>
            </DockPanel>

            <!-- Entry list -->
            <Grid Grid.Row="1">
                <ScrollViewer Background="{DynamicResource Brush.Surface.Panel}">
                    <ItemsControl ItemsSource="{Binding Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:PatchEntryViewModel">
                                <Border Background="{DynamicResource Brush.Surface.Subtle}" CornerRadius="4"
                                        Margin="4,2,4,2" Padding="10,8">
                                    <Grid ColumnDefinitions="*,28,28,28">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding ProjectName}"
                                                           Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="⚠"
                                                           Foreground="{DynamicResource Brush.Severity.Warning}" FontSize="{StaticResource FontSize.Body}"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding HasConflict}"
                                                           ToolTip.Tip="{StaticResource PatchManager_EntryConflictDetail}"/>
                                                <TextBlock Text="⚠"
                                                           Foreground="{DynamicResource Brush.Severity.Error}" FontSize="{StaticResource FontSize.Body}"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding LoadError,
                                                                       Converter={StaticResource NullOrEmptyToVis}}"
                                                           ToolTip.Tip="{Binding LoadError}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DisplayPath}"
                                                       Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{StaticResource FontSize.Small}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="↑"
                                                Command="{Binding DataContext.MoveUpCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{StaticResource FontSize.Medium}" Padding="4"
                                                ToolTip.Tip="{StaticResource ToolTip_MoveEntryUp}"
                                                AutomationProperties.HelpText="{StaticResource ToolTip_MoveEntryUp}"
                                                AutomationProperties.Name="{StaticResource AutomationName_MovePatchUp}"/>
                                        <Button Grid.Column="2" Content="↓"
                                                Command="{Binding DataContext.MoveDownCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{StaticResource FontSize.Medium}" Padding="4"
                                                ToolTip.Tip="{StaticResource ToolTip_MoveEntryDown}"
                                                AutomationProperties.HelpText="{StaticResource ToolTip_MoveEntryDown}"
                                                AutomationProperties.Name="{StaticResource AutomationName_MovePatchDown}"/>
                                        <Button Grid.Column="3" Content="✕"
                                                Command="{Binding DataContext.RemoveEntryCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource Brush.Severity.Error}" FontSize="{StaticResource FontSize.Medium}" Padding="4"
                                                ToolTip.Tip="{StaticResource ToolTip_RemoveEntry}"
                                                AutomationProperties.HelpText="{StaticResource ToolTip_RemoveEntry}"
                                                AutomationProperties.Name="{StaticResource AutomationName_RemovePatch}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="{StaticResource PatchManager_EmptyHint}"
                           Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{StaticResource FontSize.Label}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsVisible="{Binding HasEntries,
                                       Converter={StaticResource InverseBoolToVis}}"/>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{StaticResource PatchManager_OrderHint}"
                       Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{StaticResource FontSize.Caption}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </Grid>

        <!-- ── Conflict summary ─────────────────────────────────────── -->
        <Border Grid.Row="3" Background="{DynamicResource Brush.Surface.Card}" CornerRadius="3" Padding="10,6"
                Margin="0,8,0,0"
                IsVisible="{Binding HasConflicts}">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource Brush.Severity.Warning}" FontSize="{StaticResource FontSize.Label}" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding Conflicts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="{StaticResource FontSize.Small}" Foreground="{DynamicResource Brush.Text.Muted.Light}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="  conversation '{0}' · node {1} · {2}">
                                        <Binding Path="ConversationName"/>
                                        <Binding Path="NodeId"/>
                                        <Binding Path="FieldName"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ── Footer ──────────────────────────────────────────────── -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Small}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="{Binding HasConflicts,
                                   Converter={StaticResource InverseBoolToVis}}"/>
            <Button Grid.Column="1" Classes="primary-btn"
                    Content="{StaticResource PatchManager_Apply}"
                    Command="{Binding ApplyCommand}"
                    IsVisible="{Binding IsApplying, Converter={StaticResource InverseBoolToVis}}"
                    ToolTip.Tip="{StaticResource ToolTip_ApplyPatches}"
                    AutomationProperties.HelpText="{StaticResource ToolTip_ApplyPatches}"/>
            <Button Grid.Column="1" Classes="primary-btn"
                    Content="{StaticResource PatchManager_Applying}"
                    IsEnabled="False"
                    IsVisible="{Binding IsApplying}"/>
        </Grid>

    </Grid>
</UserControl>
