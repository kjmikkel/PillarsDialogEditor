<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.14" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.14" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.14" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.14" />
    <PackageReference Include="NodifyAvalonia" Version="6.6.0" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    <PackageReference Include="NAudio" Version="2.2.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DialogEditor.Core\DialogEditor.Core.csproj" />
    <ProjectReference Include="..\DialogEditor.ViewModels\DialogEditor.ViewModels.csproj" />
    <ProjectReference Include="..\DialogEditor.Avalonia.Shared\DialogEditor.Avalonia.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\**"/>
    <AvaloniaResource Include="Resources\Strings.axaml"/>
    <!-- Prevent the SDK from also treating Strings.axaml as a compiled AvaloniaXaml resource -->
    <AvaloniaXaml Remove="Resources\Strings.axaml"/>
  </ItemGroup>

  <ItemGroup>
    <!-- Ship the beginner walkthrough next to the executable so Help > Open Walkthrough finds it. -->
    <Content Include="..\docs\walkthrough.md" Link="docs\walkthrough.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- Ship the changelog next to the executable so Help > Changelog finds it. -->
    <Content Include="..\CHANGELOG.md" Link="CHANGELOG.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- Bundle vgmstream-cli for PoE2 .wem audio preview. Attribution: THIRD_PARTY_LICENSES.md -->
    <Content Include="tools\vgmstream-cli.exe">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- vgmstream-cli runtime dependencies (codec DLLs shipped alongside the CLI) -->
    <Content Include="tools\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
