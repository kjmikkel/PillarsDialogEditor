<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.CommitConsentDialog"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Title="{StaticResource CommitConsent_Title}"
        Width="460" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">
  <StackPanel Margin="14" Spacing="8">
    <TextBlock Text="{StaticResource CommitConsent_Intro}"
               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12"
               TextWrapping="Wrap"/>
    <Border BorderBrush="{DynamicResource Brush.Border.OnDark}" BorderThickness="1" CornerRadius="3" Padding="6" MaxHeight="160">
      <ScrollViewer>
        <ItemsControl x:Name="FileList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" FontFamily="Consolas,monospace"
                         Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
    <TextBlock Text="{StaticResource CommitConsent_MessageLabel}"
               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12"/>
    <TextBox x:Name="MessageBox"
             Background="{DynamicResource Brush.Surface.Input}" Foreground="{DynamicResource Brush.Text.Primary}"
             BorderBrush="{DynamicResource Brush.Border.Strong}" BorderThickness="1"
             FontSize="12" Padding="6,4"
             AcceptsReturn="False"
             ToolTip.Tip="{StaticResource CommitConsent_MessageLabel}"
             AutomationProperties.Name="{StaticResource CommitConsent_MessageLabel}"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button x:Name="CancelButton"
              Content="{StaticResource CommitConsent_Cancel}"
              Background="{DynamicResource Brush.Surface.Header}" Foreground="White" BorderThickness="0"
              Padding="16,6" FontSize="12"
              IsCancel="True"/>
      <Button x:Name="CommitButton"
              Content="{StaticResource CommitConsent_Commit}"
              Background="{DynamicResource Brush.Button.Primary.Background}" Foreground="White" BorderThickness="0"
              Padding="16,6" FontSize="12"
              IsDefault="True"/>
    </StackPanel>
  </StackPanel>
</Window>
