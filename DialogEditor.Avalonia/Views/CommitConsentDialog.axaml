<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.CommitConsentDialog"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Title="{StaticResource CommitConsent_Title}"
        Width="460" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#252525">
  <StackPanel Margin="14" Spacing="8">
    <TextBlock Text="{StaticResource CommitConsent_Intro}"
               Foreground="#e8e8e8" FontSize="12"
               TextWrapping="Wrap"/>
    <Border BorderBrush="#33ffffff" BorderThickness="1" CornerRadius="3" Padding="6" MaxHeight="160">
      <ScrollViewer>
        <ItemsControl x:Name="FileList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" FontFamily="Consolas,monospace"
                         Foreground="#e8e8e8" FontSize="12"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
    <TextBlock Text="{StaticResource CommitConsent_MessageLabel}"
               Foreground="#e8e8e8" FontSize="12"/>
    <TextBox x:Name="MessageBox"
             Background="#141414" Foreground="#e8e8e8"
             BorderBrush="#444" BorderThickness="1"
             FontSize="12" Padding="6,4"
             AcceptsReturn="False"
             ToolTip.Tip="{StaticResource CommitConsent_MessageLabel}"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button x:Name="CancelButton"
              Content="{StaticResource CommitConsent_Cancel}"
              Background="#333" Foreground="White" BorderThickness="0"
              Padding="16,6" FontSize="12"
              IsCancel="True"/>
      <Button x:Name="CommitButton"
              Content="{StaticResource CommitConsent_Commit}"
              Background="#1a5276" Foreground="White" BorderThickness="0"
              Padding="16,6" FontSize="12"
              IsDefault="True"/>
    </StackPanel>
  </StackPanel>
</Window>
