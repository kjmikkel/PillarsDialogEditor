<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.BlameWindow"
        Title="{DynamicResource BlameWindow_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="780" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">

    <Grid Margin="16" RowDefinitions="Auto,*,Auto">

        <!-- Column headers (shown only when there are rows) -->
        <Grid Grid.Row="0" ColumnDefinitions="160,60,130,110,90,*"
              Margin="0,0,0,6" IsVisible="{Binding HasData}">
            <TextBlock Grid.Column="0" Text="{DynamicResource BlameWindow_ColConversation}"
                       Foreground="{DynamicResource Brush.Text.Caption}" FontSize="{StaticResource FontSize.Body}" FontWeight="Bold"/>
            <TextBlock Grid.Column="1" Text="{DynamicResource BlameWindow_ColNode}"
                       Foreground="{DynamicResource Brush.Text.Caption}" FontSize="{StaticResource FontSize.Body}" FontWeight="Bold"/>
            <TextBlock Grid.Column="2" Text="{DynamicResource BlameWindow_ColAuthor}"
                       Foreground="{DynamicResource Brush.Text.Caption}" FontSize="{StaticResource FontSize.Body}" FontWeight="Bold"/>
            <TextBlock Grid.Column="3" Text="{DynamicResource BlameWindow_ColDate}"
                       Foreground="{DynamicResource Brush.Text.Caption}" FontSize="{StaticResource FontSize.Body}" FontWeight="Bold"/>
            <TextBlock Grid.Column="4" Text="{DynamicResource BlameWindow_ColCommit}"
                       Foreground="{DynamicResource Brush.Text.Caption}" FontSize="{StaticResource FontSize.Body}" FontWeight="Bold"/>
            <TextBlock Grid.Column="5" Text="{DynamicResource BlameWindow_ColMessage}"
                       Foreground="{DynamicResource Brush.Text.Caption}" FontSize="{StaticResource FontSize.Body}" FontWeight="Bold"/>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource Brush.Text.Meta.Commit}" FontSize="{StaticResource FontSize.Medium}" TextWrapping="Wrap"
                   IsVisible="{Binding !HasData}"
                   VerticalAlignment="Top"/>

        <ListBox Grid.Row="1" x:Name="BlameList"
                 ItemsSource="{Binding Rows}"
                 Background="{DynamicResource Brush.Surface.Card}" BorderThickness="0"
                 IsVisible="{Binding HasData}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="160,60,130,110,90,*" Margin="0,3">
                        <TextBlock Grid.Column="0" Text="{Binding ConversationName}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{StaticResource FontSize.Body}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding NodeId}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{StaticResource FontSize.Body}"/>
                        <TextBlock Grid.Column="2" Text="{Binding Author}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{StaticResource FontSize.Body}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Date, Converter={StaticResource CommitDate}}"
                                   ToolTip.Tip="{Binding Date}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{StaticResource FontSize.Body}"/>
                        <TextBlock Grid.Column="4" Text="{Binding ShortSha}"
                                   Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Body}" FontFamily="Consolas,monospace"/>
                        <TextBlock Grid.Column="5" Text="{Binding Subject}"
                                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}" TextWrapping="Wrap"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,14,0,0">
            <Button x:Name="CloseButton"
                    Content="{DynamicResource BlameWindow_Close}"
                    Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="{StaticResource FontSize.Body}"/>
        </StackPanel>

    </Grid>

</Window>
