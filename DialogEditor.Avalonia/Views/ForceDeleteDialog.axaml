<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.ForceDeleteDialog"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Title="{DynamicResource ForceDelete_Title}"
        Width="420" MinWidth="420" SizeToContent="Height"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">
  <StackPanel Margin="20" Spacing="12">
    <TextBlock x:Name="MessageText"
               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}"
               TextWrapping="Wrap"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button x:Name="CancelButton"
              Content="{DynamicResource ForceDelete_Cancel}"
              Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
              Padding="16,6" FontSize="{StaticResource FontSize.Body}"
              IsCancel="True"
              IsDefault="True"
              ToolTip.Tip="{DynamicResource ForceDelete_Cancel}"
              AutomationProperties.HelpText="{DynamicResource ForceDelete_Cancel}"/>
      <Button x:Name="ConfirmButton"
              Content="{DynamicResource ForceDelete_Confirm}"
              Background="{DynamicResource Brush.Button.Destructive.Background}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
              Padding="16,6" FontSize="{StaticResource FontSize.Body}"
              ToolTip.Tip="{DynamicResource ForceDelete_Confirm}"
              AutomationProperties.HelpText="{DynamicResource ForceDelete_Confirm}"/>
    </StackPanel>
  </StackPanel>
</Window>
