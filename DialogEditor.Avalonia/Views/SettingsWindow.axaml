<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.SettingsWindow"
        Title="{StaticResource Settings_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="500" Height="220"
        CanResize="False"
        Background="{DynamicResource Brush.Surface.Window}"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground"       Value="{DynamicResource Brush.Text.Muted.Light}"/>
            <Setter Property="FontSize"         Value="{StaticResource FontSize.Label}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width"            Value="140"/>
        </Style>
        <Style Selector="TextBox.path">
            <Setter Property="Background"   Value="{DynamicResource Brush.Surface.Card}"/>
            <Setter Property="Foreground"   Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource Brush.Border.Strong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="{StaticResource FontSize.Label}"/>
            <Setter Property="IsReadOnly"   Value="True"/>
            <Setter Property="Padding"      Value="4,3"/>
        </Style>
        <Style Selector="Button.browse">
            <Setter Property="Background"   Value="{DynamicResource Brush.Surface.Header}"/>
            <Setter Property="Foreground"   Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="Margin"       Value="6,0,0,0"/>
            <Setter Property="FontSize"     Value="{StaticResource FontSize.Label}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto,Auto" Margin="16">

        <StackPanel Grid.Row="0" Spacing="12">

            <!-- Backup directory -->
            <DockPanel ToolTip.Tip="{StaticResource Settings_BackupDirectoryTooltip}">
                <TextBlock Classes="label" Text="{StaticResource Settings_BackupDirectory}"/>
                <Button Classes="browse"
                        DockPanel.Dock="Right"
                        Content="{StaticResource Settings_Browse}"
                        Command="{Binding BrowseBackupDirectoryCommand}"
                        ToolTip.Tip="{StaticResource Settings_BackupDirectoryTooltip}"
                        AutomationProperties.HelpText="{StaticResource Settings_BackupDirectoryTooltip}"/>
                <TextBox Classes="path"
                         Text="{Binding BackupDirectory}"
                         Watermark="{StaticResource Settings_PathNotSet}"
                         ToolTip.Tip="{StaticResource Settings_BackupDirectoryTooltip}"
                         AutomationProperties.HelpText="{StaticResource Settings_BackupDirectoryTooltip}"
                         AutomationProperties.Name="{StaticResource Settings_BackupDirectory}"/>
            </DockPanel>

            <!-- Default localization format -->
            <DockPanel>
                <TextBlock Classes="label" Text="{StaticResource Settings_LocalizationFormat}"/>
                <ComboBox SelectedItem="{Binding LocalizationFormat, Mode=TwoWay}"
                          MinWidth="120"
                          AutomationProperties.Name="{StaticResource Settings_LocalizationFormat}">
                    <ComboBoxItem Content="Csv"/>
                    <ComboBoxItem Content="Json"/>
                    <ComboBoxItem Content="Xliff"/>
                </ComboBox>
            </DockPanel>

            <!-- Theme picker (own DataContext set in code-behind; shared with PatchManager) -->
            <shared:ThemePickerView x:Name="ThemePicker"/>

        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="1"
                Content="{StaticResource Settings_Close}"
                HorizontalAlignment="Right"
                Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Secondary}" BorderThickness="0"
                Padding="16,5" Margin="0,12,0,0"
                Click="Close_Click"/>

        <!-- Focus hint bar (Gaps item 13) -->
        <shared:FocusHintBar Grid.Row="2" x:Name="HintBar"/>

    </Grid>
</Window>
