<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.SettingsWindow"
        Title="{DynamicResource Settings_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="500" MinWidth="500" SizeToContent="Height"
        CanResize="True"
        Background="{DynamicResource Brush.Surface.Window}"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground"       Value="{DynamicResource Brush.Text.Muted.Light}"/>
            <Setter Property="FontSize"         Value="{DynamicResource FontSize.Label}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth"         Value="140"/>
        </Style>
        <Style Selector="TextBox.path">
            <Setter Property="Background"   Value="{DynamicResource Brush.Surface.Card}"/>
            <Setter Property="Foreground"   Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource Brush.Border.Strong}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="{DynamicResource FontSize.Label}"/>
            <Setter Property="IsReadOnly"   Value="True"/>
            <Setter Property="Padding"      Value="4,3"/>
        </Style>
        <Style Selector="Button.browse">
            <Setter Property="Background"   Value="{DynamicResource Brush.Surface.Header}"/>
            <Setter Property="Foreground"   Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="Margin"       Value="6,0,0,0"/>
            <Setter Property="FontSize"     Value="{DynamicResource FontSize.Label}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto" Margin="16">

        <StackPanel Grid.Row="0" Spacing="12">

            <!-- Backup directory -->
            <DockPanel ToolTip.Tip="{DynamicResource Settings_BackupDirectoryTooltip}">
                <TextBlock Classes="label" Text="{DynamicResource Settings_BackupDirectory}"/>
                <Button Classes="browse"
                        DockPanel.Dock="Right"
                        Content="{DynamicResource Settings_Browse}"
                        Command="{Binding BrowseBackupDirectoryCommand}"
                        ToolTip.Tip="{DynamicResource Settings_BackupDirectoryTooltip}"
                        AutomationProperties.HelpText="{DynamicResource Settings_BackupDirectoryTooltip}"/>
                <TextBox Classes="path"
                         Text="{Binding BackupDirectory}"
                         Watermark="{DynamicResource Settings_PathNotSet}"
                         ToolTip.Tip="{DynamicResource Settings_BackupDirectoryTooltip}"
                         AutomationProperties.HelpText="{DynamicResource Settings_BackupDirectoryTooltip}"
                         AutomationProperties.Name="{DynamicResource Settings_BackupDirectory}"/>
            </DockPanel>

            <!-- Default localization format -->
            <DockPanel ToolTip.Tip="{DynamicResource Settings_LocalizationFormatTooltip}">
                <TextBlock Classes="label" Text="{DynamicResource Settings_LocalizationFormat}"/>
                <ComboBox x:Name="LocalizationFormatComboBox"
                          ItemsSource="{Binding LocalizationFormatOptions}"
                          SelectedItem="{Binding LocalizationFormat, Mode=TwoWay}"
                          MinWidth="120"
                          ToolTip.Tip="{DynamicResource Settings_LocalizationFormatTooltip}"
                          AutomationProperties.HelpText="{DynamicResource Settings_LocalizationFormatTooltip}"
                          AutomationProperties.Name="{DynamicResource Settings_LocalizationFormat}"/>
            </DockPanel>

            <!-- Font scale (Gaps item 6 part B) -->
            <DockPanel ToolTip.Tip="{DynamicResource Settings_FontScaleTooltip}">
                <TextBlock Classes="label" Text="{DynamicResource Settings_FontScale}"/>
                <ComboBox ItemsSource="{Binding FontScaleOptions}"
                          SelectedItem="{Binding SelectedFontScale, Mode=TwoWay}"
                          MinWidth="120"
                          ToolTip.Tip="{DynamicResource Settings_FontScaleTooltip}"
                          AutomationProperties.HelpText="{DynamicResource Settings_FontScaleTooltip}"
                          AutomationProperties.Name="{DynamicResource Settings_FontScale}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource FontScaleToPercent}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </DockPanel>

            <!-- Font scale live preview: independent of the static FontSize.* tokens,
                 so it reflects the *selected* (not-yet-applied) scale immediately. -->
            <Border BorderBrush="{DynamicResource Brush.Border.Default}" BorderThickness="1" CornerRadius="3"
                    Padding="8" Background="{DynamicResource Brush.Surface.Inset}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource Settings_FontScalePreviewBody}"
                               FontSize="{Binding PreviewBodyFontSize}"
                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                    <TextBlock Text="{DynamicResource Settings_FontScalePreviewSubtitle}"
                               FontSize="{Binding PreviewSubtitleFontSize}"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{DynamicResource Settings_FontScalePreviewTitle}"
                               FontSize="{Binding PreviewTitleFontSize}"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Spelling: user-supplied Hunspell dictionaries (layer 1 of the
                 three-layer spell checker; spec 2026-07-11) -->
            <StackPanel Spacing="6">
                <TextBlock Text="{DynamicResource Settings_SpellingHeader}"
                           Foreground="{DynamicResource Brush.Text.Primary}"
                           FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource Settings_SpellingInstructions}"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           FontSize="{DynamicResource FontSize.Small}"
                           TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource Settings_OpenDictionariesFolder}"
                            Command="{Binding OpenDictionariesFolderCommand}"
                            ToolTip.Tip="{DynamicResource ToolTip_OpenDictionariesFolder}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_OpenDictionariesFolder}"/>
                    <Button Content="{DynamicResource Settings_DictionarySource}"
                            Command="{Binding OpenDictionarySourceCommand}"
                            ToolTip.Tip="{DynamicResource ToolTip_DictionarySource}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_DictionarySource}"/>
                </StackPanel>
                <TextBlock Text="{Binding DetectedDictionariesText}"
                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                           FontSize="{DynamicResource FontSize.Small}"/>
            </StackPanel>

            <!-- Language picker (own DataContext set in code-behind; shared with PatchManager) -->
            <shared:LanguagePickerView x:Name="LanguagePicker"/>

            <!-- Theme picker (own DataContext set in code-behind; shared with PatchManager) -->
            <shared:ThemePickerView x:Name="ThemePicker"/>

        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="1"
                Content="{DynamicResource Settings_Close}"
                HorizontalAlignment="Right"
                Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Secondary}" BorderThickness="0"
                Padding="16,5" Margin="0,12,0,0"
                Click="Close_Click"/>

        <!-- Focus hint bar (Gaps item 13) -->
        <shared:FocusHintBar Grid.Row="2" x:Name="HintBar"/>

    </Grid>
</Window>
