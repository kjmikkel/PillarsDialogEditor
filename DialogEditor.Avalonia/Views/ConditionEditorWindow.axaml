<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
        xmlns:types="clr-namespace:DialogEditor.ViewModels.Services;assembly=DialogEditor.ViewModels"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.ConditionEditorWindow"
        Title="{Binding WindowTitle}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="640" Height="560" MinWidth="480" MinHeight="360"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Window}"
        x:CompileBindings="False">

    <Window.Styles>
        <Style Selector="TextBlock.param-label">
            <Setter Property="Foreground"        Value="{DynamicResource Brush.Text.Muted}"/>
            <Setter Property="FontSize"          Value="{DynamicResource FontSize.Label}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth"          Value="110"/>
        </Style>
        <Style Selector="Button.type-hint">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Foreground"        Value="{DynamicResource Brush.Text.Muted}"/>
            <Setter Property="FontSize"          Value="{DynamicResource FontSize.Label}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="4,0,0,0"/>
            <Setter Property="Padding"           Value="2,0"/>
            <Setter Property="Cursor"            Value="Help"/>
            <Setter Property="Focusable"         Value="False"/>
        </Style>
        <Style Selector="Button.type-hint:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
        </Style>
        <Style Selector="TextBox.param-input">
            <Setter Property="Background"       Value="{DynamicResource Brush.Surface.Input}"/>
            <Setter Property="Foreground"       Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource Brush.Border.Strong}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="{DynamicResource FontSize.Body}"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="AutoCompleteBox.param-input">
            <Setter Property="Background"       Value="{DynamicResource Brush.Surface.Input}"/>
            <Setter Property="Foreground"       Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource Brush.Border.Strong}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="{DynamicResource FontSize.Body}"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.footer-btn">
            <Setter Property="Background"      Value="{DynamicResource Brush.Surface.Header}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,6"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSize.Body}"/>
            <Setter Property="MinWidth"        Value="90"/>
        </Style>
        <Style Selector="Button.footer-btn.primary">
            <Setter Property="Background" Value="{DynamicResource Brush.Button.Primary.Background}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto,Auto">

        <ScrollViewer Grid.Row="0" Padding="0">
            <StackPanel Margin="14,12,14,4" Spacing="6">

                <!-- Condition rows -->
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ConditionRowViewModel">
                            <Border Background="{DynamicResource Brush.Surface.Panel}" CornerRadius="4"
                                    Margin="0,0,0,4" Padding="10,8">
                                <StackPanel Spacing="6">

                                    <!-- Row header -->
                                    <Grid ColumnDefinitions="70,Auto,*,28,28,28">
                                        <!-- And / Or -->
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{x:Static vm:ConditionRowViewModel.OperatorOptions}"
                                                  SelectedItem="{Binding Operator, Mode=TwoWay}"
                                                  Background="{DynamicResource Brush.Surface.Card}" BorderBrush="{DynamicResource Brush.Border.Muted}"
                                                  BorderThickness="1" FontSize="{DynamicResource FontSize.Label}" Padding="4,2"
                                                  AutomationProperties.Name="{DynamicResource AutomationName_ConditionOperator}"/>
                                        <!-- NOT toggle -->
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Not, Mode=TwoWay}"
                                                  Content="{DynamicResource Label_Condition_NOT}"
                                                  Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{DynamicResource FontSize.Label}"
                                                  Margin="8,0,8,0" VerticalAlignment="Center"
                                                  ToolTip.Tip="{DynamicResource ToolTip_ConditionNot}"
                                                  AutomationProperties.HelpText="{DynamicResource ToolTip_ConditionNot}"/>
                                        <!-- Display name (leaves) -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource FontSize.Medium}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsLeaf}"/>
                                        <!-- Branch indicator + edit button: ⚙ icon and the
                                             truncated group name share the flexible middle
                                             column (the * bounds the name so the ellipsis
                                             actually fires); the Edit button docks hard-right
                                             so it clusters with the outer ↑ ↓ ✕ buttons and
                                             can never be pushed off-screen. -->
                                        <Grid Grid.Column="2"
                                              ColumnDefinitions="Auto,*,Auto"
                                              VerticalAlignment="Center"
                                              IsVisible="{Binding IsBranch}">
                                            <TextBlock Grid.Column="0" Text="⚙"
                                                       Foreground="{DynamicResource Brush.Text.Highlight}" FontSize="{DynamicResource FontSize.Medium}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"
                                                       ToolTip.Tip="{DynamicResource ToolTip_ConditionBranch}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Body}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       ToolTip.Tip="{Binding DisplayName}"/>
                                            <Button Grid.Column="2"
                                                    Content="{DynamicResource Button_EditBranchGroup}"
                                                    Tag="{Binding}"
                                                    Click="EditBranchGroup_Click"
                                                    Background="{DynamicResource Brush.Node.Script.Header}" Foreground="{DynamicResource Brush.Text.Secondary}"
                                                    BorderThickness="0" Padding="8,2" FontSize="{DynamicResource FontSize.Small}"
                                                    Margin="6,0,0,0"
                                                    ToolTip.Tip="{DynamicResource ToolTip_EditBranchGroup}"
                                                    AutomationProperties.HelpText="{DynamicResource ToolTip_EditBranchGroup}"/>
                                        </Grid>
                                        <!-- Move up -->
                                        <Button Grid.Column="3" Content="↑"
                                                Command="{Binding DataContext.MoveUpCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{DynamicResource FontSize.Medium}" Padding="4"
                                                ToolTip.Tip="{DynamicResource ToolTip_MoveConditionUp}"
                                                AutomationProperties.HelpText="{DynamicResource ToolTip_MoveConditionUp}"
                                                AutomationProperties.Name="{DynamicResource AutomationName_MoveConditionUp}"/>
                                        <!-- Move down -->
                                        <Button Grid.Column="4" Content="↓"
                                                Command="{Binding DataContext.MoveDownCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{DynamicResource FontSize.Medium}" Padding="4"
                                                ToolTip.Tip="{DynamicResource ToolTip_MoveConditionDown}"
                                                AutomationProperties.HelpText="{DynamicResource ToolTip_MoveConditionDown}"
                                                AutomationProperties.Name="{DynamicResource AutomationName_MoveConditionDown}"/>
                                        <!-- Delete -->
                                        <Button Grid.Column="5" Content="✕"
                                                Command="{Binding DataContext.DeleteRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource Brush.Severity.Error}" FontSize="{DynamicResource FontSize.Medium}" Padding="4"
                                                ToolTip.Tip="{DynamicResource ToolTip_DeleteCondition}"
                                                AutomationProperties.HelpText="{DynamicResource ToolTip_DeleteCondition}"
                                                AutomationProperties.Name="{DynamicResource AutomationName_RemoveCondition}"/>
                                    </Grid>

                                    <!-- Parameters (hidden for branch rows) -->
                                    <ItemsControl ItemsSource="{Binding Parameters}"
                                                  IsVisible="{Binding IsLeaf}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ParameterValueViewModel">
                                                <Grid ColumnDefinitions="110,*,Auto"
                                                      Margin="0,2,0,0" MinHeight="32">
                                                    <!-- Parameter label -->
                                                    <TextBlock Grid.Column="0"
                                                               Classes="param-label"
                                                               Text="{Binding Name}"/>
                                                    <!-- Text input (shown when not an enum type) -->
                                                    <TextBox Grid.Column="1"
                                                             Classes="param-input"
                                                             Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             IsVisible="{Binding IsText}"
                                                             ToolTip.Tip="{Binding TypeHint}"
                                                             AutomationProperties.Name="{Binding Name}"/>
                                                    <!-- Enum/Operator AutoCompleteBox — supports both
                                                         free-text and filtering for large option lists -->
                                                    <AutoCompleteBox Grid.Column="1"
                                                              Classes="param-input"
                                                              ItemsSource="{Binding EnumOptions}"
                                                              Text="{Binding Value, Mode=TwoWay}"
                                                              FilterMode="Contains"
                                                              MinimumPrefixLength="0"
                                                              IsVisible="{Binding IsEnum}"
                                                              ToolTip.Tip="{Binding TypeHint}"
                                                              AutomationProperties.Name="{Binding Name}"/>
                                                    <!-- GUID AutoCompleteBox — "Name — GUID" suggestions from
                                                         SpeakerNameService; filters on name AND raw GUID fragment;
                                                         OnValueChanged normalises "Name — GUID" → bare GUID -->
                                                    <AutoCompleteBox Grid.Column="1"
                                                              Classes="param-input"
                                                              ItemsSource="{Binding Suggestions}"
                                                              Text="{Binding Value, Mode=TwoWay}"
                                                              FilterMode="Contains"
                                                              MinimumPrefixLength="0"
                                                              IsVisible="{Binding HasLookup}"
                                                              ToolTip.Tip="{Binding TypeHint}"
                                                              AutomationProperties.HelpText="{Binding TypeHint}"
                                                              AutomationProperties.Name="{Binding Name}"/>
                                                    <!-- Type hint (?) — Button for reliable tooltip on hover -->
                                                    <Button Grid.Column="2"
                                                            Classes="type-hint"
                                                            Content="(?)"
                                                            ToolTip.Tip="{Binding TypeHint}"
                                                            IsVisible="{Binding HasTypeHint}"
                                                            AutomationProperties.Name="{DynamicResource AutomationName_ParameterHelp}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add condition row -->
                <Border Background="{DynamicResource Brush.Surface.Card}" CornerRadius="3" Padding="8,6">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableConditions}"
                                  SelectedItem="{Binding SelectedNewCondition, Mode=TwoWay}"
                                  PlaceholderText="{DynamicResource Placeholder_PickCondition}"
                                  Background="{DynamicResource Brush.Surface.Input}" BorderBrush="{DynamicResource Brush.Border.Strong}" BorderThickness="1"
                                  FontSize="{DynamicResource FontSize.Body}" Padding="6,4"
                                  ToolTip.Tip="{DynamicResource ToolTip_PickCondition}"
                                  AutomationProperties.HelpText="{DynamicResource ToolTip_PickCondition}"
                                  AutomationProperties.Name="{DynamicResource Placeholder_PickCondition}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="types:ConditionEntry">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{DynamicResource FontSize.Body}"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{DynamicResource FontSize.Small}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1"
                                Content="+ Add"
                                Command="{Binding AddSelectedConditionCommand}"
                                Background="{DynamicResource Brush.Node.Script.Header}" Foreground="{DynamicResource Brush.Text.Secondary}" BorderThickness="0"
                                Padding="14,6" Margin="8,0,0,0" FontSize="{DynamicResource FontSize.Body}"
                                ToolTip.Tip="{DynamicResource ToolTip_AddCondition}"
                                AutomationProperties.HelpText="{DynamicResource ToolTip_AddCondition}"/>
                        <Button Grid.Column="2"
                                Content="{DynamicResource Button_NewGroup}"
                                Command="{Binding AddGroupCommand}"
                                Background="{DynamicResource Brush.Node.Script.Header}" Foreground="{DynamicResource Brush.Text.Secondary}" BorderThickness="0"
                                Padding="14,6" Margin="6,0,0,0" FontSize="{DynamicResource FontSize.Body}"
                                ToolTip.Tip="{DynamicResource ToolTip_NewGroup}"
                                AutomationProperties.HelpText="{DynamicResource ToolTip_NewGroup}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Surface.Panel}" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Classes="footer-btn"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        ToolTip.Tip="{DynamicResource ToolTip_ConditionEditorCancel}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_ConditionEditorCancel}"/>
                <Button Classes="footer-btn primary"
                        Content="OK"
                        Command="{Binding ConfirmCommand}"
                        ToolTip.Tip="{DynamicResource ToolTip_ConditionEditorOK}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_ConditionEditorOK}"/>
            </StackPanel>
        </Border>

        <!-- Focus hint bar (Gaps item 13) -->
        <shared:FocusHintBar Grid.Row="2" x:Name="HintBar"/>

    </Grid>
</Window>
