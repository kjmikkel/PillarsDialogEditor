<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
        xmlns:types="clr-namespace:DialogEditor.ViewModels.Services;assembly=DialogEditor.ViewModels"
        x:Class="DialogEditor.Avalonia.Views.ConditionEditorWindow"
        Title="{Binding WindowTitle}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="640" Height="560" MinWidth="480" MinHeight="360"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        x:CompileBindings="False">

    <Window.Styles>
        <Style Selector="TextBlock.param-label">
            <Setter Property="Foreground"        Value="#888"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth"          Value="110"/>
        </Style>
        <Style Selector="Button.type-hint">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Foreground"        Value="#888"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="4,0,0,0"/>
            <Setter Property="Padding"           Value="2,0"/>
            <Setter Property="Cursor"            Value="Help"/>
            <Setter Property="Focusable"         Value="False"/>
        </Style>
        <Style Selector="Button.type-hint:pointerover">
            <Setter Property="Foreground" Value="#ccc"/>
        </Style>
        <Style Selector="TextBox.param-input">
            <Setter Property="Background"       Value="#141414"/>
            <Setter Property="Foreground"       Value="#e8e8e8"/>
            <Setter Property="BorderBrush"      Value="#444"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.param-input">
            <Setter Property="Background"       Value="#141414"/>
            <Setter Property="Foreground"       Value="#e8e8e8"/>
            <Setter Property="BorderBrush"      Value="#444"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.footer-btn">
            <Setter Property="Background"      Value="#333"/>
            <Setter Property="Foreground"      Value="#ccc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="MinWidth"        Value="90"/>
        </Style>
        <Style Selector="Button.footer-btn.primary">
            <Setter Property="Background" Value="#1a5276"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <ScrollViewer Grid.Row="0" Padding="0">
            <StackPanel Margin="14,12,14,4" Spacing="6">

                <!-- Condition rows -->
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:ConditionRowViewModel">
                            <Border Background="#252525" CornerRadius="4"
                                    Margin="0,0,0,4" Padding="10,8">
                                <StackPanel Spacing="6">

                                    <!-- Row header -->
                                    <Grid ColumnDefinitions="70,Auto,*,28,28,28">
                                        <!-- And / Or (hidden for branch rows — branch controls its own operator) -->
                                        <ComboBox Grid.Column="0"
                                                  ItemsSource="{x:Static vm:ConditionRowViewModel.OperatorOptions}"
                                                  SelectedItem="{Binding Operator, Mode=TwoWay}"
                                                  Background="#1a1a1a" BorderBrush="#555"
                                                  BorderThickness="1" FontSize="11" Padding="4,2"
                                                  IsVisible="{Binding IsLeaf}"/>
                                        <!-- NOT toggle -->
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding Not, Mode=TwoWay}"
                                                  Content="{StaticResource Label_Condition_NOT}"
                                                  Foreground="#aaa" FontSize="11"
                                                  Margin="8,0,8,0" VerticalAlignment="Center"
                                                  IsVisible="{Binding IsLeaf}"
                                                  ToolTip.Tip="{StaticResource ToolTip_ConditionNot}"/>
                                        <!-- Display name (leaves) -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="#e8e8e8" FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding IsLeaf}"/>
                                        <!-- Branch indicator + edit button -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center" Spacing="6"
                                                    IsVisible="{Binding IsBranch}">
                                            <TextBlock Text="⚙" Foreground="#f0a830" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#888" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       ToolTip.Tip="{StaticResource ToolTip_ConditionBranch}"/>
                                            <Button Content="{StaticResource Button_EditBranchGroup}"
                                                    Tag="{Binding}"
                                                    Click="EditBranchGroup_Click"
                                                    Background="#2c3e50" Foreground="#ccc"
                                                    BorderThickness="0" Padding="8,2" FontSize="10"
                                                    ToolTip.Tip="{StaticResource ToolTip_EditBranchGroup}"/>
                                        </StackPanel>
                                        <!-- Move up -->
                                        <Button Grid.Column="3" Content="↑"
                                                Command="{Binding DataContext.MoveUpCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#aaa" FontSize="13" Padding="4"
                                                ToolTip.Tip="{StaticResource ToolTip_MoveConditionUp}"/>
                                        <!-- Move down -->
                                        <Button Grid.Column="4" Content="↓"
                                                Command="{Binding DataContext.MoveDownCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#aaa" FontSize="13" Padding="4"
                                                ToolTip.Tip="{StaticResource ToolTip_MoveConditionDown}"/>
                                        <!-- Delete -->
                                        <Button Grid.Column="5" Content="✕"
                                                Command="{Binding DataContext.DeleteRowCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#c0392b" FontSize="13" Padding="4"
                                                ToolTip.Tip="{StaticResource ToolTip_DeleteCondition}"/>
                                    </Grid>

                                    <!-- Parameters (hidden for branch rows) -->
                                    <ItemsControl ItemsSource="{Binding Parameters}"
                                                  IsVisible="{Binding IsLeaf}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ParameterValueViewModel">
                                                <Grid ColumnDefinitions="110,*,Auto"
                                                      Margin="0,2,0,0" MinHeight="32">
                                                    <!-- Parameter label -->
                                                    <TextBlock Grid.Column="0"
                                                               Classes="param-label"
                                                               Text="{Binding Name}"/>
                                                    <!-- Text input (shown when not an enum type) -->
                                                    <TextBox Grid.Column="1"
                                                             Classes="param-input"
                                                             Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             IsVisible="{Binding IsText}"
                                                             ToolTip.Tip="{Binding TypeHint}"/>
                                                    <!-- Enum/Operator ComboBox -->
                                                    <ComboBox Grid.Column="1"
                                                              Classes="param-input"
                                                              ItemsSource="{Binding EnumOptions}"
                                                              SelectedItem="{Binding Value, Mode=TwoWay}"
                                                              IsVisible="{Binding IsEnum}"
                                                              ToolTip.Tip="{Binding TypeHint}"/>
                                                    <!-- Type hint (?) — Button for reliable tooltip on hover -->
                                                    <Button Grid.Column="2"
                                                            Classes="type-hint"
                                                            Content="(?)"
                                                            ToolTip.Tip="{Binding TypeHint}"
                                                            IsVisible="{Binding HasTypeHint}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add condition row -->
                <Border Background="#1a1a1a" CornerRadius="3" Padding="8,6">
                    <Grid ColumnDefinitions="*,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableConditions}"
                                  SelectedItem="{Binding SelectedNewCondition, Mode=TwoWay}"
                                  PlaceholderText="{StaticResource Placeholder_PickCondition}"
                                  Background="#141414" BorderBrush="#444" BorderThickness="1"
                                  FontSize="12" Padding="6,4"
                                  ToolTip.Tip="{StaticResource ToolTip_PickCondition}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="types:ConditionEntry">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#e8e8e8" FontSize="12"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="#555" FontSize="10"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="1"
                                Content="+ Add"
                                Command="{Binding AddSelectedConditionCommand}"
                                Background="#2c3e50" Foreground="#ccc" BorderThickness="0"
                                Padding="14,6" Margin="8,0,0,0" FontSize="12"
                                ToolTip.Tip="{StaticResource ToolTip_AddCondition}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" Background="#252525" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Classes="footer-btn"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        ToolTip.Tip="{StaticResource ToolTip_ConditionEditorCancel}"/>
                <Button Classes="footer-btn primary"
                        Content="OK"
                        Command="{Binding ConfirmCommand}"
                        ToolTip.Tip="{StaticResource ToolTip_ConditionEditorOK}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
