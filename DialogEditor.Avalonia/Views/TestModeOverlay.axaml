<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DialogEditor.Avalonia.Views.TestModeOverlay"
             IsHitTestVisible="True"
             x:CompileBindings="False">

    <!-- Full-screen semi-transparent backdrop that absorbs all pointer events -->
    <Grid Background="#BB000000">

        <!-- Centred card -->
        <Border Background="#252525"
                BorderBrush="#555" BorderThickness="1"
                CornerRadius="6"
                Padding="32,24"
                MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="20" HorizontalAlignment="Center">

                <!-- Icon + heading -->
                <TextBlock Text="⚗"
                           FontSize="32"
                           HorizontalAlignment="Center"
                           Foreground="#f0a830"/>

                <TextBlock Text="{StaticResource TestMode_Message}"
                           Foreground="#e8e8e8"
                           FontSize="13"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="380"/>

                <Button Content="{StaticResource TestMode_Restore}"
                        Command="{Binding RestoreConversationCommand}"
                        HorizontalAlignment="Center"
                        Background="#c0392b" Foreground="White"
                        BorderThickness="0"
                        Padding="24,8" FontSize="13"
                        ToolTip.Tip="{StaticResource ToolTip_TestMode_Restore}"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
