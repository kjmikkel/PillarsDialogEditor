<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.ConflictResolutionDialog"
        Title="{DynamicResource ConflictDialog_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="520" MinWidth="520" SizeToContent="Height"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">

    <StackPanel Margin="20">

        <TextBlock Text="{DynamicResource ConflictDialog_Intro}"
                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Medium}"
                   TextWrapping="Wrap" Margin="0,0,0,14"/>

        <Border Background="{DynamicResource Brush.Surface.Card}" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
            <StackPanel>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{DynamicResource ConflictDialog_NodeLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Label}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="NodeIdBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}" TextWrapping="Wrap"/>
                </Grid>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{DynamicResource ConflictDialog_FieldLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Label}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FieldNameBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}" TextWrapping="Wrap"/>
                </Grid>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{DynamicResource ConflictDialog_ExpectedLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Label}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ExpectedBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}" TextWrapping="Wrap"/>
                </Grid>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{DynamicResource ConflictDialog_ActualLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Label}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActualBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelButton"
                    Content="{DynamicResource ConflictDialog_Cancel}"
                    ToolTip.Tip="{DynamicResource ConflictDialog_CancelTooltip}"
                    AutomationProperties.HelpText="{DynamicResource ConflictDialog_CancelTooltip}"
                    Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="{StaticResource FontSize.Body}"/>
            <Button x:Name="ForceButton"
                    Content="{DynamicResource ConflictDialog_Force}"
                    ToolTip.Tip="{DynamicResource ConflictDialog_ForceTooltip}"
                    AutomationProperties.HelpText="{DynamicResource ConflictDialog_ForceTooltip}"
                    Background="{DynamicResource Brush.Button.Caution.Background}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="{StaticResource FontSize.Body}"/>
        </StackPanel>

        <!-- Focus hint bar (Gaps item 16) -->
        <shared:FocusHintBar x:Name="HintBar"/>

    </StackPanel>

</Window>
