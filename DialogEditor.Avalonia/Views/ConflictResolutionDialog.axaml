<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.ConflictResolutionDialog"
        Title="{StaticResource ConflictDialog_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="520" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">

    <StackPanel Margin="20">

        <TextBlock Text="{StaticResource ConflictDialog_Intro}"
                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13"
                   TextWrapping="Wrap" Margin="0,0,0,14"/>

        <Border Background="{DynamicResource Brush.Surface.Card}" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
            <StackPanel>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{StaticResource ConflictDialog_NodeLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="NodeIdBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12" TextWrapping="Wrap"/>
                </Grid>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{StaticResource ConflictDialog_FieldLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FieldNameBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12" TextWrapping="Wrap"/>
                </Grid>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{StaticResource ConflictDialog_ExpectedLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ExpectedBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12" TextWrapping="Wrap"/>
                </Grid>
                <Grid ColumnDefinitions="120,*" Margin="0,3">
                    <TextBlock Text="{StaticResource ConflictDialog_ActualLabel}"
                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActualBlock" Grid.Column="1"
                               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12" TextWrapping="Wrap"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelButton"
                    Content="{StaticResource ConflictDialog_Cancel}"
                    ToolTip.Tip="{StaticResource ConflictDialog_CancelTooltip}"
                    Background="{DynamicResource Brush.Surface.Header}" Foreground="White" BorderThickness="0"
                    Padding="16,6" FontSize="12"/>
            <Button x:Name="ForceButton"
                    Content="{StaticResource ConflictDialog_Force}"
                    ToolTip.Tip="{StaticResource ConflictDialog_ForceTooltip}"
                    Background="{DynamicResource Brush.Button.Caution.Background}" Foreground="White" BorderThickness="0"
                    Padding="16,6" FontSize="12"/>
        </StackPanel>

    </StackPanel>

</Window>
