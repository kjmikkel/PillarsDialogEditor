<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
             xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
             xmlns:models="clr-namespace:DialogEditor.Core.Models;assembly=DialogEditor.Core"
             x:Class="DialogEditor.Avalonia.Views.ConversationView" x:CompileBindings="False">

    <UserControl.Styles>
        <!-- Connection stroke colours — driven by CSS classes set in code -->
        <Style Selector="nodify|Connection">
            <Setter Property="Stroke" Value="#aaa"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
        </Style>
        <Style Selector="nodify|Connection.always">
            <Setter Property="Stroke" Value="#b8760a"/>
        </Style>
        <Style Selector="nodify|Connection.never">
            <Setter Property="Stroke" Value="#555"/>
            <Setter Property="StrokeDashArray" Value="4,3"/>
        </Style>
        <Style Selector="nodify|Connection.highlighted">
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="2.5"/>
        </Style>
        <Style Selector="nodify|Connection.highlighted.always">
            <Setter Property="Stroke" Value="#f0a830"/>
        </Style>
        <Style Selector="nodify|Connection.highlighted.never">
            <Setter Property="Stroke" Value="#bbb"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#252525" Padding="8,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{StaticResource Legend_Control_Fit}"
                            Command="{x:Static nodify:EditorCommands.FitToScreen}"
                            CommandParameter="{Binding ElementName=Editor}"
                            Background="#333" Foreground="#aaa" BorderThickness="0" Padding="8,2"
                            ToolTip.Tip="{StaticResource ToolTip_FitToScreen}"/>
                    <Button Content="+"
                            Command="{x:Static nodify:EditorCommands.ZoomIn}"
                            CommandParameter="{Binding ElementName=Editor}"
                            Background="#333" Foreground="#aaa" BorderThickness="0" Padding="8,2" Margin="4,0,0,0"
                            ToolTip.Tip="{StaticResource ToolTip_ZoomIn}"/>
                    <Button Content="−"
                            Command="{x:Static nodify:EditorCommands.ZoomOut}"
                            CommandParameter="{Binding ElementName=Editor}"
                            Background="#333" Foreground="#aaa" BorderThickness="0" Padding="8,2" Margin="2,0,0,0"
                            ToolTip.Tip="{StaticResource ToolTip_ZoomOut}"/>
                    <Button Content="⌂"
                            Click="CenterOnRoot_Click"
                            Background="#333" Foreground="#aaa" BorderThickness="0" Padding="8,2" Margin="8,0,0,0"
                            ToolTip.Tip="{StaticResource ToolTip_JumpToRoot}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding NodeCountText}"
                           Foreground="#888" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Grid VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery}"
                             Background="#333" Foreground="#ccc" CaretBrush="#ccc"
                             BorderBrush="#555" BorderThickness="1"
                             Padding="6,2,24,2" FontSize="10"
                             ToolTip.Tip="{StaticResource ToolTip_SearchNodes}"/>
                    <TextBlock Text="{StaticResource Placeholder_SearchNodes}"
                               Foreground="#555" FontSize="10"
                               Padding="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                               IsVisible="{Binding SearchQuery, Converter={StaticResource NullOrEmptyToVis}}"/>
                    <Button Command="{Binding ClearSearchCommand}"
                            HorizontalAlignment="Right" Width="20"
                            Content="✕" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#666" FontSize="10" Cursor="Hand"
                            ToolTip.Tip="{StaticResource ToolTip_ClearSearch}"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Canvas -->
        <Grid Grid.Row="1">
            <nodify:NodifyEditor x:Name="Editor"
                                 Background="#7a6a8e"
                                 ItemsSource="{Binding Nodes}"
                                 Connections="{Binding Connections}">

                <!-- Style-based bindings sit on top of Nodify's own default ControlTheme
                     without replacing it (unlike ItemContainerTheme + ControlTheme). -->
                <nodify:NodifyEditor.Styles>
                    <Style Selector="nodify|ItemContainer">
                        <Setter Property="Location" Value="{Binding Location,
                                           Converter={StaticResource LayoutPointConverter}}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    </Style>
                </nodify:NodifyEditor.Styles>

                <!-- DIAGNOSTIC ItemTemplate: plain border instead of nodify:Node
                     to test whether ItemTemplate is applied at all. -->
                <nodify:NodifyEditor.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                        <Border Width="180" Height="60" Background="Red" CornerRadius="4">
                            <TextBlock Text="{Binding Title}" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="11"/>
                        </Border>
                    </DataTemplate>
                </nodify:NodifyEditor.ItemTemplate>

                <nodify:NodifyEditor.ConnectionTemplate>
                    <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                        <nodify:Connection
                            Source="{Binding Source.Anchor, Converter={StaticResource LayoutPointConverter}}"
                            Target="{Binding Target.Anchor, Converter={StaticResource LayoutPointConverter}}"
                            Classes.always="{Binding IsAlways}"
                            Classes.never="{Binding IsNever}"
                            Classes.highlighted="{Binding IsHighlighted}"/>
                    </DataTemplate>
                </nodify:NodifyEditor.ConnectionTemplate>

            </nodify:NodifyEditor>

            <!-- Minimap -->
            <nodify:Minimap
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="8" Width="160" Height="110"
                IsReadOnly="False"
                Background="#1a1a2a"
                ItemsSource="{Binding Nodes}"
                ViewportLocation="{Binding ViewportLocation, ElementName=Editor, Mode=TwoWay}"
                ViewportSize="{Binding ViewportSize, ElementName=Editor}"
                ToolTip.Tip="{StaticResource ToolTip_Minimap}">
                <nodify:Minimap.ItemContainerTheme>
                    <ControlTheme TargetType="nodify:MinimapItem">
                        <Setter Property="Location" Value="{Binding Location,
                                           Converter={StaticResource LayoutPointConverter}}"/>
                        <Setter Property="Width" Value="200"/>
                        <Setter Property="Height" Value="80"/>
                        <Setter Property="Template">
                            <ControlTemplate TargetType="nodify:MinimapItem">
                                <Border Background="{Binding SpeakerCategory,
                                                    Converter={StaticResource SpeakerCategoryToBrush}}"
                                        CornerRadius="2"/>
                            </ControlTemplate>
                        </Setter>
                    </ControlTheme>
                </nodify:Minimap.ItemContainerTheme>
            </nodify:Minimap>

        </Grid>
    </Grid>
</UserControl>
