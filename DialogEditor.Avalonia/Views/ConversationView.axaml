<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="clr-namespace:Nodify;assembly=Nodify"
             xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
             xmlns:models="clr-namespace:DialogEditor.Core.Models;assembly=DialogEditor.Core"
             xmlns:theming="clr-namespace:DialogEditor.Avalonia.Shared.Theming;assembly=DialogEditor.Avalonia.Shared"
             xmlns:local="clr-namespace:DialogEditor.Avalonia.Views"
             x:Class="DialogEditor.Avalonia.Views.ConversationView" x:CompileBindings="False">

    <UserControl.Styles>
        <!-- Connection stroke colours — driven by CSS classes set in code -->
        <Style Selector="nodify|Connection">
            <Setter Property="Stroke" Value="{DynamicResource Brush.Connection.Default}"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
        </Style>
        <Style Selector="nodify|Connection.always">
            <Setter Property="Stroke" Value="{DynamicResource Brush.Connection.Always}"/>
            <Setter Property="StrokeDashArray" Value="10,2,2,2"/>
        </Style>
        <Style Selector="nodify|Connection.never">
            <Setter Property="Stroke" Value="{DynamicResource Brush.Connection.Never}"/>
            <Setter Property="StrokeDashArray" Value="4,3"/>
        </Style>
        <Style Selector="nodify|Connection.highlighted">
            <Setter Property="Stroke" Value="{DynamicResource Brush.Connection.Highlighted}"/>
            <Setter Property="StrokeThickness" Value="2.5"/>
        </Style>
        <Style Selector="nodify|Connection.highlighted.always">
            <Setter Property="Stroke" Value="{DynamicResource Brush.Connection.Highlighted.Always}"/>
            <Setter Property="StrokeDashArray" Value="10,2,2,2"/>
        </Style>
        <Style Selector="nodify|Connection.highlighted.never">
            <Setter Property="Stroke" Value="{DynamicResource Brush.Connection.Highlighted.Never}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Toolbar. Bottom divider so the toolbar/canvas edge reads in every theme — a faint
             hairline in Dark/Light, a bright separator in High-Contrast (where panel and canvas
             are both dark and tone alone wouldn't separate them). -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface.Panel}" Padding="8,4"
                BorderBrush="{DynamicResource Brush.Border.Default}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{DynamicResource Legend_Control_Fit}"
                            Click="FitToScreen_Click"
                            Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Muted.Light}" BorderThickness="0" Padding="8,2"
                            ToolTip.Tip="{DynamicResource ToolTip_FitToScreen}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_FitToScreen}"/>
                    <Button Content="+"
                            Click="ZoomIn_Click"
                            Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Muted.Light}" BorderThickness="0" Padding="8,2" Margin="4,0,0,0"
                            ToolTip.Tip="{DynamicResource ToolTip_ZoomIn}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_ZoomIn}"
                            AutomationProperties.Name="{DynamicResource AutomationName_ZoomIn}"/>
                    <Button Content="−"
                            Click="ZoomOut_Click"
                            Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Muted.Light}" BorderThickness="0" Padding="8,2" Margin="2,0,0,0"
                            ToolTip.Tip="{DynamicResource ToolTip_ZoomOut}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_ZoomOut}"
                            AutomationProperties.Name="{DynamicResource AutomationName_ZoomOut}"/>
                    <Button Content="{DynamicResource Label_AddAnnotation}"
                            Click="AddAnnotation_Click"
                            IsVisible="{Binding IsEditable}"
                            Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Muted.Light}" BorderThickness="0" Padding="8,2" Margin="4,0,0,0"
                            ToolTip.Tip="{DynamicResource ToolTip_AddAnnotation}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_AddAnnotation}"
                            AutomationProperties.Name="{DynamicResource AutomationName_AddAnnotation}"/>
                    <Button Content="⌂"
                            Click="CenterOnRoot_Click"
                            Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Muted.Light}" BorderThickness="0" Padding="8,2" Margin="8,0,0,0"
                            ToolTip.Tip="{DynamicResource ToolTip_JumpToRoot}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_JumpToRoot}"
                            AutomationProperties.Name="{DynamicResource AutomationName_JumpToRoot}"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatisticsText}"
                           Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Small}" VerticalAlignment="Center" Margin="0,0,8,0"
                           ToolTip.Tip="{Binding StatisticsTooltip}"/>
                <Grid VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery}"
                             Watermark="{DynamicResource Placeholder_SearchNodes}"
                             AutomationProperties.Name="{DynamicResource Placeholder_SearchNodes}"
                             Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Secondary}" CaretBrush="{DynamicResource Brush.Text.Secondary}"
                             BorderBrush="{DynamicResource Brush.Border.Muted}" BorderThickness="1"
                             Padding="6,2,24,2" FontSize="{DynamicResource FontSize.Body}" Height="26"
                             VerticalContentAlignment="Center"
                             KeyDown="SearchBox_KeyDown"
                             ToolTip.Tip="{DynamicResource ToolTip_SearchNodes}"
                             AutomationProperties.HelpText="{DynamicResource ToolTip_SearchNodes}"/>
                    <Button Command="{Binding ClearSearchCommand}"
                            HorizontalAlignment="Right" Width="24" Height="24"
                            Content="✕" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{DynamicResource FontSize.Small}" Cursor="Hand"
                            ToolTip.Tip="{DynamicResource ToolTip_ClearSearch}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_ClearSearch}"
                            AutomationProperties.Name="{DynamicResource AutomationName_ClearSearch}"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- Canvas -->
        <Grid Grid.Row="1" ClipToBounds="True">
            <nodify:NodifyEditor x:Name="Editor"
                                 Background="{DynamicResource Brush.Canvas.Background}"
                                 ItemsSource="{Binding Nodes}"
                                 Connections="{Binding Connections}"
                                 PendingConnection="{Binding PendingConnection}"
                                 DoubleTapped="Editor_DoubleTapped"
                                 KeyDown="Editor_KeyDown"
                                 GotFocus="Editor_GotFocus"
                                 PointerPressed="Editor_PointerPressed">
                <nodify:NodifyEditor.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource Menu_Canvas_AddNodeHere}"
                                  Click="CanvasMenu_AddNode_Click"
                                  IsVisible="{Binding IsEditable}"
                                  ToolTip.Tip="{DynamicResource ToolTip_Menu_Canvas_AddNodeHere}"
                                  AutomationProperties.HelpText="{DynamicResource ToolTip_Menu_Canvas_AddNodeHere}"/>
                        <MenuItem Header="{DynamicResource Menu_Canvas_AddAnnotationHere}"
                                  Click="CanvasMenu_AddAnnotation_Click"
                                  IsVisible="{Binding IsEditable}"
                                  ToolTip.Tip="{DynamicResource ToolTip_Menu_Canvas_AddAnnotationHere}"
                                  AutomationProperties.HelpText="{DynamicResource ToolTip_Menu_Canvas_AddAnnotationHere}"/>
                        <Separator IsVisible="{Binding CanBatchImportVo}"/>
                        <MenuItem Header="{DynamicResource Menu_BatchImportVo}"
                                  Command="{Binding BatchImportVoCommand}"
                                  IsVisible="{Binding CanBatchImportVo}"
                                  ToolTip.Tip="{DynamicResource ToolTip_Menu_BatchImportVo}"
                                  AutomationProperties.HelpText="{DynamicResource ToolTip_Menu_BatchImportVo}"/>
                    </ContextMenu>
                </nodify:NodifyEditor.ContextMenu>

                <!-- Drag-to-connect: the PendingConnection control MUST live inside
                     PendingConnectionTemplate (not be assigned to the PendingConnection
                     DataContext property directly). Only when hosted via the template does
                     it find its owner NodifyEditor (GetParentOfType) and subscribe to the
                     drag events that update SourceAnchor/TargetAnchor — without that, the
                     in-progress line has no coordinates to draw and stays invisible. -->
                <nodify:NodifyEditor.PendingConnectionTemplate>
                    <DataTemplate DataType="{x:Type vm:PendingConnectionViewModel}">
                        <nodify:PendingConnection
                            StartedCommand="{Binding StartCommand}"
                            CompletedCommand="{Binding CompleteCommand}"
                            Stroke="{DynamicResource Brush.Connection.Default}" StrokeThickness="2" StrokeDashArray="4,3"/>
                    </DataTemplate>
                </nodify:NodifyEditor.PendingConnectionTemplate>

                <nodify:NodifyEditor.ItemContainerTheme>
                    <ControlTheme TargetType="nodify:ItemContainer"
                                  BasedOn="{StaticResource {x:Type nodify:ItemContainer}}">
                        <Setter Property="Location" Value="{Binding Location, Mode=TwoWay,
                                                   Converter={StaticResource LayoutPointConverter}}"/>
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    </ControlTheme>
                </nodify:NodifyEditor.ItemContainerTheme>

                <nodify:NodifyEditor.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
                        <nodify:Node Input="{Binding Inputs}" Output="{Binding Outputs}">

                            <nodify:Node.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Menu_DeleteNode}"
                                              Command="{Binding $parent[UserControl].DataContext.DeleteNodeCmdCommand}"
                                              CommandParameter="{Binding}"
                                              ToolTip.Tip="{DynamicResource ToolTip_DeleteNode}"
                                              AutomationProperties.HelpText="{DynamicResource ToolTip_DeleteNode}"/>
                                    <MenuItem Header="{DynamicResource Menu_AddConnectedNode}"
                                              Command="{Binding $parent[UserControl].DataContext.AddConnectedNodeCmdCommand}"
                                              CommandParameter="{Binding}"
                                              ToolTip.Tip="{DynamicResource ToolTip_AddConnectedNode}"
                                              AutomationProperties.HelpText="{DynamicResource ToolTip_AddConnectedNode}"/>
                                    <MenuItem Header="{DynamicResource Menu_ConnectToNode}"
                                              Command="{Binding $parent[UserControl].DataContext.BeginConnectCmdCommand}"
                                              CommandParameter="{Binding}"
                                              ToolTip.Tip="{DynamicResource ToolTip_ConnectToNode}"
                                              AutomationProperties.HelpText="{DynamicResource ToolTip_ConnectToNode}"/>
                                    <MenuItem Header="{DynamicResource Menu_Canvas_BrowseSpeakerLinesForNode}"
                                              Command="{Binding $parent[UserControl].DataContext.BrowseSpeakerLinesForNodeCommand}"
                                              CommandParameter="{Binding}"
                                              ToolTip.Tip="{DynamicResource ToolTip_Canvas_BrowseSpeakerLinesForNode}"
                                              AutomationProperties.HelpText="{DynamicResource ToolTip_Canvas_BrowseSpeakerLinesForNode}"/>
                                    <Separator IsVisible="{Binding $parent[UserControl].DataContext.Detail.HasVoStatus}"/>
                                    <MenuItem Header="{DynamicResource Menu_ImportVo}"
                                              Command="{Binding $parent[UserControl].DataContext.Detail.ImportVoCommand}"
                                              IsVisible="{Binding $parent[UserControl].DataContext.Detail.HasVoStatus}"
                                              ToolTip.Tip="{DynamicResource ToolTip_Menu_ImportVo}"
                                              AutomationProperties.HelpText="{DynamicResource ToolTip_Menu_ImportVo}"/>
                                </ContextMenu>
                            </nodify:Node.ContextMenu>

                            <nodify:Node.InputConnectorTemplate>
                                <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                                    <nodify:NodeInput Anchor="{Binding Anchor, Mode=OneWayToSource,
                                                                  Converter={StaticResource LayoutPointConverter}}"
                                                      IsConnected="True"/>
                                </DataTemplate>
                            </nodify:Node.InputConnectorTemplate>

                            <nodify:Node.OutputConnectorTemplate>
                                <DataTemplate DataType="{x:Type vm:ConnectorViewModel}">
                                    <nodify:NodeOutput Anchor="{Binding Anchor, Mode=OneWayToSource,
                                                                   Converter={StaticResource LayoutPointConverter}}"
                                                       IsConnected="True"/>
                                </DataTemplate>
                            </nodify:Node.OutputConnectorTemplate>

                            <Grid Width="200" RowDefinitions="Auto,Auto,Auto,Auto"
                                  Opacity="{Binding IsSearchMatch, Converter={StaticResource SearchMatchOpacity}}">

                                <!-- Diff tint overlay — transparent when Unchanged -->
                                <Border Grid.Row="0" Grid.RowSpan="3"
                                        CornerRadius="2"
                                        IsHitTestVisible="False"
                                        ZIndex="10"
                                        BorderThickness="3"
                                        BorderBrush="{Binding DiffStatus, Converter={StaticResource DiffStatusToBrushConverter}}"
                                        Background="Transparent"/>

                                <!-- Diff status badge — corner glyph mirroring the border colour;
                                     transparent background + empty glyph when Unchanged, so it
                                     renders as nothing (Layer 2.5) -->
                                <Border Grid.Row="0" Grid.RowSpan="3"
                                        Width="18" Height="18" CornerRadius="9"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-9,-9,0"
                                        IsHitTestVisible="False"
                                        ZIndex="11"
                                        Background="{Binding DiffStatus, Converter={StaticResource DiffStatusToBrushConverter}}">
                                    <TextBlock Text="{Binding DiffStatus, Converter={StaticResource DiffStatusToGlyph}}"
                                               Foreground="{DynamicResource Brush.Text.OnAccent}" FontWeight="Bold" FontSize="{DynamicResource FontSize.Label}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Connect-mode source highlight — dashed amber border + 🔗
                                     badge, top-left (opposite the diff badge's top-right corner
                                     so the two never collide). Transparent/invisible when this
                                     node isn't the connect-mode source (Layer 2.5), reusing
                                     Brush.Severity.Warning so no new colour token is needed. -->
                                <Rectangle Grid.Row="0" Grid.RowSpan="3"
                                           IsHitTestVisible="False"
                                           ZIndex="10"
                                           Stretch="Fill"
                                           StrokeThickness="3"
                                           StrokeDashArray="6,3"
                                           Stroke="{DynamicResource Brush.Severity.Warning}"
                                           IsVisible="{Binding IsConnectionSource}"/>

                                <Border x:Name="ConnectionSourceBadge"
                                        Grid.Row="0" Grid.RowSpan="3"
                                        Width="18" Height="18" CornerRadius="9"
                                        HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="-9,-9,0,0"
                                        IsHitTestVisible="False"
                                        ZIndex="11"
                                        Background="{DynamicResource Brush.Severity.Warning}"
                                        IsVisible="{Binding IsConnectionSource}">
                                    <TextBlock Text="🔗"
                                               FontSize="{DynamicResource FontSize.Label}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Header — amber when Bark, speaker-color when Conversation -->
                                <Border Grid.Row="0" CornerRadius="2,2,0,0">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource NodeColorConverter}">
                                            <Binding Path="SpeakerCategory"/>
                                            <Binding Path="DisplayType"/>
                                            <!-- Theme tick (ignored by the converter): re-fires this binding on a palette swap so the node retints live -->
                                            <Binding Source="{x:Static theming:ThemeService.Current}" Path="Revision"/>
                                        </MultiBinding>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Node-type shape marker: shape encodes type (redundant with colour for
                                             accessibility — Layer 2.5), fill mirrors the speaker colour as before -->
                                        <Path Width="9" Height="9" Margin="6,0,4,0" VerticalAlignment="Center" Stretch="Uniform"
                                              ToolTip.Tip="{Binding SpeakerCategory}">
                                            <Path.Data>
                                                <MultiBinding Converter="{StaticResource NodeTypeShape}">
                                                    <Binding Path="SpeakerCategory"/>
                                                    <Binding Path="DisplayType"/>
                                                </MultiBinding>
                                            </Path.Data>
                                            <Path.Fill>
                                                <!-- MultiBinding (not a plain Binding) so the theme tick can retint the marker live on a palette swap -->
                                                <MultiBinding Converter="{StaticResource SpeakerCategoryToBrush}">
                                                    <Binding Path="SpeakerCategory"/>
                                                    <Binding Source="{x:Static theming:ThemeService.Current}" Path="Revision"/>
                                                </MultiBinding>
                                            </Path.Fill>
                                        </Path>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource Brush.Text.OnAccent}" FontWeight="Bold"
                                                   FontSize="{DynamicResource FontSize.Small}" Padding="0,3,6,3"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>

                                <!-- Body -->
                                <Border Grid.Row="1">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource NodeColorConverter}" ConverterParameter="body">
                                            <Binding Path="SpeakerCategory"/>
                                            <Binding Path="DisplayType"/>
                                            <!-- Theme tick (ignored by the converter): re-fires this binding on a palette swap so the node retints live -->
                                            <Binding Source="{x:Static theming:ThemeService.Current}" Path="Revision"/>
                                        </MultiBinding>
                                    </Border.Background>
                                    <TextBlock Text="{Binding TextPreview}"
                                               TextWrapping="Wrap"
                                               Padding="6,4" FontSize="{DynamicResource FontSize.Small}"
                                               Foreground="{DynamicResource Brush.Text.OnLight}" MaxHeight="70"/>
                                </Border>

                                <!-- Footer -->
                                <Border Grid.Row="2" Padding="6,2">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource NodeColorConverter}" ConverterParameter="footer">
                                            <Binding Path="SpeakerCategory"/>
                                            <Binding Path="DisplayType"/>
                                            <!-- Theme tick (ignored by the converter): re-fires this binding on a palette swap so the node retints live -->
                                            <Binding Source="{x:Static theming:ThemeService.Current}" Path="Revision"/>
                                        </MultiBinding>
                                    </Border.Background>
                                    <TextBlock Text="{Binding FooterText}" FontSize="{DynamicResource FontSize.Caption}" Foreground="{DynamicResource Brush.Text.OnLight.Muted}"/>
                                </Border>

                            </Grid>

                        </nodify:Node>
                    </DataTemplate>
                </nodify:NodifyEditor.ItemTemplate>

                <nodify:NodifyEditor.ConnectionTemplate>
                    <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                        <nodify:Connection
                            Source="{Binding Source.Anchor, Converter={StaticResource LayoutPointConverter}}"
                            Target="{Binding Target.Anchor, Converter={StaticResource LayoutPointConverter}}"
                            Classes.always="{Binding IsAlways}"
                            Classes.never="{Binding IsNever}"
                            Classes.highlighted="{Binding IsHighlighted}">
                            <nodify:Connection.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Menu_DeleteConnection}"
                                              Command="{Binding $parent[UserControl].DataContext.DeleteConnectionCmdCommand}"
                                              CommandParameter="{Binding}"
                                              ToolTip.Tip="{DynamicResource ToolTip_DeleteConnection}"
                                              AutomationProperties.HelpText="{DynamicResource ToolTip_DeleteConnection}"/>
                                </ContextMenu>
                            </nodify:Connection.ContextMenu>
                        </nodify:Connection>
                    </DataTemplate>
                </nodify:NodifyEditor.ConnectionTemplate>

            </nodify:NodifyEditor>

            <!-- Minimap -->
            <nodify:Minimap
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="8" Width="160" Height="110"
                IsReadOnly="False"
                Background="{DynamicResource Brush.Surface.Info}"
                ItemsSource="{Binding Nodes}"
                ViewportLocation="{Binding ViewportLocation, ElementName=Editor, Mode=TwoWay}"
                ViewportSize="{Binding ViewportSize, ElementName=Editor}"
                ToolTip.Tip="{DynamicResource ToolTip_Minimap}">
                <nodify:Minimap.ItemContainerTheme>
                    <ControlTheme TargetType="nodify:MinimapItem"
                                  BasedOn="{StaticResource {x:Type nodify:MinimapItem}}">
                        <Setter Property="Location" Value="{Binding Location,
                                           Converter={StaticResource LayoutPointConverter}}"/>
                        <Setter Property="Width" Value="200"/>
                        <Setter Property="Height" Value="80"/>
                        <Setter Property="Template">
                            <ControlTemplate TargetType="nodify:MinimapItem">
                                <Border CornerRadius="2">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource NodeColorConverter}">
                                            <Binding Path="SpeakerCategory"/>
                                            <Binding Path="DisplayType"/>
                                            <!-- Theme tick (ignored by the converter): re-fires this binding on a palette swap so the node retints live -->
                                            <Binding Source="{x:Static theming:ThemeService.Current}" Path="Revision"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>
                            </ControlTemplate>
                        </Setter>
                    </ControlTheme>
                </nodify:Minimap.ItemContainerTheme>
            </nodify:Minimap>

            <!-- Annotation overlay — above the NodifyEditor in stacking order.
                 ItemsControl background is null so empty-canvas areas are not hit-tested;
                 only the rendered annotation boxes intercept pointer events.
                 Body area within each AnnotationView is IsHitTestVisible=False so clicks
                 on the body fall through to nodes beneath.
                 RenderTransform (set in code-behind) mirrors the NodifyEditor viewport. -->
            <!-- Annotation overlay — screen-coordinate positioned (not world-coordinate +
                 RenderTransform) so items are always within Canvas layout bounds and cannot
                 be clipped by Avalonia's implicit per-element render rect.  ConversationView
                 code-behind recomputes ScreenX/Y/Width/Height on every viewport change and
                 on every world-position change (drag/resize).  The parent Grid's
                 ClipToBounds="True" provides the natural viewport boundary. -->
            <ItemsControl x:Name="AnnotationLayer"
                          ItemsSource="{Binding Annotations}"
                          IsHitTestVisible="{Binding IsEditable}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:AnnotationViewModel}">
                        <local:AnnotationView DeleteRequested="Annotation_DeleteRequested"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding ScreenX}"/>
                        <Setter Property="Canvas.Top"  Value="{Binding ScreenY}"/>
                        <Setter Property="Width"       Value="{Binding ScreenWidth}"/>
                        <Setter Property="Height"      Value="{Binding ScreenHeight}"/>
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>
            </ItemsControl>

        </Grid>
    </Grid>
</UserControl>
