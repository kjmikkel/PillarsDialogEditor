<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.BranchNameDialog"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="400" MinWidth="400" SizeToContent="Height"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">
  <StackPanel Margin="20" Spacing="8">
    <TextBlock Text="{DynamicResource BranchName_Label}"
               Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}"/>
    <TextBox x:Name="NameBox"
             Background="{DynamicResource Brush.Surface.Input}" Foreground="{DynamicResource Brush.Text.Primary}"
             BorderBrush="{DynamicResource Brush.Border.Strong}" BorderThickness="1"
             FontSize="{StaticResource FontSize.Body}" Padding="6,4"
             AcceptsReturn="False"
             ToolTip.Tip="{DynamicResource BranchName_Label}"
             AutomationProperties.HelpText="{DynamicResource BranchName_Label}"
             AutomationProperties.Name="{DynamicResource BranchName_Label}"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
      <Button x:Name="CancelButton"
              Content="{DynamicResource BranchName_Cancel}"
              Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
              Padding="16,6" FontSize="{StaticResource FontSize.Body}"
              IsCancel="True"/>
      <Button x:Name="OkButton"
              Content="{DynamicResource BranchName_Ok}"
              Background="{DynamicResource Brush.Button.Primary.Background}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
              Padding="16,6" FontSize="{StaticResource FontSize.Body}"
              IsDefault="True"/>
    </StackPanel>
  </StackPanel>
</Window>
