<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
             x:Class="DialogEditor.Avalonia.Views.GameBrowserView" x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Filter box -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface.Panel}" Padding="4" BorderBrush="{DynamicResource Brush.Border.Default}" BorderThickness="0,0,0,1">
            <Grid>
                <TextBox x:Name="FilterBox"
                         Text="{Binding FilterText}"
                         Watermark="{DynamicResource Placeholder_FilterConversations}"
                         Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.Secondary}" CaretBrush="{DynamicResource Brush.Text.Secondary}"
                         BorderBrush="{DynamicResource Brush.Border.Muted}" BorderThickness="1"
                         Padding="6,3,24,3" FontSize="{DynamicResource FontSize.Body}" Height="26"
                         VerticalContentAlignment="Center"
                         KeyDown="FilterBox_KeyDown"
                         ToolTip.Tip="{DynamicResource ToolTip_FilterConversations}"
                         AutomationProperties.HelpText="{DynamicResource ToolTip_FilterConversations}"
                         AutomationProperties.Name="{DynamicResource Placeholder_FilterConversations}"/>
                <Button Command="{Binding ClearFilterCommand}"
                        HorizontalAlignment="Right" Width="24" Height="24"
                        Content="✕" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{DynamicResource FontSize.Small}" Cursor="Hand"
                        ToolTip.Tip="{DynamicResource ToolTip_ClearFilter}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_ClearFilter}"
                        AutomationProperties.Name="{DynamicResource AutomationName_ClearFilter}"/>
            </Grid>
        </Border>

        <!-- Conversation tree -->
        <TreeView Grid.Row="1" Background="{DynamicResource Brush.Surface.Subtle}"
                  BorderThickness="0"
                  ItemsSource="{Binding FilteredFolders}"
                  SelectedItem="{Binding SelectedTreeItem, Mode=TwoWay}"
                  SelectionChanged="TreeView_SelectionChanged">

            <TreeView.Styles>
                <!-- Selection highlight -->
                <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
                    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}"/>
                </Style>
                <Style Selector="TreeViewItem:selected:focus /template/ ContentPresenter#PART_HeaderPresenter">
                    <Setter Property="Background" Value="{DynamicResource Brush.Border.Focus}"/>
                </Style>
            </TreeView.Styles>

            <TreeView.DataTemplates>
                <TreeDataTemplate DataType="{x:Type vm:ConversationFolderViewModel}" ItemsSource="{Binding Items}">
                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Small}" Padding="2"/>
                </TreeDataTemplate>
                <DataTemplate DataType="{x:Type vm:ConversationItemViewModel}">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{Binding IsNew, Converter={StaticResource BoolToNewConversationBrush}}"
                               FontSize="{DynamicResource FontSize.Small}" Padding="2"
                               Cursor="Hand"
                               Tapped="ConversationItem_Tapped"/>
                </DataTemplate>
            </TreeView.DataTemplates>

            <TreeView.ItemContainerTheme>
                <ControlTheme TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </ControlTheme>
            </TreeView.ItemContainerTheme>

        </TreeView>

        <!-- Game name footer -->
        <Border Grid.Row="2" Background="{DynamicResource Brush.Surface.Card}" Padding="8,5">
            <TextBlock Text="{Binding GameName}" Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{DynamicResource FontSize.Caption}"/>
        </Border>
    </Grid>
</UserControl>
