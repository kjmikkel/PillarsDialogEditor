<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
        xmlns:diff="clr-namespace:DialogEditor.Patch.Diff;assembly=DialogEditor.Patch"
        xmlns:views="clr-namespace:DialogEditor.Avalonia.Views"
        xmlns:controls="clr-namespace:DialogEditor.Avalonia.Controls"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.DiffWindow"
        Title="{DynamicResource DiffWindow_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="820" Height="560"
        Background="{DynamicResource Brush.Surface.Panel}"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False">

    <DockPanel Margin="12">

        <!-- ── Endpoint selectors ─────────────────────────────────────── -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{DynamicResource DiffWindow_LeftLabel}"
                       Foreground="{DynamicResource Brush.Text.Muted.Light}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       ToolTip.Tip="{DynamicResource ToolTip_DiffLeftPicker}"/>
            <ComboBox Grid.Column="1"
                      x:Name="LeftPicker"
                      ItemsSource="{Binding EndpointOptions}"
                      SelectedItem="{Binding LeftEndpoint, Mode=TwoWay}"
                      ToolTip.Tip="{DynamicResource ToolTip_DiffLeftPicker}"
                      AutomationProperties.HelpText="{DynamicResource ToolTip_DiffLeftPicker}"
                      AutomationProperties.Name="{DynamicResource DiffWindow_LeftLabel}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EndpointOption}">
                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Brush.Text.Emphasis}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Column="3"
                       Text="{DynamicResource DiffWindow_RightLabel}"
                       Foreground="{DynamicResource Brush.Text.Muted.Light}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       ToolTip.Tip="{DynamicResource ToolTip_DiffRightPicker}"/>
            <ComboBox Grid.Column="4"
                      x:Name="RightPicker"
                      ItemsSource="{Binding EndpointOptions}"
                      SelectedItem="{Binding RightEndpoint, Mode=TwoWay}"
                      ToolTip.Tip="{DynamicResource ToolTip_DiffRightPicker}"
                      AutomationProperties.HelpText="{DynamicResource ToolTip_DiffRightPicker}"
                      AutomationProperties.Name="{DynamicResource DiffWindow_RightLabel}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EndpointOption}">
                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource Brush.Text.Emphasis}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Surface.Card}" Padding="8,4" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource Brush.Text.Muted}"
                       FontSize="{DynamicResource FontSize.Label}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ── Apply bar ──────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Surface.Inset}" Padding="8,6" Margin="0,6,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="{DynamicResource Diff_BringInButton}"
                        Command="{Binding ApplyCommand}"
                        ToolTip.Tip="{DynamicResource ToolTip_Diff_BringIn}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_BringIn}"/>
                <Button DockPanel.Dock="Right" Content="{DynamicResource Diff_UndoBringIn}"
                        Click="UndoBringIn_Click" Margin="0,0,8,0"
                        ToolTip.Tip="{DynamicResource ToolTip_Diff_UndoBringIn}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_UndoBringIn}"/>
                <StackPanel>
                    <CheckBox x:Name="AutoPullCheck"
                              Content="{DynamicResource Diff_AutoPullLabel}"
                              IsChecked="{Binding AutoPullDependencies, Mode=TwoWay}"
                              Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{DynamicResource FontSize.Label}"
                              ToolTip.Tip="{DynamicResource ToolTip_Diff_AutoPull}"
                              AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_AutoPull}"/>
                    <TextBlock Text="{DynamicResource Diff_Hint}" Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Label}" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Dangling-link panel (above apply bar; visible after an apply leaves dangling links) ── -->
        <Expander DockPanel.Dock="Bottom"
                  x:Name="DanglingPanel"
                  Margin="0,6,0,0"
                  IsExpanded="False"
                  IsVisible="{Binding DanglingLinks.Count, Converter={StaticResource CountToVis}}"
                  ToolTip.Tip="{DynamicResource ToolTip_Diff_DanglingPanel}"
                  AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_DanglingPanel}">
            <Expander.Header>
                <TextBlock Text="{Binding DanglingLinks.Count, StringFormat={StaticResource Diff_DanglingWarning}}"
                           Foreground="{DynamicResource Brush.Text.Status.Changed}" FontSize="{DynamicResource FontSize.Label}"/>
            </Expander.Header>
            <StackPanel Margin="8,4,0,4" Spacing="2">
                <TextBlock Text="{DynamicResource Diff_DanglingHeader}"
                           Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Label}" TextWrapping="Wrap"/>
                <ItemsControl x:Name="DanglingList" ItemsSource="{Binding DanglingLinkDescriptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{DynamicResource FontSize.Label}" Margin="0,1,0,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Expander>

        <!-- Focus hint bar (Gaps item 13) -->
        <shared:FocusHintBar DockPanel.Dock="Bottom" x:Name="HintBar"/>

        <!-- ── Main area: list + detail ───────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: changed conversations list -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="{DynamicResource DiffWindow_ChangedHeader}"
                           Foreground="{DynamicResource Brush.Text.Muted}"
                           FontSize="{DynamicResource FontSize.Small}"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource Brush.Border.Strong}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <ListBox x:Name="ChangedList"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                             Background="Transparent"
                             ToolTip.Tip="{DynamicResource ToolTip_DiffChangedList}"
                             AutomationProperties.HelpText="{DynamicResource ToolTip_DiffChangedList}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ConversationChangeViewModel}">
                                <StackPanel Orientation="Vertical" Margin="2,2">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsAllSelected, Mode=TwoWay}" IsThreeState="True"
                                                  ToolTip.Tip="{DynamicResource ToolTip_Diff_BringIn}"
                                                  AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_BringIn}"/>
                                        <ToggleButton Content="{Binding Name}" IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                      Background="Transparent" Foreground="{DynamicResource Brush.Text.Emphasis}" BorderThickness="0" Padding="4,0"
                                                      ToolTip.Tip="{DynamicResource ToolTip_Diff_ExpandConversation}"
                                                      AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_ExpandConversation}"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Nodes}" IsVisible="{Binding IsExpanded}" Margin="20,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:NodeChangeViewModel}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              ToolTip.Tip="{DynamicResource ToolTip_Diff_BringIn}"
                                                              AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_BringIn}"/>
                                                    <Border Width="9" Height="9" VerticalAlignment="Center"
                                                            Background="{Binding Kind, Converter={StaticResource DiffStatusToBrushConverter}}"/>
                                                    <TextBlock Text="{Binding NodeId, StringFormat={StaticResource Diff_NodeLine}}" Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{DynamicResource FontSize.Label}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- Right: canvas header + diff canvas -->
            <DockPanel Grid.Column="2">

                <!-- Canvas mode toggle + colour key -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                    <RadioButton GroupName="CanvasMode" Content="{DynamicResource Diff_ViewChanges}"
                                 IsChecked="{Binding CanvasMode, Converter={StaticResource EnumToBool}, ConverterParameter=Changes, Mode=TwoWay}"
                                 ToolTip.Tip="{DynamicResource ToolTip_Diff_ViewToggle}"
                                 AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_ViewToggle}"/>
                    <RadioButton GroupName="CanvasMode" Content="{DynamicResource Diff_ViewPreview}"
                                 IsChecked="{Binding CanvasMode, Converter={StaticResource EnumToBool}, ConverterParameter=AppliedPreview, Mode=TwoWay}"
                                 ToolTip.Tip="{DynamicResource ToolTip_Diff_ViewToggle}"
                                 AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_ViewToggle}"/>
                    <Border Width="10" Height="10" Background="{DynamicResource Brush.Text.Status.Added}" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Diff_LegendAdded}" Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{DynamicResource FontSize.Small}" VerticalAlignment="Center"/>
                    <Border Width="10" Height="10" Background="{DynamicResource Brush.Text.Status.Changed}" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Diff_LegendChanged}" Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{DynamicResource FontSize.Small}" VerticalAlignment="Center"/>
                    <Border Width="10" Height="10" Background="{DynamicResource Brush.Text.Status.Removed}" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Diff_LegendRemoved}" Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{DynamicResource FontSize.Small}" VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource Diff_HelpButton}" Click="Help_Click"
                            ToolTip.Tip="{DynamicResource ToolTip_Diff_Help}"
                            AutomationProperties.HelpText="{DynamicResource ToolTip_Diff_Help}"/>
                </StackPanel>

                <!-- ── Before/after detail panel (per changed language) ── -->
                <Border DockPanel.Dock="Bottom"
                        x:Name="DetailPanel"
                        Background="{DynamicResource Brush.Surface.Window}"
                        BorderBrush="{DynamicResource Brush.Border.Strong}" BorderThickness="1" CornerRadius="4"
                        Padding="8" Margin="0,6,0,0"
                        IsVisible="{Binding SelectedNodeDetail, Converter={StaticResource IsNotNull}}"
                        ToolTip.Tip="{DynamicResource ToolTip_Diff_Detail}">
                    <DockPanel DataContext="{Binding SelectedNodeDetail}">
                        <TextBlock DockPanel.Dock="Top" Text="{Binding HeaderText}"
                                   Foreground="{DynamicResource Brush.Text.Emphasis}" FontWeight="Bold" FontSize="{DynamicResource FontSize.Body}"/>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{DynamicResource Diff_Detail_StructuralOnly}"
                                   Foreground="{DynamicResource Brush.Text.Status.Changed}" FontSize="{DynamicResource FontSize.Label}" TextWrapping="Wrap"
                                   IsVisible="{Binding IsStructuralOnly}"/>
                        <ScrollViewer MaxHeight="180" IsVisible="{Binding ShowSections}">
                            <ItemsControl x:Name="SectionsList" ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="2" Margin="0,6,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding LanguageName}"
                                                           Foreground="{DynamicResource Brush.Text.Tertiary}" FontWeight="SemiBold" FontSize="{DynamicResource FontSize.Label}"/>
                                                <TextBlock Text="{DynamicResource Diff_Detail_PrimaryMarker}"
                                                           Foreground="{DynamicResource Brush.Text.Disabled}" FontSize="{DynamicResource FontSize.Small}"
                                                           IsVisible="{Binding IsPrimary}"/>
                                            </StackPanel>

                                            <TextBlock Text="{DynamicResource Diff_Detail_DefaultTextLabel}"
                                                       Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Small}"/>
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{DynamicResource Diff_Detail_BeforeLabel}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Label}" Margin="0,0,6,0"/>
                                                <controls:InlineDiffTextBlock Grid.Column="1"
                                                           Before="{Binding DefaultBefore}" After="{Binding DefaultAfter}"
                                                           ShowAfter="False" Foreground="{DynamicResource Brush.Text.Emphasis}" FontSize="{DynamicResource FontSize.Body}" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{DynamicResource Diff_Detail_AfterLabel}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Label}" Margin="0,0,6,0"/>
                                                <controls:InlineDiffTextBlock Grid.Column="1"
                                                           Before="{Binding DefaultBefore}" After="{Binding DefaultAfter}"
                                                           ShowAfter="True" Foreground="{DynamicResource Brush.Text.Emphasis}" FontSize="{DynamicResource FontSize.Body}" TextWrapping="Wrap"/>
                                            </Grid>

                                            <StackPanel Spacing="2" IsVisible="{Binding HasFemaleRow}">
                                                <TextBlock Text="{DynamicResource Diff_Detail_FemaleTextLabel}"
                                                           Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Small}"/>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Grid.Column="0" Text="{DynamicResource Diff_Detail_BeforeLabel}"
                                                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Label}" Margin="0,0,6,0"/>
                                                    <controls:InlineDiffTextBlock Grid.Column="1"
                                                               Before="{Binding FemaleBefore}" After="{Binding FemaleAfter}"
                                                               ShowAfter="False" Foreground="{DynamicResource Brush.Text.Emphasis}" FontSize="{DynamicResource FontSize.Body}" TextWrapping="Wrap"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Grid.Column="0" Text="{DynamicResource Diff_Detail_AfterLabel}"
                                                               Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{DynamicResource FontSize.Label}" Margin="0,0,6,0"/>
                                                    <controls:InlineDiffTextBlock Grid.Column="1"
                                                               Before="{Binding FemaleBefore}" After="{Binding FemaleAfter}"
                                                               ShowAfter="True" Foreground="{DynamicResource Brush.Text.Emphasis}" FontSize="{DynamicResource FontSize.Body}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Canvas panel -->
                <Panel>

                    <!-- Canvas — shown when DiffCanvas is not null -->
                    <views:ConversationView DataContext="{Binding DiffCanvas}"
                                            IsVisible="{Binding DiffCanvas, Converter={StaticResource IsNotNull}}"/>

                    <!-- Hint — shown when DiffCanvas is null -->
                    <Border Background="{DynamicResource Brush.Surface.Window}"
                            IsVisible="{Binding DiffCanvas, Converter={StaticResource IsNull}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Selected.Name}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="{DynamicResource FontSize.Subtitle}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"
                                       IsVisible="{Binding Selected, Converter={StaticResource IsNotNull}}"/>
                            <TextBlock Text="{Binding CanvasHint}"
                                       Foreground="{DynamicResource Brush.Text.Disabled}"
                                       FontSize="{DynamicResource FontSize.Label}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="260"
                                       IsVisible="{Binding CanvasHint, Converter={StaticResource NullOrEmptyToVis}}"/>
                            <TextBlock Text="{DynamicResource DiffWindow_SelectHint}"
                                       Foreground="{DynamicResource Brush.Text.Disabled}"
                                       FontSize="{DynamicResource FontSize.Label}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="260"
                                       IsVisible="{Binding Selected, Converter={StaticResource IsNull}}"/>
                        </StackPanel>
                    </Border>
                </Panel>
            </DockPanel>
        </Grid>

    </DockPanel>
</Window>
