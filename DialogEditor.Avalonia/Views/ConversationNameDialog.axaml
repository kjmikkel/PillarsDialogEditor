<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.ConversationNameDialog"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="460" MinWidth="460" SizeToContent="Height"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">

    <StackPanel Margin="20">

        <TextBlock Text="{StaticResource Dialog_NewConversation_Prompt}"
                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="{StaticResource FontSize.Body}"
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <TextBox x:Name="NameBox"
                 Watermark="{StaticResource Dialog_NewConversation_Placeholder}"
                 Background="{DynamicResource Brush.Surface.Input}" Foreground="{DynamicResource Brush.Text.Primary}"
                 BorderBrush="{DynamicResource Brush.Border.Strong}" BorderThickness="1"
                 FontSize="{StaticResource FontSize.Body}" Padding="6,4" Margin="0,0,0,16"
                 AcceptsReturn="False"
                 AutomationProperties.Name="{StaticResource AutomationName_ConversationName}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="{StaticResource FontSize.Body}"/>
            <Button x:Name="OkButton"
                    Content="{StaticResource Dialog_NewConversation_Create}"
                    Background="{DynamicResource Brush.Button.Primary.Background}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="{StaticResource FontSize.Body}"/>
        </StackPanel>

    </StackPanel>

</Window>
