<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.ConversationNameDialog"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="460" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#252525">

    <StackPanel Margin="20">

        <TextBlock Text="{StaticResource Dialog_NewConversation_Prompt}"
                   Foreground="#e8e8e8" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <TextBox x:Name="NameBox"
                 Watermark="{StaticResource Dialog_NewConversation_Placeholder}"
                 Background="#141414" Foreground="#e8e8e8"
                 BorderBrush="#444" BorderThickness="1"
                 FontSize="12" Padding="6,4" Margin="0,0,0,16"
                 AcceptsReturn="False"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Background="#333" Foreground="White" BorderThickness="0"
                    Padding="16,6" FontSize="12"/>
            <Button x:Name="OkButton"
                    Content="{StaticResource Dialog_NewConversation_Create}"
                    Background="#1a5276" Foreground="White" BorderThickness="0"
                    Padding="16,6" FontSize="12"/>
        </StackPanel>

    </StackPanel>

</Window>
