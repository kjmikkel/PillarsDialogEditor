<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.GitConflictResolutionWindow"
        Title="{StaticResource GitConflictWindow_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="780" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Surface.Panel}">

    <Grid Margin="16" RowDefinitions="Auto,*,Auto" ColumnDefinitions="260,*">

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="{StaticResource GitConflictWindow_Intro}"
                   Foreground="{DynamicResource Brush.Text.Primary}" FontSize="13"
                   TextWrapping="Wrap" Margin="0,0,0,14"/>

        <!-- Conflict list -->
        <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
            <TextBlock DockPanel.Dock="Top"
                       Text="{StaticResource GitConflictWindow_ListHeader}"
                       Foreground="{DynamicResource Brush.Text.Muted}" FontSize="11" Margin="0,0,0,4"/>
            <ListBox x:Name="ConflictList"
                     ItemsSource="{Binding Conflicts}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                     Background="{DynamicResource Brush.Surface.Card}" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock Text="{StaticResource GitConflictWindow_Unresolved}"
                                       Foreground="{DynamicResource Brush.Text.Meta.Commit}" FontSize="10"
                                       IsVisible="{Binding IsUnresolved}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Detail: side-by-side mine vs theirs for the selected conflict.
             Mine = the BLUE pair, Theirs = the RED pair (Brush.Conflict.Mine/Theirs.* now
             name those hues; see Tokens.axaml). -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" DataContext="{Binding Selected}">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                <Border Grid.Column="0" Background="{DynamicResource Brush.Conflict.Mine.Background}" CornerRadius="4"
                        Padding="12" Margin="0,0,6,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{StaticResource GitConflictWindow_MineHeader}"
                                   Foreground="{DynamicResource Brush.Conflict.Mine.Foreground}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{StaticResource GitConflict_DefaultTextLabel}"
                                   Foreground="{DynamicResource Brush.Text.Muted}" FontSize="10"
                                   IsVisible="{Binding HasFemaleRow}"/>
                        <TextBlock x:Name="MineDiffText"
                                   FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock Text="{StaticResource GitConflict_FemaleTextLabel}"
                                   Foreground="{DynamicResource Brush.Text.Muted}" FontSize="10"
                                   IsVisible="{Binding HasFemaleRow}"/>
                        <TextBlock x:Name="MineFemaleDiffText"
                                   FontSize="12" TextWrapping="Wrap"
                                   IsVisible="{Binding HasFemaleRow}"/>
                        <RadioButton x:Name="MineRadio" GroupName="Choice"
                                     Content="{Binding MineLabel}"
                                     IsChecked="{Binding IsMineChosen, Mode=TwoWay}"
                                     ToolTip.Tip="{StaticResource GitConflictWindow_MineTooltip}"
                                     AutomationProperties.HelpText="{StaticResource GitConflictWindow_MineTooltip}"
                                     Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource Brush.Conflict.Theirs.Background}" CornerRadius="4"
                        Padding="12" Margin="6,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{StaticResource GitConflictWindow_TheirsHeader}"
                                   Foreground="{DynamicResource Brush.Conflict.Theirs.Foreground}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{StaticResource GitConflict_DefaultTextLabel}"
                                   Foreground="{DynamicResource Brush.Text.Muted}" FontSize="10"
                                   IsVisible="{Binding HasFemaleRow}"/>
                        <TextBlock x:Name="TheirsDiffText"
                                   FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock Text="{StaticResource GitConflict_FemaleTextLabel}"
                                   Foreground="{DynamicResource Brush.Text.Muted}" FontSize="10"
                                   IsVisible="{Binding HasFemaleRow}"/>
                        <TextBlock x:Name="TheirsFemaleDiffText"
                                   FontSize="12" TextWrapping="Wrap"
                                   IsVisible="{Binding HasFemaleRow}"/>
                        <RadioButton x:Name="TheirsRadio" GroupName="Choice"
                                     Content="{Binding TheirsLabel}"
                                     IsChecked="{Binding IsTheirsChosen, Mode=TwoWay}"
                                     ToolTip.Tip="{StaticResource GitConflictWindow_TheirsTooltip}"
                                     AutomationProperties.HelpText="{StaticResource GitConflictWindow_TheirsTooltip}"
                                     Foreground="{DynamicResource Brush.Text.Primary}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,14,0,0">
            <Button x:Name="CancelButton"
                    Content="{StaticResource GitConflictWindow_Cancel}"
                    ToolTip.Tip="{StaticResource GitConflictWindow_CancelTooltip}"
                    AutomationProperties.HelpText="{StaticResource GitConflictWindow_CancelTooltip}"
                    Background="{DynamicResource Brush.Surface.Header}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="12"/>
            <Button x:Name="ApplyButton"
                    Content="{StaticResource GitConflictWindow_Apply}"
                    Command="{Binding ApplyCommand}"
                    ToolTip.Tip="{StaticResource GitConflictWindow_ApplyTooltip}"
                    AutomationProperties.HelpText="{StaticResource GitConflictWindow_ApplyTooltip}"
                    Background="{DynamicResource Brush.Button.Confirm.Background}" Foreground="{DynamicResource Brush.Text.OnAccent}" BorderThickness="0"
                    Padding="16,6" FontSize="12"/>
        </StackPanel>

    </Grid>

</Window>
