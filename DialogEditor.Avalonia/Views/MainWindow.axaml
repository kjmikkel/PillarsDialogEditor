<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DialogEditor.Avalonia.Views"
        x:Class="DialogEditor.Avalonia.Views.MainWindow"
        Title="{Binding WindowTitle}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="1400" Height="850"
        Background="#1e1e1e" x:CompileBindings="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Menu bar + slim toolbar -->
        <Border Grid.Row="0" Background="#252525" Padding="0">
            <DockPanel>

                <!-- Right-docked: ? and ⚙ -->
                <ToggleButton x:Name="HelpToggle"
                              DockPanel.Dock="Right"
                              Content="?"
                              IsChecked="False"
                              IsCheckedChanged="HelpToggle_IsCheckedChanged"
                              Theme="{StaticResource ToolbarPlainToggleButton}"
                              ToolTip.Tip="{StaticResource ToolTip_HelpToggle}"/>
                <Button DockPanel.Dock="Right"
                        x:Name="SettingsButton"
                        Content="⚙"
                        Click="SettingsButton_Click"
                        Theme="{StaticResource ToolbarPlainButton}"
                        ToolTip.Tip="{StaticResource ToolTip_Settings}"/>

                <!-- Menu bar -->
                <Menu DockPanel.Dock="Left"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Foreground="#ccc"
                      Margin="4,0,8,0">

                    <MenuItem Header="{StaticResource Menu_File}">
                        <MenuItem Header="{StaticResource Menu_NewProject}"
                                  Command="{Binding NewProjectCommand}"
                                  InputGesture="Ctrl+N"/>
                        <MenuItem Header="{StaticResource Menu_OpenProject}"
                                  Command="{Binding OpenProjectCommand}"
                                  InputGesture="Ctrl+O"/>
                        <MenuItem Header="{StaticResource Menu_SaveProject}"
                                  Command="{Binding SaveProjectCommand}"
                                  InputGesture="Ctrl+S"/>
                        <MenuItem Header="{StaticResource Menu_MergeProjects}"
                                  Command="{Binding MergeProjectsCommand}"
                                  ToolTip.Tip="{StaticResource ToolTip_MergeProjects}"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource Button_OpenFolder}"
                                  Command="{Binding OpenFolderCommand}"
                                  InputGesture="Ctrl+Shift+O"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource PatchManager_Title}"
                                  Click="PatchManager_Click"
                                  ToolTip.Tip="{StaticResource ToolTip_PatchManagerOpen}"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource Menu_ImportConversation}"
                                  Command="{Binding ImportConversationCommand}"
                                  ToolTip.Tip="{StaticResource ToolTip_ImportConversation}"/>
                        <MenuItem Header="{StaticResource Menu_ExportConversation}"
                                  Command="{Binding ExportConversationsCommand}"
                                  ToolTip.Tip="{StaticResource ToolTip_ExportConversation}"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource Menu_ExportForTranslation}"
                                  Command="{Binding ExportForTranslationCommand}"
                                  ToolTip.Tip="{StaticResource ToolTip_ExportForTranslation}"/>
                        <MenuItem Header="{StaticResource Menu_ImportTranslation}"
                                  Command="{Binding ImportTranslationCommand}"
                                  ToolTip.Tip="{StaticResource ToolTip_ImportTranslation}"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource Menu_Settings}"
                                  Click="SettingsButton_Click"
                                  InputGesture="Ctrl+,"/>
                    </MenuItem>

                    <MenuItem Header="{StaticResource Menu_Edit}">
                        <MenuItem Header="{StaticResource Button_Undo}"
                                  Command="{Binding Canvas.UndoCommand}"
                                  InputGesture="Ctrl+Z"/>
                        <MenuItem Header="{StaticResource Button_Redo}"
                                  Command="{Binding Canvas.RedoCommand}"
                                  InputGesture="Ctrl+Y"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource Menu_FindReplace}"
                                  Click="FindReplace_Click"
                                  InputGesture="Ctrl+H"
                                  ToolTip.Tip="{StaticResource ToolTip_FindReplace}"/>
                        <MenuItem Header="{StaticResource Menu_BatchReplace}"
                                  Click="BatchReplace_Click"
                                  InputGesture="Ctrl+Shift+H"
                                  ToolTip.Tip="{StaticResource ToolTip_BatchReplace}"/>
                        <MenuItem Header="{StaticResource Menu_FlowAnalytics}"
                                  Click="FlowAnalytics_Click"
                                  InputGesture="F7"
                                  ToolTip.Tip="{StaticResource ToolTip_FlowAnalytics}"/>
                        <MenuItem Header="{StaticResource Menu_CompareVersions}"
                                  Click="CompareVersions_Click"
                                  IsEnabled="{Binding IsProjectOpen}"
                                  ToolTip.Tip="{StaticResource ToolTip_CompareVersions}"/>
                        <MenuItem Header="{StaticResource Menu_History}"
                                  Click="History_Click"
                                  IsEnabled="{Binding IsProjectOpen}"
                                  ToolTip.Tip="{StaticResource ToolTip_History}"/>
                        <MenuItem Header="{StaticResource Menu_Attribution}"
                                  Click="Attribution_Click"
                                  IsEnabled="{Binding IsProjectOpen}"
                                  ToolTip.Tip="{StaticResource ToolTip_Attribution}"/>
                        <MenuItem Header="{StaticResource Menu_Branches}"
                                  Click="OnOpenBranches"
                                  IsEnabled="{Binding IsProjectOpen}"
                                  ToolTip.Tip="{StaticResource Menu_BranchesTip}"/>
                    </MenuItem>

                    <MenuItem Header="{StaticResource Menu_Test}">
                        <MenuItem Header="{StaticResource Button_TestPatch}"
                                  Command="{Binding TestPatchCommand}"
                                  InputGesture="F5"/>
                        <MenuItem Header="{StaticResource TestMode_Restore}"
                                  Command="{Binding RestoreConversationCommand}"
                                  InputGesture="F6"/>
                        <Separator/>
                        <MenuItem Header="{StaticResource Button_RestoreBackup}"
                                  Command="{Binding RestoreBackupCommand}"
                                  InputGesture="Ctrl+Shift+B"/>
                    </MenuItem>

                    <MenuItem Header="{StaticResource Menu_Help}">
                        <MenuItem Header="{StaticResource Menu_CreateSample}"
                                  ToolTip.Tip="{StaticResource Menu_CreateSampleTip}"
                                  Command="{Binding CreateSampleProjectCommand}"/>
                        <MenuItem Header="{StaticResource Menu_OpenWalkthrough}"
                                  ToolTip.Tip="{StaticResource Menu_OpenWalkthroughTip}"
                                  Command="{Binding OpenWalkthroughCommand}"/>
                    </MenuItem>

                </Menu>

                <!-- Language selector -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBlock Text="{StaticResource Label_Language}" Foreground="#888" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               IsVisible="{Binding AvailableLanguages.Count, Converter={StaticResource CountToVis}}"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                              MinWidth="60"
                              ToolTip.Tip="{StaticResource ToolTip_Language}"
                              IsVisible="{Binding AvailableLanguages.Count, Converter={StaticResource CountToVis}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Test mode overlay — covers the content area and blocks editing -->
        <views:TestModeOverlay x:Name="TestOverlay"
                               Grid.Row="1"
                               IsVisible="False"
                               ZIndex="100"/>

        <!-- Main content area -->
        <Grid Grid.Row="1" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="240" MinWidth="180"/>
            </Grid.ColumnDefinitions>

            <!-- Browser panel -->
            <Grid Grid.Column="0" x:Name="BrowserPanel">
                <!-- Expanded state — Border provides conditional drop shadow when open as flyout -->
                <Border IsVisible="{Binding IsBrowserExpanded}"
                        Classes.flyout="{Binding IsBrowserFlyoutOpen}">
                    <Border.Styles>
                        <Style Selector="Border.flyout">
                            <Setter Property="BoxShadow" Value="0 0 18 0 #A0000000"/>
                            <Setter Property="ZIndex" Value="5"/>
                        </Style>
                    </Border.Styles>
                    <Grid RowDefinitions="Auto,*">
                    <Border Background="#252525" Padding="6,4">
                        <DockPanel>
                            <ToggleButton DockPanel.Dock="Right"
                                          IsChecked="{Binding IsBrowserPinned, Mode=TwoWay}"
                                          Content="📌"
                                          Background="#333" Foreground="#aaa" BorderThickness="0" Padding="6,2"
                                          ToolTip.Tip="{StaticResource ToolTip_PinPanel}"/>
                          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{StaticResource Browser_Header}" Foreground="#888" FontSize="10" FontWeight="Bold"/>
                          </StackPanel>
                          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,6,0">
                                <Button Command="{Binding Browser.ExpandAllCommand}" Content="⊞"
                                        Background="Transparent" BorderThickness="0" Foreground="#555"
                                        FontSize="10" Cursor="Hand"
                                        ToolTip.Tip="{StaticResource ToolTip_ExpandAll}"/>
                                <Button Command="{Binding Browser.CollapseAllCommand}" Content="⊟" Margin="2,0,0,0"
                                        Background="Transparent" BorderThickness="0" Foreground="#555"
                                        FontSize="10" Cursor="Hand"
                                        ToolTip.Tip="{StaticResource ToolTip_CollapseAll}"/>
                                <Button Command="{Binding NewConversationCommand}" Content="⊕" Margin="4,0,0,0"
                                        Background="Transparent" BorderThickness="0" Foreground="#7dcea0"
                                        FontSize="12" Cursor="Hand"
                                        ToolTip.Tip="{StaticResource ToolTip_NewConversation}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <views:GameBrowserView Grid.Row="1" DataContext="{Binding Browser}"/>
                    </Grid>
                </Border>

                <!-- Collapsed strip -->
                <Grid IsVisible="{Binding IsBrowserExpanded, Converter={StaticResource InverseBoolToVis}}"
                      RowDefinitions="Auto,Auto,*">
                    <ToggleButton Grid.Row="0" Margin="4,4,4,0"
                                  IsChecked="{Binding IsBrowserPinned, Mode=TwoWay}"
                                  Content="📌"
                                  Background="#333" Foreground="#aaa" BorderThickness="0" Padding="6,2"
                                  ToolTip.Tip="{StaticResource ToolTip_PinPanel}"/>
                    <Button Grid.Row="1" Grid.RowSpan="2"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            Click="CollapsedBrowserTitle_Click"
                            ToolTip.Tip="{StaticResource ToolTip_TogglePanel}">
                        <LayoutTransformControl Margin="0,10,0,0">
                            <LayoutTransformControl.LayoutTransform>
                                <RotateTransform Angle="90"/>
                            </LayoutTransformControl.LayoutTransform>
                            <TextBlock Text="{StaticResource Browser_Header}"
                                       Foreground="#555" FontSize="10" FontWeight="Bold"/>
                        </LayoutTransformControl>
                    </Button>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="#333"/>
            <views:ConversationView x:Name="CanvasView" Grid.Column="2" DataContext="{Binding Canvas}"/>
            <GridSplitter Grid.Column="3" ResizeDirection="Columns" Background="#333"/>

            <!-- Detail panel -->
            <Grid Grid.Column="4" x:Name="DetailPanel">
                <!-- Expanded state -->
                <Grid IsVisible="{Binding IsDetailExpanded}" RowDefinitions="Auto,*">
                    <Border Background="#252525" Padding="6,4">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="−"
                                    Click="ToggleDetail_Click"
                                    Background="#333" Foreground="#aaa" BorderThickness="0" Padding="6,2"
                                    ToolTip.Tip="{StaticResource ToolTip_TogglePanel}"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{StaticResource Label_NodeDetails}" Foreground="#888" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CurrentConversationName}"
                                           Foreground="#555" FontSize="10" Margin="6,0,0,0"
                                           IsVisible="{Binding CurrentConversationName, Converter={StaticResource NullOrEmptyToVis}}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <views:NodeDetailView Grid.Row="1" DataContext="{Binding Detail}"
                                         IsEnabled="{Binding IsProjectOpen}"/>
                </Grid>

                <!-- Collapsed strip -->
                <Grid IsVisible="{Binding IsDetailExpanded, Converter={StaticResource InverseBoolToVis}}"
                      RowDefinitions="Auto,*">
                    <Button Grid.Row="0" Margin="4,4,4,0"
                            Content="+"
                            Click="ToggleDetail_Click"
                            Background="#333" Foreground="#aaa" BorderThickness="0" Padding="6,2"
                            ToolTip.Tip="{StaticResource ToolTip_TogglePanel}"/>
                    <LayoutTransformControl Grid.Row="1" Margin="0,10,0,0"
                                            HorizontalAlignment="Center" VerticalAlignment="Top">
                        <LayoutTransformControl.LayoutTransform>
                            <RotateTransform Angle="90"/>
                        </LayoutTransformControl.LayoutTransform>
                        <TextBlock Text="{StaticResource Label_NodeDetails}"
                                   Foreground="#555" FontSize="10" FontWeight="Bold"/>
                    </LayoutTransformControl>
                </Grid>
            </Grid>

            <!-- Legend is now LegendWindow (floating); toggled from MainWindow.axaml.cs -->
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#1a1a1a" Padding="8,4">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="{StaticResource MainWindow_ResolveConflictsButton}"
                        Command="{Binding ResolveConflictsCommand}"
                        IsVisible="{Binding HasPendingConflictResolution}"
                        ToolTip.Tip="{StaticResource MainWindow_ResolveConflictsTooltip}"
                        Background="#8e4912" Foreground="White" BorderThickness="0"
                        Padding="12,2" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
