<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DialogEditor.ViewModels;assembly=DialogEditor.ViewModels"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.ExportConversationsWindow"
        Title="{DynamicResource ExportConversations_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="480" MinWidth="480" SizeToContent="Height"
        Background="{DynamicResource Brush.Surface.Window}"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False">

    <DockPanel Margin="16">

        <!-- ── Conversation list ──────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button x:Name="SelectAllButton"
                        Content="{DynamicResource ExportConversations_SelectAll}"
                        Command="{Binding SelectAllCommand}"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource Brush.Text.Link}"
                        ToolTip.Tip="{DynamicResource ToolTip_ExportConversations_SelectAll}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_ExportConversations_SelectAll}"/>
                <TextBlock Text=" / " Foreground="{DynamicResource Brush.Text.Muted}" VerticalAlignment="Center"/>
                <Button x:Name="SelectNoneButton"
                        Content="{DynamicResource ExportConversations_SelectNone}"
                        Command="{Binding SelectNoneCommand}"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource Brush.Text.Link}"
                        ToolTip.Tip="{DynamicResource ToolTip_ExportConversations_SelectNone}"
                        AutomationProperties.HelpText="{DynamicResource ToolTip_ExportConversations_SelectNone}"/>
            </StackPanel>
            <Border Height="200" BorderBrush="{DynamicResource Brush.Border.Strong}" BorderThickness="1" CornerRadius="4">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ConversationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ConversationExportItem}">
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsChecked}"
                                          Foreground="{DynamicResource Brush.Text.Emphasis}"
                                          Padding="8,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- ── Footer ────────────────────────────────────────────────── -->
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusText}"
                       Foreground="{DynamicResource Brush.Text.Muted}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
            <Button Grid.Column="1"
                    x:Name="ExportButton"
                    Content="{DynamicResource ExportConversations_Export}"
                    Command="{Binding ExportCommand}"
                    ToolTip.Tip="{DynamicResource ToolTip_ExportConversations_Export}"
                    AutomationProperties.HelpText="{DynamicResource ToolTip_ExportConversations_Export}"
                    MinWidth="80"/>
            <Button Grid.Column="3"
                    x:Name="CloseButton"
                    Content="{DynamicResource ExportConversations_Close}"
                    Click="CloseButton_Click"
                    MinWidth="80"/>
        </Grid>

        <!-- Focus hint bar (Gaps item 13) -->
        <shared:FocusHintBar DockPanel.Dock="Bottom" x:Name="HintBar"/>

        <!-- ── Format selector ───────────────────────────────────────── -->
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource ExportConversations_Format}"
                       Foreground="{DynamicResource Brush.Text.Muted.Light}"
                       Margin="0,0,0,6"/>
            <RadioButton Content="{DynamicResource ExportConversations_FormatCsv}"
                         GroupName="Format"
                         IsChecked="{Binding SelectedFormat,
                             Converter={StaticResource StringEqualsBool},
                             ConverterParameter=csv, Mode=TwoWay}"
                         Checked="FormatRadio_Checked"
                         Tag="csv"
                         ToolTip.Tip="{DynamicResource ToolTip_ExportConversations_Csv}"
                         AutomationProperties.HelpText="{DynamicResource ToolTip_ExportConversations_Csv}"/>
            <RadioButton Content="{DynamicResource ExportConversations_FormatJson}"
                         GroupName="Format"
                         IsChecked="{Binding SelectedFormat,
                             Converter={StaticResource StringEqualsBool},
                             ConverterParameter=json, Mode=TwoWay}"
                         Checked="FormatRadio_Checked"
                         Tag="json"
                         ToolTip.Tip="{DynamicResource ToolTip_ExportConversations_Json}"
                         AutomationProperties.HelpText="{DynamicResource ToolTip_ExportConversations_Json}"/>
            <RadioButton Content="{DynamicResource ExportConversations_FormatYarnSpinner}"
                         GroupName="Format"
                         IsChecked="{Binding SelectedFormat,
                             Converter={StaticResource StringEqualsBool},
                             ConverterParameter=yarn, Mode=TwoWay}"
                         Checked="FormatRadio_Checked"
                         Tag="yarn"
                         ToolTip.Tip="{DynamicResource ToolTip_ExportConversations_Yarn}"
                         AutomationProperties.HelpText="{DynamicResource ToolTip_ExportConversations_Yarn}"/>
            <RadioButton x:Name="ArticyRadioButton"
                         Content="{DynamicResource ExportConversations_FormatArticy}"
                         GroupName="Format"
                         IsEnabled="False"
                         ToolTip.Tip="{DynamicResource ExportConversations_ArticyNote}"
                         AutomationProperties.HelpText="{DynamicResource ExportConversations_ArticyNote}"/>
        </StackPanel>

    </DockPanel>
</Window>
