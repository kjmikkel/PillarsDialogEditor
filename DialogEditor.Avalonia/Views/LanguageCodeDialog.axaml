<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DialogEditor.Avalonia.Views.LanguageCodeDialog"
        Title="{StaticResource Localization_LanguageCodeDialog_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="340" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        x:CompileBindings="False">

    <StackPanel Margin="16" Spacing="10">

        <TextBlock Text="{StaticResource Localization_LanguageCodeDialog_Prompt}"
                   Foreground="#e8e8e8" FontSize="12" TextWrapping="Wrap"/>

        <TextBox x:Name="LanguageCodeBox"
                 Background="#141414"
                 Foreground="#e8e8e8"
                 BorderBrush="#444"
                 BorderThickness="1"
                 FontSize="12"
                 Padding="6,4"
                 AcceptsReturn="False"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    IsCancel="True"
                    Background="#333" Foreground="#ccc" BorderThickness="0"
                    Padding="16,5"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    IsDefault="True"
                    Background="#1a5276" Foreground="White" BorderThickness="0"
                    Padding="16,5"
                    Click="OkButton_Click"/>
        </StackPanel>

    </StackPanel>

</Window>
