<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:DialogEditor.Avalonia.Shared;assembly=DialogEditor.Avalonia.Shared"
        x:Class="DialogEditor.Avalonia.Views.FindReplaceWindow"
        Title="{DynamicResource FindReplace_Title}"
        Icon="avares://DialogEditor.Avalonia/Assets/app.ico"
        Width="420" MinWidth="420" SizeToContent="Height"
        CanResize="True"
        ShowInTaskbar="False"
        Background="{DynamicResource Brush.Surface.Window}"
        WindowStartupLocation="CenterOwner"
        x:CompileBindings="False">

    <Window.Styles>
        <Style Selector="TextBox.find-box">
            <Setter Property="Background"       Value="{DynamicResource Brush.Surface.Input}"/>
            <Setter Property="Foreground"       Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource Brush.Border.Strong}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="{StaticResource FontSize.Body}"/>
            <Setter Property="Padding"          Value="6,3"/>
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Background"      Value="{DynamicResource Brush.Surface.Header}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSize.Label}"/>
            <Setter Property="MinWidth"        Value="80"/>
        </Style>
        <Style Selector="Button.primary-btn">
            <Setter Property="Background"      Value="{DynamicResource Brush.Button.Primary.Background}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontSize"        Value="{StaticResource FontSize.Label}"/>
            <Setter Property="MinWidth"        Value="80"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="14,10,14,10">

        <!-- Find row -->
        <Grid Grid.Row="0" ColumnDefinitions="70,*" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="{DynamicResource FindReplace_FindLabel}"
                       Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{StaticResource FontSize.Label}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Classes="find-box"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     x:Name="SearchBox"
                     ToolTip.Tip="{DynamicResource ToolTip_FindAll}"
                     AutomationProperties.HelpText="{DynamicResource ToolTip_FindAll}"
                     AutomationProperties.Name="{DynamicResource FindReplace_FindLabel}"/>
        </Grid>

        <!-- Replace row -->
        <Grid Grid.Row="1" ColumnDefinitions="70,*" Margin="0,0,0,8">
            <TextBlock Grid.Column="0" Text="{DynamicResource FindReplace_ReplaceLabel}"
                       Foreground="{DynamicResource Brush.Text.Muted.Light}" FontSize="{StaticResource FontSize.Label}" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" Classes="find-box"
                     Text="{Binding ReplaceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip.Tip="{DynamicResource ToolTip_ReplaceAll}"
                     AutomationProperties.HelpText="{DynamicResource ToolTip_ReplaceAll}"
                     AutomationProperties.Name="{DynamicResource FindReplace_ReplaceLabel}"/>
        </Grid>

        <!-- Options row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
            <CheckBox IsChecked="{Binding CaseSensitive, Mode=TwoWay}"
                      Content="{DynamicResource FindReplace_CaseSensitive}"
                      Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="{StaticResource FontSize.Label}"
                      ToolTip.Tip="{DynamicResource ToolTip_CaseSensitive}"
                      AutomationProperties.HelpText="{DynamicResource ToolTip_CaseSensitive}"/>
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource Brush.Text.Muted}" FontSize="{StaticResource FontSize.Small}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Buttons -->
        <WrapPanel Grid.Row="3" Orientation="Horizontal" ItemWidth="88">
            <Button Classes="action-btn" Margin="0,0,4,4"
                    Content="{DynamicResource FindReplace_FindAll}"
                    Command="{Binding FindCommand}"
                    ToolTip.Tip="{DynamicResource ToolTip_FindAll}"
                    AutomationProperties.HelpText="{DynamicResource ToolTip_FindAll}"/>
            <Button Classes="action-btn" Margin="0,0,4,4"
                    Content="{DynamicResource FindReplace_FindPrev}"
                    Command="{Binding FindPrevCommand}"
                    ToolTip.Tip="{DynamicResource ToolTip_FindPrev}"
                    AutomationProperties.HelpText="{DynamicResource ToolTip_FindPrev}"/>
            <Button Classes="action-btn" Margin="0,0,4,4"
                    Content="{DynamicResource FindReplace_FindNext}"
                    Command="{Binding FindNextCommand}"
                    ToolTip.Tip="{DynamicResource ToolTip_FindNext}"
                    AutomationProperties.HelpText="{DynamicResource ToolTip_FindNext}"/>
            <Button Classes="action-btn" Margin="0,0,4,4"
                    Content="{DynamicResource FindReplace_ReplaceOne}"
                    Command="{Binding ReplaceCommand}"
                    ToolTip.Tip="{DynamicResource ToolTip_Replace}"
                    AutomationProperties.HelpText="{DynamicResource ToolTip_Replace}"/>
            <Button Classes="primary-btn" Margin="0,0,4,4"
                    Content="{DynamicResource FindReplace_ReplaceAll}"
                    Command="{Binding ReplaceAllCommand}"
                    ToolTip.Tip="{DynamicResource ToolTip_ReplaceAll}"
                    AutomationProperties.HelpText="{DynamicResource ToolTip_ReplaceAll}"/>
        </WrapPanel>

        <!-- Focus hint bar (Gaps item 13) -->
        <shared:FocusHintBar Grid.Row="4" x:Name="HintBar"/>

    </Grid>
</Window>
