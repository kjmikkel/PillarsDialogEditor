    <!-- ─── Test mode overlay ─────────────────────────────────────────────── -->
    <sys:String x:Key="TestMode_Message">Game files have been patched for testing. Launch the game and test your changes, then press Restore when you are done.</sys:String>
    <sys:String x:Key="TestMode_Restore">Restore Conversation</sys:String>
    <sys:String x:Key="ToolTip_TestMode_Restore">Revert the game files to their pre-test state and resume editing</sys:String>

    <!-- ─── Patch — status messages ──────────────────────────────────────── -->
    <!-- {0} = conversation name -->
    <sys:String x:Key="Status_PatchSaved">Patch saved: {0}</sys:String>
    <!-- Shown in the status bar when a conversation is loaded but no project is open -->
    <sys:String x:Key="Status_NoProjectReadOnly">Viewing only — open or create a project (File › New Project) to start editing.</sys:String>
    <!-- Shown when trying to save/test but no patch directory is configured -->
    <sys:String x:Key="Status_NoPatchDirectory">Set a patch output directory in Settings before saving.</sys:String>
    <!-- {0} = conversation name -->
    <sys:String x:Key="Status_PatchNotFound">No patch file found for {0} — save first.</sys:String>
    <!-- {0} = node ID, {1} = field name, {2} = expected value, {3} = actual value -->
    <sys:String x:Key="Status_PatchConflict">Patch conflict on node {0} field '{1}': expected '{2}' but found '{3}'.</sys:String>
    <!-- {0} = node ID, {1} = field name -->
    <sys:String x:Key="Status_PatchConflictCancelled">Test cancelled — conflict on node {0} field '{1}'.</sys:String>
    <!-- {0} = conversation name, {1} = error message -->
    <sys:String x:Key="Status_TestApplyError">Test apply failed for {0}: {1}</sys:String>

    <!-- ─── Conflict resolution dialog ──────────────────────────────────── -->
    <sys:String x:Key="ConflictDialog_Title">Patch Conflict</sys:String>
    <sys:String x:Key="ConflictDialog_Intro">This patch cannot be applied cleanly because a game file has changed since the patch was created.</sys:String>
    <sys:String x:Key="ConflictDialog_NodeLabel">Node ID:</sys:String>
    <sys:String x:Key="ConflictDialog_FieldLabel">Field:</sys:String>
    <sys:String x:Key="ConflictDialog_ExpectedLabel">Patch expects:</sys:String>
    <sys:String x:Key="ConflictDialog_ActualLabel">File currently has:</sys:String>
    <sys:String x:Key="ConflictDialog_Force">Force Apply</sys:String>
    <sys:String x:Key="ConflictDialog_Cancel">Cancel Test</sys:String>
    <sys:String x:Key="ConflictDialog_ForceTooltip">Apply the patch anyway, ignoring the mismatch. The patch's target value will overwrite whatever is currently in the file.</sys:String>
    <sys:String x:Key="ConflictDialog_CancelTooltip">Cancel the test and leave game files unchanged.</sys:String>
    <!-- Shown after successful Restore Conversation -->
    <sys:String x:Key="Status_RestoreComplete2">Conversation restored — ready to edit.</sys:String>

    <!-- ─── Project — status messages ────────────────────────────────────── -->
    <!-- {0} = project name -->
    <sys:String x:Key="Status_ProjectNew">New project: {0}</sys:String>
    <!-- {0} = project name, {1} = patch count -->
    <sys:String x:Key="Status_ProjectOpened">Opened project '{0}' ({1} patch(es))</sys:String>
    <!-- {0} = project name -->
    <sys:String x:Key="Status_ProjectSaved">Project saved: {0}</sys:String>
    <!-- Shown when Ctrl+S is pressed with no project open -->
    <sys:String x:Key="Status_NoProjectOpen">No project is open — use File &gt; New Project or Open Project.</sys:String>
    <!-- Shown when Test Patch is pressed but project has no patches -->
    <sys:String x:Key="Status_ProjectNoPatch">The project has no patches yet — save a conversation first.</sys:String>
    <!-- {0} = path, {1} = error message -->
    <sys:String x:Key="Status_ProjectOpenError">Could not open project '{0}': {1}</sys:String>
    <!-- Git conflict resolution. {0} = path, {1} = conflict count -->
    <sys:String x:Key="Status_ProjectGitConflictDetected">'{0}' has {1} unresolved git merge conflict(s). Resolve them to open the project.</sys:String>
    <!-- {0} = path -->
    <sys:String x:Key="Status_ProjectGitConflictUnparseable">'{0}' has git merge conflicts too complex to resolve here — resolve them in your git tool, then reopen.</sys:String>
    <!-- {0} = project name -->
    <sys:String x:Key="Status_ProjectGitConflictResolved">Resolved git conflicts in '{0}'. Review and save to write the merged project to disk.</sys:String>
    <sys:String x:Key="Status_ProjectGitConflictCancelled">Conflict resolution cancelled — project not opened.</sys:String>
    <!-- Startup deferral: {0} = path, {1} = conflict count -->
    <sys:String x:Key="Status_ProjectGitConflictPending">'{0}' has {1} unresolved git merge conflict(s). Click Resolve to fix them.</sys:String>
    <sys:String x:Key="MainWindow_ResolveConflictsButton">Resolve…</sys:String>
    <sys:String x:Key="MainWindow_ResolveConflictsTooltip">Open the conflict resolution dialog for the project that was reopened with unresolved git merge conflicts.</sys:String>
    <!-- Git conflict resolution row titles. {0} = conversation, {1} = node id, {2} = field / kind -->
    <sys:String x:Key="GitConflict_RowTitleField">{0} · node {1} · {2}</sys:String>
    <sys:String x:Key="GitConflict_RowTitleNode">{0} · node {1} · {2}</sys:String>
    <!-- {0} = conversation, {1} = node id, {2} = language code -->
    <sys:String x:Key="GitConflict_RowTitleTranslation">{0} · node {1} · text ({2})</sys:String>
    <!-- Per-variant captions in the conflict detail body -->
    <sys:String x:Key="GitConflict_DefaultTextLabel">Default text</sys:String>
    <sys:String x:Key="GitConflict_FemaleTextLabel">Female text</sys:String>
    <!-- Whole-conversation conflict. {0} = conversation -->
    <sys:String x:Key="GitConflict_RowTitleConversation">{0} · whole conversation</sys:String>
    <sys:String x:Key="GitConflict_KindDeleteVsEdit">deletion vs edit</sys:String>
    <sys:String x:Key="GitConflict_KindAddAdd">added on both sides</sys:String>
    <sys:String x:Key="GitConflict_KindConversation">conversation-level change</sys:String>
    <!-- Per-side choice labels -->
    <sys:String x:Key="GitConflict_KeepMine">Keep mine</sys:String>
    <sys:String x:Key="GitConflict_KeepTheirs">Keep theirs</sys:String>
    <sys:String x:Key="GitConflict_AcceptDeletion">Accept deletion</sys:String>
    <sys:String x:Key="GitConflict_KeepEdit">Keep the edit</sys:String>
    <!-- Git conflict resolution window chrome -->
    <sys:String x:Key="GitConflictWindow_Title">Resolve Git Conflicts</sys:String>
    <sys:String x:Key="GitConflictWindow_Intro">This project has unresolved git merge conflicts. Choose which side to keep for each one, then Apply. The merged project opens unsaved — review it and save to write the resolution to disk.</sys:String>
    <sys:String x:Key="GitConflictWindow_ListHeader">Conflicts</sys:String>
    <sys:String x:Key="GitConflictWindow_MineHeader">Mine (current branch)</sys:String>
    <sys:String x:Key="GitConflictWindow_TheirsHeader">Theirs (incoming)</sys:String>
    <sys:String x:Key="GitConflictWindow_MineTooltip">Keep your side's value for this conflict (the version on your current branch).</sys:String>
    <sys:String x:Key="GitConflictWindow_TheirsTooltip">Keep the incoming side's value for this conflict (the version being merged in).</sys:String>
    <sys:String x:Key="GitConflictWindow_Apply">Apply</sys:String>
    <sys:String x:Key="GitConflictWindow_ApplyTooltip">Build the merged project from your choices and open it unsaved. Enabled once every conflict has a choice.</sys:String>
    <sys:String x:Key="GitConflictWindow_Cancel">Cancel</sys:String>
    <sys:String x:Key="GitConflictWindow_CancelTooltip">Close without resolving — the project is not opened and the file on disk is left unchanged.</sys:String>
    <sys:String x:Key="GitConflictWindow_Unresolved">unresolved</sys:String>

    <!-- History browser -->
    <sys:String x:Key="HistoryWindow_Title">Project History</sys:String>
    <sys:String x:Key="HistoryWindow_ColDate">Date</sys:String>
    <sys:String x:Key="HistoryWindow_ColAuthor">Author</sys:String>
    <sys:String x:Key="HistoryWindow_ColCommit">Commit</sys:String>
    <sys:String x:Key="HistoryWindow_ColMessage">Message</sys:String>
    <sys:String x:Key="HistoryWindow_CompareButton">Compare with my copy</sys:String>
    <sys:String x:Key="HistoryWindow_CompareTooltip">Open the selected commit in the compare window, alongside your current working copy. From there you can view what changed and bring individual changes back into your copy.</sys:String>
    <sys:String x:Key="HistoryWindow_Close">Close</sys:String>
    <sys:String x:Key="History_StatusNoHistory">No git history found for this project file yet.</sys:String>
    <sys:String x:Key="History_StatusNotARepo">This project is not inside a git repository, so there is no history to show.</sys:String>
    <sys:String x:Key="History_StatusError">Could not read this project's git history. See the log for details.</sys:String>
    <sys:String x:Key="Menu_History">History…</sys:String>
    <sys:String x:Key="ToolTip_History">Browse the git commit history of the open project file. Select a commit to compare it with your current copy.</sys:String>

    <!-- Attribution / blame -->
    <sys:String x:Key="BlameWindow_Title">Node Attribution</sys:String>
    <sys:String x:Key="BlameWindow_ColConversation">Conversation</sys:String>
    <sys:String x:Key="BlameWindow_ColNode">Node</sys:String>
    <sys:String x:Key="BlameWindow_ColAuthor">Author</sys:String>
    <sys:String x:Key="BlameWindow_ColDate">Date</sys:String>
    <sys:String x:Key="BlameWindow_ColCommit">Commit</sys:String>
    <sys:String x:Key="BlameWindow_ColMessage">Message</sys:String>
    <sys:String x:Key="BlameWindow_Close">Close</sys:String>
    <sys:String x:Key="Blame_StatusNoData">No committed attribution found for this project file yet. Newly added nodes appear here once committed to git.</sys:String>
    <sys:String x:Key="Blame_StatusNotARepo">This project is not inside a git repository, so there is no attribution to show.</sys:String>
    <sys:String x:Key="Blame_StatusError">Could not read this project's git attribution. See the log for details.</sys:String>
    <sys:String x:Key="Menu_Attribution">Attribution…</sys:String>
    <sys:String x:Key="ToolTip_Attribution">Show who last edited each dialogue node, based on the git history of the open project file. Read-only; reflects the last committed change.</sys:String>
    <sys:String x:Key="NodeDetail_LastEditedLabel">Last edited</sys:String>
    <sys:String x:Key="NodeDetail_LastEditedTooltip">Last committed change to this node: "{0}" (commit {1}).</sys:String>

    <!-- ─── Project — file picker dialogs ────────────────────────────────── -->
    <sys:String x:Key="Dialog_NewProject">Create new project</sys:String>
    <sys:String x:Key="Dialog_NewProjectDefault">MyMod</sys:String>
    <sys:String x:Key="Dialog_OpenProject">Open project</sys:String>
    <sys:String x:Key="FileType_DialogProject">Dialog Project (*.dialogproject)</sys:String>
    <sys:String x:Key="Menu_MergeProjects">Merge Projects…</sys:String>
    <sys:String x:Key="ToolTip_MergeProjects">Merge one or more other .dialogproject files into the current project. Later projects win on conflict.</sys:String>
    <sys:String x:Key="Dialog_MergeProjects">Select projects to merge into the current project</sys:String>
    <sys:String x:Key="Status_MergeComplete">Merged {0} project(s) into '{1}'</sys:String>
    <sys:String x:Key="Status_MergeError">Merge failed: {0}</sys:String>

    <!-- ─── Import Conversation (from external formats) ─────────────────── -->
    <sys:String x:Key="Menu_ImportConversation">Import Conversation…</sys:String>
    <sys:String x:Key="ToolTip_ImportConversation">Import a conversation from an external file (CSV, JSON, Articy Draft XML, or Yarn Spinner) and add it to the current project.</sys:String>
    <sys:String x:Key="Dialog_ImportConversation">Import Conversation</sys:String>
    <sys:String x:Key="FileType_CsvDialog">CSV Dialog</sys:String>
    <sys:String x:Key="FileType_JsonDialog">JSON Dialog</sys:String>
    <sys:String x:Key="FileType_ArticyXml">Articy Draft XML</sys:String>
    <sys:String x:Key="FileType_YarnSpinner">Yarn Spinner</sys:String>
    <!-- {0} = file name -->
    <sys:String x:Key="Status_ImportConversationUnknownFormat">Could not import '{0}': unrecognised file format.</sys:String>
    <!-- {0} = file name, {1} = error message -->
    <sys:String x:Key="Status_ImportConversationError">Failed to import '{0}': {1}</sys:String>
    <!-- {0} = conversation name, {1} = node count -->
    <sys:String x:Key="Status_ImportConversationAdded">Imported '{0}' ({1} nodes).</sys:String>
    <!-- {0} = conversation name, {1} = node count, {2} = comma-joined <<keyword>> list -->
    <sys:String x:Key="Status_ImportConversationAddedWithWarnings">Imported '{0}' ({1} nodes). Skipped Yarn constructs: {2}.</sys:String>

    <!-- ─── Import Warnings dialog ──────────────────────────────────────── -->
    <sys:String x:Key="ImportWarnings_Title">Import Warnings</sys:String>
    <sys:String x:Key="ImportWarnings_Body">Some constructs in this file could not be imported and were skipped. The conversation structure was imported, but the following were dropped:</sys:String>
    <sys:String x:Key="ImportWarnings_Footer">Open the original file to handle these manually if needed.</sys:String>
    <sys:String x:Key="ImportWarnings_OccurrenceSuffix">occurrence(s)</sys:String>
    <sys:String x:Key="ImportWarnings_Ok">OK</sys:String>

    <!-- ─── Export Conversation (to external formats) ──────────────────── -->
    <sys:String x:Key="Menu_ExportConversation">Export Conversation…</sys:String>
    <sys:String x:Key="ToolTip_ExportConversation">Export selected conversations to CSV, JSON, or Yarn Spinner. This exports conversation structure (nodes, links, speaker categories), not translated text.</sys:String>
    <sys:String x:Key="ExportConversations_Title">Export Conversations</sys:String>
    <sys:String x:Key="ExportConversations_SelectAll">Select All</sys:String>
    <sys:String x:Key="ExportConversations_SelectNone">Select None</sys:String>
    <sys:String x:Key="ExportConversations_Format">Format</sys:String>
    <sys:String x:Key="ExportConversations_ArticyNote">Articy Draft XML export is not supported. Articy's format requires proprietary internal IDs and template definitions that the editor does not store.</sys:String>
    <sys:String x:Key="ExportConversations_Export">Export…</sys:String>
    <sys:String x:Key="ExportConversations_Close">Close</sys:String>
    <sys:String x:Key="ToolTip_ExportConversations_SelectAll">Check all conversations in the list.</sys:String>
    <sys:String x:Key="ToolTip_ExportConversations_SelectNone">Uncheck all conversations in the list.</sys:String>
    <sys:String x:Key="ToolTip_ExportConversations_Export">Export the checked conversations to the selected format.</sys:String>
    <sys:String x:Key="ToolTip_ExportConversations_Csv">Export to comma-separated values. Round-trips cleanly through Import Conversation.</sys:String>
    <sys:String x:Key="ToolTip_ExportConversations_Json">Export to JSON. Round-trips cleanly through Import Conversation.</sys:String>
    <sys:String x:Key="ToolTip_ExportConversations_Yarn">Export to Yarn Spinner .yarn format. Conditions, scripts, and female text are omitted.</sys:String>
    <!-- {0} = count, {1} = path or folder -->
    <sys:String x:Key="Status_ExportConversationsSaved">Exported {0} conversation(s) to {1}.</sys:String>
    <!-- {0} = error message -->
    <sys:String x:Key="Status_ExportConversationsError">Export failed: {0}</sys:String>

    <!-- ─── Localization — export / import translation ─────────────────── -->
    <sys:String x:Key="Menu_ExportForTranslation">Export for Translation…</sys:String>
    <sys:String x:Key="Menu_ImportTranslation">Import Translation…</sys:String>
    <sys:String x:Key="ToolTip_ExportForTranslation">Export dialogue text to CSV, JSON, or XLIFF for human translators.</sys:String>
    <sys:String x:Key="ToolTip_ImportTranslation">Import translated text back into the project from CSV, JSON, or XLIFF.</sys:String>
    <sys:String x:Key="Localization_LanguageCodeDialog_Title">Language Code</sys:String>
    <sys:String x:Key="Localization_LanguageCodeDialog_Prompt">Language code (e.g. en, fr, de, ja):</sys:String>
    <!-- {0} = entry count, {1} = file path -->
    <sys:String x:Key="Localization_StatusExported">Exported {0} entries to {1}</sys:String>
    <!-- {0} = entry count, {1} = language code -->
    <sys:String x:Key="Localization_StatusImported">{0} translations imported for {1}</sys:String>
    <sys:String x:Key="Localization_StatusImportNoEntries">No translated entries found in file</sys:String>

    <!-- ─── Settings — localization format ────────────────────────────── -->
    <sys:String x:Key="Settings_LocalizationFormat">Default localization format</sys:String>

    <!-- PatchManager strings are in DialogEditor.Avalonia.Shared/Resources/SharedStrings.axaml -->

    <!-- ─── Branches window ────────────────────────────────────────────── -->
    <sys:String x:Key="Branches_WindowTitle">Branches</sys:String>
    <sys:String x:Key="Branches_CurrentTag">(current)</sys:String>
    <sys:String x:Key="Branches_Switch">Switch</sys:String>
    <sys:String x:Key="Branches_SwitchTip">Check out the selected branch. Unsaved edits are guarded first; if your saved work blocks the switch, you'll be offered to commit it.</sys:String>
    <sys:String x:Key="Branches_New">New…</sys:String>
    <sys:String x:Key="Branches_NewTip">Create a new branch from the current state and switch to it.</sys:String>
    <sys:String x:Key="Branches_Rename">Rename…</sys:String>
    <sys:String x:Key="Branches_RenameTip">Rename the selected branch.</sys:String>
    <sys:String x:Key="Branches_Delete">Delete</sys:String>
    <sys:String x:Key="Branches_DeleteTip">Delete the selected branch. Refuses an unmerged branch unless you confirm a force-delete. The current branch cannot be deleted.</sys:String>
    <sys:String x:Key="Branches_Close">Close</sys:String>

    <!-- {0} = branch name -->
    <sys:String x:Key="Branches_StatusSwitched">Switched to {0}.</sys:String>
    <sys:String x:Key="Branches_StatusCreated">Created and switched to {0}.</sys:String>
    <sys:String x:Key="Branches_StatusRenamed">Renamed to {0}.</sys:String>
    <sys:String x:Key="Branches_StatusDeleted">Deleted {0}.</sys:String>
    <sys:String x:Key="Branches_StatusNone">No branches yet.</sys:String>
    <sys:String x:Key="Branches_StatusNotARepo">This project isn't inside a Git repository.</sys:String>
    <sys:String x:Key="Branches_StatusGitMissing">Git isn't installed. Install Git to manage branches.</sys:String>
    <sys:String x:Key="Branches_StatusError">Couldn't read the project's branches.</sys:String>
    <sys:String x:Key="Branches_StatusSwitchFailed">Couldn't switch branches.</sys:String>
    <sys:String x:Key="Branches_StatusCommitFailed">Couldn't commit your changes, so the switch was cancelled.</sys:String>
    <sys:String x:Key="Branches_StatusBlockedUntracked">Some new files in the project folder would be overwritten by switching to this branch. A developer may need to move or remove them first.</sys:String>
    <sys:String x:Key="Branches_StatusNameInvalid">That isn't a valid branch name.</sys:String>
    <sys:String x:Key="Branches_StatusNameExists">A branch with that name already exists.</sys:String>
    <sys:String x:Key="Branches_DefaultCommitMessage">Save dialog edits before switching branches</sys:String>

    <!-- Commit-consent dialog -->
    <sys:String x:Key="CommitConsent_Title">Commit changes before switching</sys:String>
    <sys:String x:Key="CommitConsent_Intro">These files will be committed before switching:</sys:String>
    <sys:String x:Key="CommitConsent_MessageLabel">Message</sys:String>
    <sys:String x:Key="CommitConsent_Commit">Commit &amp; Switch</sys:String>
    <sys:String x:Key="CommitConsent_Cancel">Cancel</sys:String>

    <!-- Branch-name dialog -->
    <sys:String x:Key="BranchName_NewTitle">New branch</sys:String>
    <sys:String x:Key="BranchName_RenameTitle">Rename branch</sys:String>
    <sys:String x:Key="BranchName_Label">Branch name</sys:String>
    <sys:String x:Key="BranchName_Ok">OK</sys:String>
    <sys:String x:Key="BranchName_Cancel">Cancel</sys:String>

    <!-- Force-delete dialog. {0} = branch name -->
    <sys:String x:Key="ForceDelete_Title">Delete unmerged branch?</sys:String>
    <sys:String x:Key="ForceDelete_Message">Branch "{0}" has commits that aren't merged anywhere else. Deleting it will lose those commits permanently. Delete anyway?</sys:String>
    <sys:String x:Key="ForceDelete_Confirm">Delete permanently</sys:String>
    <sys:String x:Key="ForceDelete_Cancel">Cancel</sys:String>

    <!-- Branches menu entry -->
    <sys:String x:Key="Menu_Branches">Branches…</sys:String>
    <sys:String x:Key="Menu_BranchesTip">View and manage the local Git branches of the open project.</sys:String>

    <!-- Project no longer on the switched-to branch. {0} = path -->
    <sys:String x:Key="Status_ProjectNotOnBranch">The project file doesn't exist on this branch: {0}</sys:String>

    <!-- Distinct git-not-installed status for the read-only git tools -->
    <sys:String x:Key="History_StatusGitMissing">Git isn't installed. Install Git to browse history.</sys:String>
    <sys:String x:Key="Blame_StatusGitMissing">Git isn't installed. Install Git to see attribution.</sys:String>
    <sys:String x:Key="Status_DiffGitMissing">Git isn't installed. Install Git to compare versions.</sys:String>

</ResourceDictionary>
