    <!-- ─── Node detail panel — field tooltips ──────────────────────────── -->
    <sys:String x:Key="ToolTip_DefaultText">Edit the default (male) dialogue text for this node</sys:String>
    <sys:String x:Key="ToolTip_FemaleText">Optional female-voice variant. Leave blank to use the default text for both genders.</sys:String>
    <sys:String x:Key="ToolTip_NodeType">Whether this node is an NPC line or a player response choice</sys:String>
    <sys:String x:Key="ToolTip_SpeakerGuid">GUID of the speaking character — edit directly or use the name picker above</sys:String>
    <sys:String x:Key="ToolTip_ListenerGuid">GUID of the listening character — edit directly or use the name picker above</sys:String>
    <sys:String x:Key="ToolTip_DisplayType">How this node is presented to the player (Conversation = full portrait, Bark = floating text)</sys:String>
    <sys:String x:Key="ToolTip_BarkWarnings">Bark-specific validation warnings. These do not block saving — they help writers avoid common mistakes.</sys:String>
    <sys:String x:Key="ToolTip_Persistence">OnceEver hides this node after it has been shown once, even across saves</sys:String>
    <sys:String x:Key="ToolTip_ActorDirection">Optional director's note for the voice actor — not shown to players</sys:String>
    <sys:String x:Key="ToolTip_ExternalVO">External voice-over file path or identifier</sys:String>
    <sys:String x:Key="ToolTip_HasVO">Check if a voice-over recording exists for this line</sys:String>
    <sys:String x:Key="ToolTip_HideSpeaker">Hide the speaker name label during dialogue playback</sys:String>
    <sys:String x:Key="ToolTip_Comments">Internal developer notes — not shown to players</sys:String>
    <sys:String x:Key="NodeDetail_TranslatorNote">TRANSLATOR NOTE</sys:String>
    <sys:String x:Key="ToolTip_NodeDetail_TranslatorNote">Context for translators: tone, character mood, length constraints, etc. Exported with translation files but never written to game data.</sys:String>
    <sys:String x:Key="ToolTip_AddLinkTargetId">Type a node ID and click Add to create a link from this node to that one</sys:String>

