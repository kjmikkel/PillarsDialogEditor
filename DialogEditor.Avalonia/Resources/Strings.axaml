    <!-- ─── Diff / Compare Versions window ──────────────────────────────── -->
    <sys:String x:Key="DiffWindow_Title">Compare Versions</sys:String>
    <sys:String x:Key="DiffWindow_LeftLabel">Your copy:</sys:String>
    <sys:String x:Key="DiffWindow_RightLabel">Other version:</sys:String>
    <sys:String x:Key="DiffWindow_ChangedHeader">Changed conversations</sys:String>
    <sys:String x:Key="DiffWindow_NoGameFolder">Open a game folder to see the conversation graph.</sys:String>
    <sys:String x:Key="DiffWindow_SelectHint">Select a conversation from the list to inspect it.</sys:String>
    <sys:String x:Key="Menu_CompareVersions">Compare Versions…</sys:String>
    <sys:String x:Key="ToolTip_CompareVersions">Compare two versions of your dialogue (such as a branch or an earlier save) and see what changed in each conversation.</sys:String>
    <sys:String x:Key="Diff_WorkingCopy">Your copy</sys:String>
    <!-- {0} = changed conversation count -->
    <sys:String x:Key="Status_DiffComputed">{0} changed conversation(s)</sys:String>
    <!-- Shown when the folder is not a git repository or git is not installed -->
    <sys:String x:Key="Status_DiffNoRepo">This folder isn't a git repository, or git isn't installed.</sys:String>
    <!-- {0} = endpoint label (branch name, commit, etc.) -->
    <sys:String x:Key="Status_DiffBadRef">Couldn't read the '{0}' version. It may not exist in this repository.</sys:String>
    <!-- Shown when the working-copy project file cannot be found on disk -->
    <sys:String x:Key="Status_DiffFileNotFound">Couldn't find your project file to compare.</sys:String>
    <!-- {0} = endpoint label; shown when file is locked or unreadable -->
    <sys:String x:Key="Status_DiffReadError">Couldn't read the '{0}' version: the file may be locked or unreadable.</sys:String>
    <!-- {0} = endpoint label; shown when the file was read fine but its contents are not a valid project (corrupt or hand-edited) -->
    <sys:String x:Key="Status_DiffParseError">Couldn't understand the '{0}' version: the file looks damaged or isn't a valid project file.</sys:String>
    <!-- {0} = endpoint label; fallback for unexpected load failures -->
    <sys:String x:Key="Status_DiffLoadError">Couldn't load the '{0}' version to compare.</sys:String>
    <!-- Shown in the canvas hint area when the diff canvas cannot be built -->
    <sys:String x:Key="DiffWindow_CanvasError">Couldn't build the comparison view for this conversation.</sys:String>
    <!-- {0} = number of changes brought in -->
    <sys:String x:Key="Status_BroughtIn">Brought in {0} change(s) to your copy.</sys:String>
    <!-- {0} = error message -->
    <sys:String x:Key="Status_BringInError">Couldn't bring in the changes: {0}</sys:String>
    <!-- {0} = project name -->
    <sys:String x:Key="Status_BroughtInApplied">Brought changes into '{0}'. Use Undo bring-in to reverse it.</sys:String>
    <sys:String x:Key="ToolTip_DiffLeftPicker">This is your copy — the version that changes are brought into. You can also pick a saved version here if you want.</sys:String>
    <sys:String x:Key="ToolTip_DiffRightPicker">The other version to compare your copy against. Ticked changes are brought from here into your copy.</sys:String>
    <sys:String x:Key="ToolTip_DiffChangedList">Conversations that differ between the selected versions — click to inspect</sys:String>
    <sys:String x:Key="Diff_BringInButton">Bring in</sys:String>
    <sys:String x:Key="Diff_Hint">Tick the changes you want to bring into your copy, then Bring in.</sys:String>
    <sys:String x:Key="Diff_AutoPullLabel">Also bring in linked nodes</sys:String>
    <sys:String x:Key="ToolTip_Diff_AutoPull">When ticking a change, also tick the added nodes it links to, so brought-in links don't point at nodes that were never created. Turn off for surgical single-node picks.</sys:String>
    <!-- {0} = node ID integer -->
    <sys:String x:Key="Diff_NodeLine">Line {0}</sys:String>
    <!-- {0} = number of dangling links -->
    <sys:String x:Key="Diff_DanglingWarning">{0} link(s) may not lead anywhere</sys:String>
    <sys:String x:Key="Diff_ViewChanges">Changes</sys:String>
    <sys:String x:Key="Diff_ViewPreview">Applied preview</sys:String>
    <sys:String x:Key="Diff_LegendAdded">Added</sys:String>
    <sys:String x:Key="Diff_LegendChanged">Changed</sys:String>
    <sys:String x:Key="Diff_LegendRemoved">Removed</sys:String>
    <sys:String x:Key="Diff_DanglingHeader">Heads up: some links may not lead anywhere after this.</sys:String>
    <!-- {0} = conversation, {1} = source node id, {2} = removed target node id -->
    <sys:String x:Key="Diff_DanglingRow">{0}: node {1} → node {2} (target removed)</sys:String>
    <sys:String x:Key="ToolTip_Diff_DanglingPanel">Lists links whose destination node will not exist after bringing in these changes. They are allowed, but those links will lead nowhere in-game.</sys:String>
    <sys:String x:Key="ToolTip_Diff_BringIn">Brings the ticked changes into your copy and saves it straight away. Your copy must be one of the two versions being compared.</sys:String>
    <sys:String x:Key="ToolTip_Diff_ViewToggle">Switch between seeing everything that differs between the two versions, and a preview of what your copy will look like after you bring in the ticked changes.</sys:String>
    <sys:String x:Key="ToolTip_Diff_ExpandConversation">Show or hide the changed lines in this conversation.</sys:String>
    <sys:String x:Key="Diff_HelpButton">?</sys:String>
    <sys:String x:Key="Diff_UndoBringIn">Undo bring-in</sys:String>
    <sys:String x:Key="ToolTip_Diff_Help">Open a short guide explaining how comparing versions and bringing in changes works.</sys:String>
    <sys:String x:Key="ToolTip_Diff_UndoBringIn">Reverses the last set of changes you brought in, restoring your copy to how it was just before.</sys:String>
    <sys:String x:Key="DiffHelp_Title">Comparing versions — help</sys:String>
    <sys:String x:Key="DiffHelp_ColourKeyHeader">What the colours mean</sys:String>
    <sys:String x:Key="DiffHelp_Added">Green — a line that was added.</sys:String>
    <sys:String x:Key="DiffHelp_Changed">Orange — a line that was changed.</sys:String>
    <sys:String x:Key="DiffHelp_Removed">Red — a line that was removed.</sys:String>
    <sys:String x:Key="DiffHelp_CompareHeader">Comparing two versions</sys:String>
    <sys:String x:Key="DiffHelp_CompareBody">Pick two versions of your dialogue at the top. The list shows every conversation that differs between them; click one to see it.</sys:String>
    <sys:String x:Key="DiffHelp_ViewsHeader">The two views</sys:String>
    <sys:String x:Key="DiffHelp_ViewsBody">"Changes" shows everything different between the two versions. "Applied preview" shows what your copy will look like after you bring in the lines you have ticked.</sys:String>
    <sys:String x:Key="DiffHelp_BringInHeader">Bringing in changes</sys:String>
    <sys:String x:Key="DiffHelp_BringInBody">Tick the lines you want, then press "Bring in". The changes are written into your own copy and saved. Your copy must be one of the two versions on screen.</sys:String>
    <sys:String x:Key="DiffHelp_UndoHeader">Undo</sys:String>
    <sys:String x:Key="DiffHelp_UndoBody">"Undo bring-in" reverses the last set of changes you brought in.</sys:String>
    <sys:String x:Key="DiffHelp_LinksHeader">A note on links</sys:String>
    <sys:String x:Key="DiffHelp_LinksBody">If you bring in a line that points to a line you removed, you will see a warning. It is safe to continue, but that link may not lead anywhere.</sys:String>

    <!-- Diff: before/after node detail panel -->
