<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!--
        TRANSLATOR NOTES
        ════════════════
        • {0}, {1} … are positional placeholders — preserve them exactly.
        • Symbols used as button icons (?, +, −, ⊞, ⊟, 📌, ✦, ♀, ⚙) are
          universal UI glyphs and do not need translating.
        • Game-data enum values that appear verbatim in files (ShowOnce, Always,
          Never, Conversation, Bark, None, OnceEver) are intentionally NOT in
          this file — they are technical identifiers, not UI copy.
        • Script-prefix tokens ([Enter], [Exit], [Update]) and the condition
          operator "NOT" originate in DialogEditor.Core, which has no UI
          dependency. They are a known localisation gap.
    -->

    <!-- ─── Status bar ─────────────────────────────────────────────────── -->
    <!-- Shown at app startup before any folder is opened -->
    <sys:String x:Key="Status_OpenFolder">Open a game folder to begin.</sys:String>
    <!-- Shown when the selected folder is not a valid PoE1 or PoE2 install root -->
    <sys:String x:Key="Status_FolderNotRecognized">Folder not recognised as PoE1 or PoE2 root.</sys:String>
    <!-- {0} = game name (e.g. "Pillars of Eternity"), {1} = full folder path -->
    <sys:String x:Key="Status_FolderLoaded">{0} — {1}</sys:String>
    <!-- {0} = conversation file name, {1} = number of nodes in the conversation -->
    <sys:String x:Key="Status_ConversationLoaded">{0} — {1} nodes</sys:String>
    <!-- {0} = conversation file name, {1} = exception message -->
    <sys:String x:Key="Status_LoadError">Error loading {0}: {1}</sys:String>

    <!-- ─── Speaker fallback names ─────────────────────────────────────── -->
    <!-- Shown in the node title and detail panel when the speaker GUID is
         not resolved to a named character. These are category labels, not
         character names. -->
    <sys:String x:Key="Speaker_Npc">NPC</sys:String>
    <sys:String x:Key="Speaker_Player">Player</sys:String>
    <sys:String x:Key="Speaker_Narrator">Narrator</sys:String>
    <sys:String x:Key="Speaker_Script">Script</sys:String>
    <sys:String x:Key="Speaker_Unknown">Unknown</sys:String>

    <!-- ─── Node canvas card ────────────────────────────────────────────── -->
    <!-- Title line on each node card.
         {0} = node ID (integer), {1} = speaker name, {2} = optional suffix
         (Node_PlayerChoiceSuffix when the node is a player response, else empty) -->
    <sys:String x:Key="Node_Title">Node {0} · {1}{2}</sys:String>
    <!-- Shown as the node body text when the stringtable file cannot be located -->
    <sys:String x:Key="Node_TextUnavailable">[text unavailable — stringtable not found]</sys:String>
    <!-- Appended to the node title for player-choice nodes; includes a leading space -->
    <sys:String x:Key="Node_PlayerChoiceSuffix"> ✦</sys:String>
    <!-- Appended to the node footer when a female text variant exists;
         includes two leading spaces for visual separation from the condition count -->
    <sys:String x:Key="Node_FemaleTextSuffix">  ♀</sys:String>
    <!-- Footer text when the node has exactly one condition. {0} = 1 -->
    <sys:String x:Key="Node_ConditionSingular">⚙ {0} condition</sys:String>
    <!-- Footer text when the node has two or more conditions. {0} = count -->
    <sys:String x:Key="Node_ConditionPlural">⚙ {0} conditions</sys:String>
    <!-- Footer text when the node has no conditions -->
    <sys:String x:Key="Node_NoConditions">[ No conditions ]</sys:String>
    <!-- Canvas toolbar: node count label. {0} = number of nodes loaded -->
    <sys:String x:Key="Statistics_Summary">{0} nodes  ({1} NPC / {2} player)  ·  {3:N0} words</sys:String>
    <sys:String x:Key="ToolTip_Statistics">Node and word counts for the current conversation. Female-text word count (if any) is shown in the tooltip.</sys:String>
    <sys:String x:Key="Statistics_FemaleDetail">Female text: {0:N0} words</sys:String>

    <!-- ─── Detail panel — values ──────────────────────────────────────── -->
    <!-- Node type shown in the NODE row of the detail panel -->
    <sys:String x:Key="NodeDetail_PlayerChoice">Player Choice</sys:String>
    <sys:String x:Key="NodeDetail_NpcLine">NPC Line</sys:String>
    <!-- Shown in the FEMALE TEXT row when the node has no separate female variant -->
    <sys:String x:Key="NodeDetail_SameAsDefault">(same as default)</sys:String>
    <!-- Placeholder shown when a list is empty (conditions, scripts, links) -->
    <sys:String x:Key="NodeDetail_None">(none)</sys:String>

    <!-- ─── Links formatting (LINKS TO section) ───────────────────────── -->
    <!-- Arrow prefix before each target node ID, e.g. "→ 5" -->
    <sys:String x:Key="Link_Arrow">→</sys:String>
    <!-- Prefix for the random-weight annotation, e.g. "w:0.5" -->
    <sys:String x:Key="Link_WeightPrefix">w:</sys:String>

    <!-- ─── Dialogs ────────────────────────────────────────────────────── -->
    <!-- Title bar of the OS folder-picker dialog -->
    <sys:String x:Key="Dialog_SelectFolder">Select game root folder</sys:String>

    <!-- ─── Conversation browser ──────────────────────────────────────── -->
    <!-- Display name for the virtual root folder when a conversation file
         sits directly in the root without a sub-folder -->
    <sys:String x:Key="Browser_RootFolder">(root)</sys:String>
    <!-- Panel header label -->
    <sys:String x:Key="Browser_Header">CONVERSATIONS</sys:String>
    <!-- New conversation feature -->
    <sys:String x:Key="Label_NewConversation_Suffix"> (new)</sys:String>
    <sys:String x:Key="Label_NewConversationsFolder">(new)</sys:String>
    <sys:String x:Key="Dialog_NewConversation_Create">Create</sys:String>
    <sys:String x:Key="Button_NewConversation">New conversation…</sys:String>
    <sys:String x:Key="ToolTip_NewConversation">Create a new conversation that doesn't yet exist in the game folder. It will be written to disk when you apply the patch (F5).</sys:String>
    <sys:String x:Key="Dialog_NewConversation_Title">New Conversation</sys:String>
    <sys:String x:Key="Dialog_NewConversation_Prompt">Enter a name for the new conversation file (no extension, e.g. city_market_guard):</sys:String>
    <sys:String x:Key="Dialog_NewConversation_Placeholder">my_new_conversation</sys:String>
    <sys:String x:Key="Status_NewConversationAdded">New conversation '{0}' added — add nodes, then Ctrl+S to save.</sys:String>
    <sys:String x:Key="Status_NewConversationDuplicate">A conversation named '{0}' already exists.</sys:String>
    <!-- {0} = the name the user entered -->
    <sys:String x:Key="Status_NewConversationInvalidName">'{0}' contains characters that are not allowed in a file name.</sys:String>
    <!-- Placeholder text inside the filter text box -->
    <sys:String x:Key="Placeholder_FilterConversations">Filter conversations…</sys:String>

    <!-- ─── Canvas search ──────────────────────────────────────────────── -->
    <!-- Placeholder text inside the node search box -->
    <sys:String x:Key="Placeholder_SearchNodes">Search nodes…</sys:String>

    <!-- ─── Application ───────────────────────────────────────────────── -->
    <!-- Title bar of the main window -->
    <sys:String x:Key="App_Title">Pillars Dialog Editor</sys:String>

    <!-- ─── Toolbar ────────────────────────────────────────────────────── -->
    <!-- Label / content of the "open folder" button -->
    <sys:String x:Key="Button_OpenFolder">Open Game Folder…</sys:String>
    <!-- Label preceding the language selector drop-down -->
    <sys:String x:Key="Label_Language">Language:</sys:String>

    <!-- ─── Detail panel — section labels ─────────────────────────────── -->
    <!-- Panel header shown above the detail pane -->
    <sys:String x:Key="Label_NodeDetails">NODE DETAILS</sys:String>
    <!-- Prompt shown in the centre of the panel when no node is selected -->
    <sys:String x:Key="Label_SelectNode">Select a node to view details.</sys:String>
    <!-- Section label for the default (male) dialogue text -->
    <sys:String x:Key="Label_DefaultMaleText">DEFAULT / MALE TEXT</sys:String>
    <sys:String x:Key="Label_FemaleText">FEMALE TEXT</sys:String>

    <!-- ─── Detail panel — property group headers ────────────────────── -->
    <sys:String x:Key="Label_GroupIdentity">IDENTITY</sys:String>
    <sys:String x:Key="Label_GroupDisplay">DISPLAY</sys:String>
    <sys:String x:Key="Label_GroupLogic">LOGIC</sys:String>
    <sys:String x:Key="Label_GroupVoice">VOICE</sys:String>
    <sys:String x:Key="Label_GroupLinks">LINKS</sys:String>

    <!-- ─── Detail panel — property row labels ───────────────────────── -->
    <sys:String x:Key="PropertyRow_NodeId">Node ID</sys:String>
    <sys:String x:Key="PropertyRow_Type">Type</sys:String>
    <sys:String x:Key="PropertyRow_Speaker">Speaker</sys:String>
    <sys:String x:Key="PropertyRow_SpeakerCategory">Speaker category</sys:String>
    <sys:String x:Key="ToolTip_SpeakerCategory">The speaker category controls the node colour on the canvas and which speaker slot the line occupies (NPC, Player, Narrator, or Script)</sys:String>
    <sys:String x:Key="PropertyRow_SpeakerGuid">Speaker GUID</sys:String>
    <sys:String x:Key="PropertyRow_Listener">Listener</sys:String>
    <sys:String x:Key="PropertyRow_DisplayType">Display Type</sys:String>
    <sys:String x:Key="PropertyRow_Persistence">Persistence</sys:String>
    <sys:String x:Key="PropertyRow_ActorDirection">Actor Direction</sys:String>
    <sys:String x:Key="PropertyRow_Conditions">Conditions</sys:String>
    <sys:String x:Key="PropertyRow_Scripts">Scripts</sys:String>
    <sys:String x:Key="PropertyRow_Comments">Comments</sys:String>
    <sys:String x:Key="PropertyRow_ExternalVO">External VO</sys:String>
    <sys:String x:Key="PropertyRow_HasVO">Has VO</sys:String>
    <sys:String x:Key="PropertyRow_HideSpeaker">Hide Speaker</sys:String>

    <!-- ─── Legend panel — section headers ────────────────────────────── -->
    <!-- Title bar of the legend overlay (all-caps panel header) -->
    <sys:String x:Key="Legend_Header">LEGEND</sys:String>
    <!-- Window title bar — sentence/title case -->
    <sys:String x:Key="Legend_WindowTitle">Legend</sys:String>
    <sys:String x:Key="Legend_Connections">CONNECTIONS</sys:String>
    <sys:String x:Key="Legend_NodeTypes">NODE TYPES</sys:String>
    <sys:String x:Key="Legend_Symbols">SYMBOLS</sys:String>
    <!-- Canvas controls section -->
    <sys:String x:Key="Legend_Canvas">CANVAS</sys:String>
    <!-- Conversation browser controls section -->
    <sys:String x:Key="Legend_Browser">BROWSER</sys:String>

    <!-- ─── Legend panel — connection type names and descriptions ──────── -->
    <!-- These match the QuestionNodeTextDisplay enum values used in the game
         files; keep the name identical to the game value for consistency. -->
    <sys:String x:Key="Legend_ShowOnce">ShowOnce</sys:String>
    <!-- Leading space is intentional — it follows the bold name inline -->
    <sys:String x:Key="Legend_ShowOnce_Desc"> — shown once, hidden after selection</sys:String>
    <sys:String x:Key="Legend_Always">Always</sys:String>
    <sys:String x:Key="Legend_Always_Desc"> — always available, even after selection</sys:String>
    <sys:String x:Key="Legend_Never">Never</sys:String>
    <sys:String x:Key="Legend_Never_Desc"> — never shown to the player</sys:String>

    <!-- ─── Legend panel — node type descriptions ─────────────────────── -->
    <sys:String x:Key="Legend_NpcLine">NPC line</sys:String>
    <sys:String x:Key="Legend_PlayerChoice">Player choice</sys:String>
    <!-- Parenthetical note appended after "Player choice" -->
    <sys:String x:Key="Legend_PlayerChoiceMark">(marked ✦)</sys:String>
    <sys:String x:Key="Legend_Narrator">Narrator</sys:String>
    <sys:String x:Key="Legend_ScriptAction">Script / automated action</sys:String>

    <!-- ─── Legend panel — symbol descriptions ────────────────────────── -->
    <!-- "N" is a literal count, not a placeholder — leave it as-is -->
    <sys:String x:Key="Legend_Symbol_Conditions">node has N visibility conditions</sys:String>
    <sys:String x:Key="Legend_Symbol_FemaleText">female text variant exists</sys:String>
    <sys:String x:Key="Legend_Symbol_PlayerChoice">player choice node (in title)</sys:String>

    <!-- ─── Legend panel — keyboard shortcuts section ───────────────────── -->
    <sys:String x:Key="Legend_Shortcuts">KEYBOARD SHORTCUTS</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlN_Desc">new project</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlO_Desc">open project</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlS_Desc">save project</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlShiftO">Ctrl+Shift+O</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlShiftO_Desc">open game folder</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlComma">Ctrl+,</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlComma_Desc">settings</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlZ_Desc">undo</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlY_Desc">redo</sys:String>
    <sys:String x:Key="Legend_Shortcut_Del">Delete</sys:String>
    <sys:String x:Key="Legend_Shortcut_Del_Desc">delete selected node</sys:String>
    <sys:String x:Key="Legend_Shortcut_F5_Desc">test patch</sys:String>
    <sys:String x:Key="Legend_Shortcut_F6_Desc">restore conversation after testing</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlShiftB">Ctrl+Shift+B</sys:String>
    <sys:String x:Key="Legend_Shortcut_CtrlShiftB_Desc">restore backup (all conversations)</sys:String>

    <!-- ─── Legend panel — canvas control descriptions ─────────────────── -->
    <!-- "Fit" is the button label as it appears on the toolbar -->
    <sys:String x:Key="Legend_Control_Fit">Fit</sys:String>
    <sys:String x:Key="Legend_Control_Fit_Desc">fit all nodes into view</sys:String>
    <!-- Literal button labels, not translatable symbols -->
    <sys:String x:Key="Legend_Control_Zoom">+ / −</sys:String>
    <sys:String x:Key="Legend_Control_Zoom_Desc">zoom in / out</sys:String>
    <!-- ⌂ is the house / home symbol used on the "go to root" button -->
    <sys:String x:Key="Legend_Control_Root">⌂</sys:String>
    <sys:String x:Key="Legend_Control_Root_Desc">jump to root node (ID 0)</sys:String>
    <sys:String x:Key="Legend_Control_Scroll">Scroll</sys:String>
    <sys:String x:Key="Legend_Control_Scroll_Desc">zoom</sys:String>
    <sys:String x:Key="Legend_Control_Drag">Drag</sys:String>
    <sys:String x:Key="Legend_Control_Drag_Desc">pan the canvas</sys:String>
    <!-- ⊞ and ⊟ are the expand-all / collapse-all folder buttons -->
    <sys:String x:Key="Legend_Control_ExpandCollapse">⊞ / ⊟</sys:String>
    <sys:String x:Key="Legend_Control_ExpandCollapse_Desc">expand / collapse all folders</sys:String>
    <sys:String x:Key="Legend_Control_Filter">Filter</sys:String>
    <sys:String x:Key="Legend_Control_Filter_Desc">type to filter conversations by name</sys:String>
    <!-- Keyboard shortcuts shown at the bottom of the canvas and browser control sections -->
    <sys:String x:Key="Legend_Control_CtrlF">Ctrl+F</sys:String>
    <sys:String x:Key="Legend_Control_CtrlF_Desc">focus node search</sys:String>
    <sys:String x:Key="Legend_Control_Escape">Escape</sys:String>
    <sys:String x:Key="Legend_Control_Escape_Desc">clear search or filter</sys:String>
    <!-- Conversations panel auto-hide / flyout behaviour -->
    <sys:String x:Key="Legend_Browser_Pin">📌 pinned</sys:String>
    <sys:String x:Key="Legend_Browser_Pin_Desc">panel stays open; click 📌 to switch to flyout mode</sys:String>
    <sys:String x:Key="Legend_Browser_Flyout">📌 unpinned</sys:String>
    <sys:String x:Key="Legend_Browser_Flyout_Desc">click the strip to open temporarily; closes on click-outside or selection</sys:String>

    <!-- ─── Tooltips — toolbar ─────────────────────────────────────────── -->
    <sys:String x:Key="ToolTip_OpenFolder">Open a PoE1 or PoE2 game root folder</sys:String>
    <sys:String x:Key="ToolTip_Language">Switch the display language for dialogue text</sys:String>
    <sys:String x:Key="ToolTip_HelpToggle">Show / hide the legend and keyboard reference</sys:String>

    <!-- ─── Tooltips — canvas ──────────────────────────────────────────── -->
    <sys:String x:Key="ToolTip_FitToScreen">Fit all nodes into view</sys:String>
    <sys:String x:Key="ToolTip_ZoomIn">Zoom in</sys:String>
    <sys:String x:Key="ToolTip_ZoomOut">Zoom out</sys:String>
    <!-- ⌂ button: centres the viewport on the root node (ID 0) -->
    <sys:String x:Key="ToolTip_JumpToRoot">Jump to root node (ID 0)</sys:String>
    <!-- Ctrl+F shortcut is mentioned here so it appears in the hover tooltip -->
    <sys:String x:Key="ToolTip_SearchNodes">Search nodes by ID, dialogue text, or speaker name (Ctrl+F)</sys:String>
    <sys:String x:Key="ToolTip_ClearSearch">Clear search</sys:String>
    <!-- Minimap overlay in the bottom-right corner of the canvas -->
    <sys:String x:Key="ToolTip_Minimap">Canvas overview — drag to pan</sys:String>

    <!-- ─── Tooltips — browser ─────────────────────────────────────────── -->
    <!-- ⊞ button: expands all conversation folders in the tree -->
    <sys:String x:Key="ToolTip_ExpandAll">Expand all</sys:String>
    <!-- ⊟ button: collapses all conversation folders in the tree -->
    <sys:String x:Key="ToolTip_CollapseAll">Collapse all</sys:String>
    <sys:String x:Key="ToolTip_FilterConversations">Filter conversations by filename</sys:String>
    <sys:String x:Key="ToolTip_ClearFilter">Clear filter</sys:String>

    <!-- ─── Tooltips — legend ──────────────────────────────────────────── -->
    <!-- × button in the top-right corner of the legend panel -->
    <sys:String x:Key="ToolTip_CloseLegend">Close legend</sys:String>

    <!-- ─── Tooltips — collapsible side panels ────────────────────────── -->
    <!-- − button (collapse) and + button (expand) on both side panels -->
    <sys:String x:Key="ToolTip_TogglePanel">Expand / collapse panel</sys:String>
    <!-- 📌 pin button on the Conversations panel only.
         When unpinned the panel acts as a flyout: it closes when you click
         outside it or select a conversation. -->
    <sys:String x:Key="ToolTip_PinPanel">Pin panel open — when unpinned, acts as a flyout (closes on click-outside or conversation selection)</sys:String>

    <!-- ─── Editing — toolbar buttons ───────────────────────────────────── -->
    <sys:String x:Key="Button_Undo">↩</sys:String>
    <sys:String x:Key="Button_Redo">↪</sys:String>
    <sys:String x:Key="Button_Save">Save</sys:String>
    <sys:String x:Key="Button_RestoreBackup">Restore Backup…</sys:String>
    <!-- {0} = description of the action that will be undone -->
    <sys:String x:Key="ToolTip_Undo_Format">Undo: {0} (Ctrl+Z)</sys:String>
    <sys:String x:Key="ToolTip_Undo_NoHistory">Nothing to undo (Ctrl+Z)</sys:String>
    <sys:String x:Key="ToolTip_Redo_Format">Redo: {0} (Ctrl+Y)</sys:String>
    <sys:String x:Key="ToolTip_Redo_NoHistory">Nothing to redo (Ctrl+Y)</sys:String>
    <sys:String x:Key="ToolTip_Save">Save conversation to disk (Ctrl+S)</sys:String>
    <sys:String x:Key="ToolTip_RestoreBackup">Restore all conversation files from the original backup</sys:String>

    <!-- ─── Editing — canvas context menus ──────────────────────────────── -->
    <sys:String x:Key="Menu_DeleteNode">Delete node</sys:String>
    <sys:String x:Key="Menu_AddConnectedNode">Add connected node</sys:String>
    <sys:String x:Key="Menu_DeleteConnection">Delete connection</sys:String>

    <!-- ─── Editing — status messages ───────────────────────────────────── -->
    <!-- {0} = conversation name -->
    <sys:String x:Key="Status_Saved">Saved: {0}</sys:String>
    <!-- {0} = conversation name, {1} = error message -->
    <sys:String x:Key="Status_SaveError">Save failed for {0}: {1}</sys:String>
    <sys:String x:Key="Status_BackupInProgress">Backing up conversation files…</sys:String>
    <!-- {0} = backup folder path -->
    <sys:String x:Key="Status_BackupComplete">Backup complete — {0}</sys:String>
    <!-- {0} = error message -->
    <sys:String x:Key="Status_BackupError">Backup failed: {0}</sys:String>
    <sys:String x:Key="Status_RestoreInProgress">Restoring from backup…</sys:String>
    <sys:String x:Key="Status_RestoreComplete">Restore complete — reload to see changes.</sys:String>
    <!-- {0} = error message -->
    <sys:String x:Key="Status_RestoreError">Restore failed: {0}</sys:String>
    <sys:String x:Key="Status_NoBackupFound">No backup found for this game folder.</sys:String>

    <!-- ─── Editing — dialogs ────────────────────────────────────────────── -->
    <sys:String x:Key="Dialog_SelectBackupFolder">Select backup destination folder</sys:String>

    <!-- ─── Editing — unsaved-changes prompt ────────────────────────────── -->
    <!-- {0} = conversation name -->
    <sys:String x:Key="UnsavedChanges_Title">Unsaved Changes</sys:String>
    <sys:String x:Key="UnsavedChanges_Message">'{0}' has unsaved changes.

Saving records your edits to the open project — game files are not touched until you run Test Patch (F5).</sys:String>
    <sys:String x:Key="UnsavedChanges_Save">Save to Project</sys:String>
    <sys:String x:Key="UnsavedChanges_Discard">Discard Changes</sys:String>
    <sys:String x:Key="UnsavedChanges_Cancel">Stay Here</sys:String>

    <!-- ─── Detail panel — editable field labels ────────────────────────── -->
    <sys:String x:Key="PropertyRow_ListenerGuid">Listener GUID</sys:String>

    <!-- ─── Detail panel — combobox option values ───────────────────────── -->
    <sys:String x:Key="Option_QTD_Default">(default)</sys:String>
    <sys:String x:Key="Option_NpcLine">NPC Line</sys:String>
    <sys:String x:Key="Option_PlayerChoice">Player Choice</sys:String>
    <sys:String x:Key="Option_DisplayConversation">Conversation</sys:String>
    <sys:String x:Key="Option_DisplayBark">Bark</sys:String>
    <sys:String x:Key="Bark_Warning_TextTooLong">Bark text exceeds {0} characters and may be cut off in-game.</sys:String>
    <sys:String x:Key="Bark_Warning_PlayerChoiceChild">Bark nodes should not lead to player choice responses.</sys:String>
    <sys:String x:Key="Option_PersistenceNone">None</sys:String>
    <sys:String x:Key="Option_PersistenceOnceEver">OnceEver</sys:String>

    <!-- ─── Detail panel — script editor ───────────────────────────────── -->
    <sys:String x:Key="Button_EditScripts">Edit…</sys:String>
    <sys:String x:Key="ToolTip_EditScripts">Open the script editor to add, edit, or remove scripts fired when this node is shown, exited, or updated</sys:String>
    <sys:String x:Key="Placeholder_ScriptPicker">Search catalogue or type a FullName…</sys:String>
    <sys:String x:Key="ToolTip_ScriptPicker">Select a known script from the catalogue — parameters and their types will be pre-populated. Or type a C# reflection FullName directly, e.g. Void SetGlobalValue(String, Int32), for scripts not in the catalogue.</sys:String>
    <sys:String x:Key="ToolTip_AddScriptEnter">Add the selected or typed script to the On Enter list</sys:String>
    <sys:String x:Key="ToolTip_AddScriptExit">Add the selected or typed script to the On Exit list</sys:String>
    <sys:String x:Key="ToolTip_AddScriptUpdate">Add the selected or typed script to the On Update list</sys:String>
    <sys:String x:Key="Label_ScriptSection_Enter">ON ENTER  (fires when the node is shown)</sys:String>
    <sys:String x:Key="Label_ScriptSection_Exit">ON EXIT  (fires when the player leaves the node)</sys:String>
    <sys:String x:Key="Label_ScriptSection_Update">ON UPDATE  (fires on each update tick while the node is active)</sys:String>
    <sys:String x:Key="ToolTip_ScriptEditorCancel">Discard all changes and close</sys:String>
    <sys:String x:Key="ToolTip_ScriptEditorOK">Apply these scripts to the node</sys:String>

    <!-- ─── Detail panel — condition editor ─────────────────────────────── -->
    <sys:String x:Key="Label_GroupConditions">CONDITIONS</sys:String>
    <sys:String x:Key="Button_EditConditions">Edit…</sys:String>
    <sys:String x:Key="ToolTip_EditConditions">Open the condition editor to add, edit, or remove conditions</sys:String>
    <sys:String x:Key="Button_AddCondition">+ Add</sys:String>
    <sys:String x:Key="ToolTip_AddCondition">Add selected condition to the list</sys:String>
    <sys:String x:Key="ToolTip_DeleteCondition">Remove this condition</sys:String>
    <sys:String x:Key="ToolTip_MoveConditionUp">Move condition up</sys:String>
    <sys:String x:Key="ToolTip_MoveConditionDown">Move condition down</sys:String>
    <sys:String x:Key="Label_Condition_NOT">NOT</sys:String>
    <sys:String x:Key="Option_ConditionAnd">And</sys:String>
    <sys:String x:Key="Option_ConditionOr">Or</sys:String>
    <sys:String x:Key="Placeholder_PickCondition">Pick a condition…</sys:String>
    <sys:String x:Key="ToolTip_PickCondition">Select a condition from the catalogue to add to this node</sys:String>
    <sys:String x:Key="ToolTip_ConditionNot">Negate this condition — it must evaluate to FALSE for the check to pass</sys:String>
    <sys:String x:Key="ToolTip_ConditionBranch">Grouped condition block — click Edit group… to modify its contents</sys:String>
    <sys:String x:Key="Label_BranchGroupTitle">Condition Group</sys:String>
    <sys:String x:Key="Button_EditBranchGroup">Edit group…</sys:String>
    <sys:String x:Key="Button_NewGroup">+ New group</sys:String>
